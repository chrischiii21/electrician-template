---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero2 from "../components/sections/Hero2.astro";
import TrustBar from "../components/sections/TrustBar.astro";
import AboutWithServices from "../components/sections/AboutWithServices.astro";
import Services from "../components/sections/Services.astro";
import MaintenancePlan from "../components/sections/MaintenancePlan.astro";
import Financing from "../components/sections/Financing.astro";
import Specials from "../components/sections/Specials.astro";
import CTARibbon from "../components/sections/CTARibbon.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import FeaturedWorks from "../components/sections/FeaturedWorks.astro";
import FAQ from "../components/sections/FAQ.astro";
import ServiceAreas from "../components/sections/ServiceAreas.astro";
import PricingTiers from "../components/sections/PricingTiers.astro";
import CouponModal from "../components/sections/CouponModal.astro";
---

<BaseLayout title="Commercial Services | Electrician Services">
    <!-- Header (in BaseLayout) -->

    <!-- Hero -->
    <Hero2
        title="Commercial Services"
        eyebrow="Commercial"
        description="Professional electrical solutions for your commercial needs"
        backgroundImage="https://images.unsplash.com/photo-1581092918056-0c4c3acd3789?w=1200&h=600&fit=crop"
    />

    <!-- Trust Bar -->
    <TrustBar />

    <!-- About & Other Services (Unified Split Layout) -->
    <AboutWithServices
        eyebrow="Our Expertise"
        title="Quality Commercial Electrical Solutions"
        description="We build multi-family and affordable housing communities, industrial facilities, public and private healthcare facilities, fitness centers and office buildings. We improve the supply chain management process, increase operational efficiencies and build environments that foster creativity."
        stats={[
            { number: "67+", label: "Projects Done" },
            { number: "24/7", label: "Support" },
            { number: "100%", label: "Satisfaction" },
        ]}
        image="https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=800&q=80"
        currentCategory="Commercial"
    />

    <!-- Services - Sub Category -->
    <Services category="Commercial" />

    <!-- Maintenance Plans, Financing Plans, Specials & Offers -->
    <PricingTiers />

    <!-- CTA Banner -->
    <CTARibbon />

    <!-- Testimonials -->
    <Testimonials />

    <!-- Featured Works -->
    <FeaturedWorks />

    <!-- FAQs - Unique -->
    <FAQ pageType="commercial" />

    <!-- Service Area Map -->
    <ServiceAreas />

    <!-- Footer (in BaseLayout) -->

    <CouponModal
        discount="15"
        discountType="percentage"
        code="COMMERCIAL15"
        title="Commercial Electrical Special"
        description="Save 15% on any commercial electrical service. Perfect for businesses looking to improve safety and capacity."
        features={[
            "Licensed & Insured Electricians",
            "Minimal Business Disruption",
            "Code Compliant Installation",
            "Free Safety Inspection",
        ]}
        ctaText="Get Commercial Quote"
        dismissText="Maybe later"
        ctaLink="/contact"
        expiresIn="47:59:59"
        autoOpen={true}
    />
</BaseLayout>
