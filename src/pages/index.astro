---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/sections/Hero.astro";
import TrustBar from "../components/sections/TrustBar.astro";
import Services from "../components/sections/Services.astro";
import Specials from "../components/sections/Specials.astro";
import WhyUs from "../components/sections/WhyUs.astro";
import Financing from "../components/sections/Financing.astro";
import CTARibbon from "../components/sections/CTARibbon.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import AboutUs from "../components/sections/AboutUs.astro";
import FAQ from "../components/sections/FAQ.astro";
import ServiceAreas from "../components/sections/ServiceAreas.astro";
import FinalCTA from "../components/sections/FinalCTA.astro";
import CouponModal from "../components/sections/CouponModal.astro";
import FeaturedWorks from "../components/sections/FeaturedWorks.astro";
---

<BaseLayout
	title="Professional Electrician Services | Licensed & Insured | 24/7 Emergency"
	description="Expert electrical services for residential, commercial, and emergency needs. Licensed electricians available 24/7 across California. Free estimates, same-day service, 100% satisfaction guaranteed."
>
	<Hero />
	<TrustBar />
	<Specials />
	<AboutUs />
	<Services />
	<FeaturedWorks />
	<Financing />
	<CTARibbon />
	<WhyUs />
	<Testimonials />
	<FAQ />
	<ServiceAreas />
	<FinalCTA />

	<CouponModal
		discount="15"
		discountType="percentage"
		code="POWER15"
		title="Welcome! Save on Your First Service"
		description="Get 15% off any electrical service — residential or commercial."
		features={[
			"New customers only",
			"All service types included",
			"No minimum spend",
			"Expires in 48 hours",
		]}
		ctaText="Claim My 15% Off"
		dismissText="No thanks, I'll pass"
		ctaLink="#contact"
		expiresIn="47:59:59"
		autoOpen={true}
	/>
</BaseLayout>
