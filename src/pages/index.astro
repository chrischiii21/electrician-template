---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/sections/Hero.astro";
import TrustBar from "../components/sections/TrustBar.astro";
import Specials from "../components/sections/Specials.astro";
import AboutUs from "../components/sections/AboutUs.astro";
import Services from "../components/sections/Services.astro";
import MaintenancePlan from "../components/sections/MaintenancePlan.astro";
import Financing from "../components/sections/Financing.astro";
import CTARibbon from "../components/sections/CTARibbon.astro";
import WhyUs from "../components/sections/WhyUs.astro";
import FeaturedWorks from "../components/sections/FeaturedWorks.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import FAQ from "../components/sections/FAQ.astro";
import ServiceAreas from "../components/sections/ServiceAreas.astro";
import CouponModal from "../components/sections/CouponModal.astro";
---

<BaseLayout title="Home | Electrician Services">
	<!-- Header (in BaseLayout) -->

	<!-- Hero -->
	<Hero />

	<!-- Trust Bar -->
	<TrustBar />

	<!-- Specials & Offers -->
	<Specials />

	<!-- About -->
	<AboutUs />

	<!-- Services -->
	<Services />

	<!-- Maintenance Plans -->
	<MaintenancePlan />

	<!-- Financing Plans -->
	<Financing />

	<!-- CTA Banner -->
	<CTARibbon />

	<!-- Why Choose Us -->
	<WhyUs />

	<!-- Featured Works -->
	<FeaturedWorks />

	<!-- Testimonials -->
	<Testimonials />

	<!-- FAQs - Global -->
	<FAQ pageType="home" />

	<!-- Service Area Map -->
	<ServiceAreas />

	<!-- Footer (in BaseLayout) -->

	<CouponModal
		discount="15"
		discountType="percentage"
		code="POWER15"
		title="Welcome! Save on Your First Service"
		description="Get 15% off any electrical service — residential or commercial."
		features={[
			"New customers only",
			"All service types included",
			"No minimum spend",
			"Expires in 48 hours",
		]}
		ctaText="Claim My 15% Off"
		dismissText="No thanks, I'll pass"
		ctaLink="#contact"
		expiresIn="47:59:59"
		autoOpen={true}
	/>
</BaseLayout>
