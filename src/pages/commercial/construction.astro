---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero2 from "../../components/sections/Hero2.astro";
import Testimonials from "../../components/sections/Testimonials.astro";
import FinalCTA from "../../components/sections/FinalCTA.astro";
import OffersAndFinancing from "../../components/sections/OffersAndFinancing.astro";
import FAQ from "../../components/sections/FAQ.astro";
import TrustBar from "../../components/sections/TrustBar.astro";
import CTARibbon from "../../components/sections/CTARibbon.astro";
import ServiceAreas from "../../components/sections/ServiceAreas.astro";
import CouponModal from "../../components/sections/CouponModal.astro";
import ServiceHighlight from "../../components/sections/ServiceHighlight.astro";
import RelatedServices from "../../components/sections/RelatedServices.astro";
---

<BaseLayout
    title="Ground-up Electrical Construction | Commercial Electricians | Licensed Contractors"
    description="Professional ground-up electrical construction services for commercial buildings. Complete electrical systems from excavation to final inspection. Licensed contractors with 15+ years experience. 100% inspection pass rate."
    canonical="https://example.com/commercial/construction"
>
    <Hero2
        title="Ground-up Electrical Construction"
        eyebrow="Commercial"
        description="Complete electrical construction services from the ground up"
        backgroundImage="https://images.unsplash.com/photo-1504384308090-c894fdcc538d?w=1200&h=600&fit=crop"
    />
    <ServiceHighlight
        contentTitle="Complete Electrical Systems From Ground Up"
        contentDescription="Ground-up electrical construction is our specialty. We coordinate with general contractors from day one, installing underground conduit during excavation, rough-in wiring during framing, and complete power distribution systems before walls close. Every wire, panel, and circuit is strategically placed for optimal performance and code compliance."
        contentDetails="We start with comprehensive load calculations and electrical blueprints tailored to your building's needs. Our team sizes service panels, plans circuit distribution, and coordinates with utility companies for main service installation—ensuring your new facility has reliable, efficient power from the moment you open."
        image="https://images.unsplash.com/photo-1621905251189-08b45d6a269e?w=600&h=800&fit=crop"
        stats={[
            {
                icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />',
                value: "250+",
                label: "New Buildings Wired",
            },
            {
                icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />',
                value: "15+",
                label: "Years in Construction",
            },
            {
                icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />',
                value: "100%",
                label: "Inspection Pass Rate",
            },
            {
                icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />',
                value: "96%",
                label: "On-Time Completion",
            },
        ]}
        phone="(555) 123-4567"
        hours="Mon-Sat 7:00-6:00"
    />
    <TrustBar />
    <OffersAndFinancing category="Commercial" />
    <Testimonials />
    <CTARibbon />
    <RelatedServices
        title="Other <span class='text-accent'>Commercial</span> Electrical Services"
        services={[
            {
                title: "Standby <span class='text-accent'>Power</span> Systems",
                description:
                    "Backup generators and UPS systems to keep your business running during power outages.",
                link: "/commercial/power-systems",
                icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />',
            },
            {
                title: "Commercial <span class='text-accent'>HVAC</span> Electrical",
                description:
                    "Electrical installations and maintenance for commercial heating, cooling, and ventilation systems.",
                link: "/commercial/hvac",
                icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />',
            },
            {
                title: "Electrical <span class='text-accent'>Panel</span> Upgrades",
                description:
                    "Panel replacements and upgrades to meet increased power demands for commercial facilities.",
                link: "/commercial/panels",
                icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />',
            },
        ]}
    />
    <FAQ />
    <ServiceAreas />
    <FinalCTA />
    <CouponModal
        discount="200"
        discountType="amount"
        code="CONSTRUCT200"
        title="Ground-up Construction Special"
        description="Save $200 on complete electrical systems for new construction projects. Professional installation from the ground up."
        features={[
            "New Construction Specialists",
            "Complete Electrical Systems",
            "Permit-Ready Work",
            "Project Timeline Guarantee",
        ]}
        ctaText="Start Your Project"
        dismissText="Not right now"
        ctaLink="/contact"
        expiresIn="47:59:59"
        autoOpen={true}
    />
</BaseLayout>
