        image: "/images/local-presence.jpg",
    },
];
---

<BaseLayout title="Los Angeles | Electrician Services">
    <Hero2
        title="Los Angeles"
        eyebrow="Service Area"
        description="Professional electrical services serving Los Angeles and surrounding areas"
        backgroundImage="https://images.unsplash.com/photo-1480714378408-67cf0d13bc1b?w=1200&h=600&fit=crop"
    />

    <TrustBar />

    <LocalServices />

    <WhyServiceArea city="Los Angeles" reasons={laReasons} />

    <ServiceAreaMap
        city="Los Angeles"
        neighborhoods={laNeighborhoods}
        totalElectricians={8}
    />

    <Specials />

    <Testimonials />

    <CTARibbon />

    <CouponModal
        discount="20"
        discountType="percentage"
        code="LA20"
        title="Los Angeles Exclusive Offer"
        description="Get 20% off any electrical service in Los Angeles and surrounding areas."
        features={[
            "Valid in all LA neighborhoods",
            "Residential & Commercial",
            "Same-day service available",
            "Expires in 48 hours",
        ]}
        ctaText="Book Now"
        dismissText="Not right now"
        ctaLink="#contact"
        expiresIn="47:59:59"
        data-auto-open-delay="2000"
    />

    <ExitModal
        discount="25"
        discountType="percentage"
        code="LA25"
        title="Don't Leave LA Without This Deal"
        subtitle="25% Off LA Services"
        description="We serve all of Los Angeles. Get 25% off your next electrical service in any LA neighborhood."
        features={[
            "Valid in all LA neighborhoods",
            "Residential & Commercial",
            "Same-day booking available",
            "Valid for 7 days",
        ]}
        ctaText="Claim 25% Off"
        dismissText="Not interested"
        ctaLink="#contact"
        expiresIn="6:23:59"
    />
</BaseLayout>
