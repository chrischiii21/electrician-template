const laFeatures = [
    {
        icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-full h-full text-accent"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`,
        title: "Your Vision, Our Expertise",
        description:
            "We customize every electrical solution to match your specific needs, creating unique installations just for you across Los Angeles.",
    },
    {
        icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-full h-full text-accent"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
        title: "Built to Last, Built for You",
        description:
            "With the best materials and expert craftsmanship, our electrical systems provide enduring quality for years of reliable service.",
