];
---

<BaseLayout title="Los Angeles | Electrician Services">
    <Hero2
        title="Los Angeles"
        eyebrow="Service Area"
        description="Professional electrical services serving Los Angeles and surrounding areas"
        backgroundImage="https://images.unsplash.com/photo-1480714378408-67cf0d13bc1b?w=1200&h=600&fit=crop"
    />
    <ServiceAreaTrust
        city="Los Angeles"
        eyebrow="Worry No More"
        title="Experience worry-free electrical solutions across <span class='text-accent'>Los Angeles</span>."
        description="Our licensed electricians, based in Los Angeles, provide comprehensive electrical services tailored to your needs. With meticulous design and expert craftsmanship, we bring reliable power solutions to homes and businesses across LA County."
        mainImage="https://images.unsplash.com/photo-1621905251918-48416bd8575a?w=800&h=600&fit=crop"
        secondaryImage="/images/hero-1.avif"
        features={laFeatures}
    />
    <Services />
    <CTARibbon />
    <OffersAndFinancing />
    <FeaturedWorks />
    <Testimonials />
    <FAQ pageType="los-angeles" />
    <ServiceAreaMap
        city="Los Angeles"
        neighborhoods={laNeighborhoods}
        totalElectricians={8}
    />
    <FinalCTA />
    <CouponModal
        discount="75"
        discountType="amount"
        code="SPRING75"
        title="Los Angeles Electrical Special"
        description="Save $75 on any electrical panel upgrade in Los Angeles County. Serving all LA neighborhoods from Downtown to Malibu."
        features={[
            "Same-Day Service Available",
            "All LA Neighborhoods Covered",
            "Licensed CA Electricians",
            "100% Satisfaction Guarantee",
        ]}
        ctaText="Claim LA Discount"
        dismissText="No thanks"
        ctaLink="/contact"
        expiresIn="47:59:59"
        autoOpen={true}
    />
</BaseLayout>
