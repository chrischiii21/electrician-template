---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";

interface Feature {
    icon: string;
    title: string;
    description: string;
}

interface Props {
    city: string;
    eyebrow: string;
    title: string;
    description: string;
    additionalText?: string;
    features: Feature[];
    mainImage: string;
    secondaryImage: string;
}

const {
    city,
    eyebrow,
    title,
    description,
    additionalText,
    features,
    mainImage,
    secondaryImage,
} = Astro.props;
---

<section class="bg-gray-50 py-20">
    <Container size="lg">
        <div class="bg-gray-50 p-12 md:p-16">
            <div class="grid lg:grid-cols-2 gap-16 items-start">
                <!-- Left: Images -->
                <div class="space-y-6">
                    <div class="scroll-fade-left">
                        <img
                            src={mainImage}
                            alt={`Electrical services in ${city}`}
                            class="w-full h-[400px] object-cover"
                        />
                    </div>
                    <div class="scroll-fade-left" style="transition-delay: 0.2s;">
                        <img
                            src={secondaryImage}
                            alt={`Professional electricians in ${city}`}
                            class="w-full h-[360px] object-cover"
                        />
                    </div>
                </div>

                <!-- Right: Content -->
                <div class="scroll-animate">
                    <!-- Eyebrow with line -->
                    <div class="flex items-center gap-4 mb-6">
                        <div class="h-px w-16 bg-accent"></div>
                        <Text size="lg" class="text-accent! font-bold">
                            {eyebrow}
                        </Text>
                    </div>

                    <!-- Title -->
                    <Heading level={2} class="text-4xl md:text-5xl mb-6 font-black leading-tight">
                        <Fragment set:html={title} />
                    </Heading>

                    <!-- Description -->
                    <Text size="xl" class="text-gray-700! mb-4 leading-relaxed">
                        {description}
                    </Text>

                    {additionalText && (
                        <Text size="base" class="text-gray-700! mb-8 leading-relaxed">
                            {additionalText}
                        </Text>
                    )}

                    <!-- Features Grid -->
                    <div class="grid md:grid-cols-2 gap-8 mt-10">
                        {features.map((feature) => (
                            <div class="scroll-stagger">
                                <!-- Icon -->
                                <div class="w-16 h-16 flex items-center justify-center mb-4">
                                    <div class="w-full h-full" set:html={feature.icon} />
                                </div>

                                <!-- Title -->
                                <Heading level={3} class="text-xl font-black mb-3 text-text!">
                                    {feature.title}
                                </Heading>

                                <!-- Description -->
                                <Text size="lg" class="text-gray-600! leading-relaxed">
                                    {feature.description}
                                </Text>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </div>
    </Container>
</section>
