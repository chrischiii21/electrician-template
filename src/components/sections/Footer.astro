---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";

const footerLinksContent =
    await import("../../content/footer-links.md?raw").then((m) => m.default);

const serviceAreasContent =
    await import("../../content/service-areas-footer.md?raw").then(
        (m) => m.default,
    );

const socialLinksContent =
    await import("../../content/social-links.md?raw").then((m) => m.default);

const parseLinks = (content: string) => {
    return content
        .split("\n")
        .filter((line: string) => line.startsWith("## "))
        .map((line: string) => {
            const label = line.replace("## ", "").trim();
            const lines = content.split("\n");
            const lineIndex = lines.indexOf(line);

            let href = "";

            for (let i = lineIndex + 1; i < lines.length; i++) {
                const currentLine = lines[i];
                if (currentLine.includes("**Href**")) {
                    href =
                        currentLine
                            .match(/\*\*Href\*\*:\s*(.+)/)?.[1]
                            ?.trim() || "";
                }
                if (currentLine.startsWith("## ") && currentLine !== line)
                    break;
            }

            return { label, href };
        });
};

const parseSocialLinks = (content: string) => {
    return content
        .split("\n")
        .filter((line: string) => line.startsWith("## "))
        .map((line: string) => {
            const label = line.replace("## ", "").trim();
            const lines = content.split("\n");
            const lineIndex = lines.indexOf(line);

            let href = "";
            let icon = "";

            for (let i = lineIndex + 1; i < lines.length; i++) {
                const currentLine = lines[i];
                if (currentLine.includes("**Href**")) {
                    href =
                        currentLine
                            .match(/\*\*Href\*\*:\s*(.+)/)?.[1]
                            ?.trim() || "";
                }
                if (currentLine.includes("**Icon**")) {
                    icon =
                        currentLine
                            .match(/\*\*Icon\*\*:\s*(.+)/)?.[1]
                            ?.trim() || "";
                }
                if (currentLine.startsWith("## ") && currentLine !== line)
                    break;
            }

            return { label, href, icon };
        });
};

const footerLinks = parseLinks(footerLinksContent);
const serviceAreas = parseLinks(serviceAreasContent);
const socialLinks = parseSocialLinks(socialLinksContent);
---

<footer class="bg-gray-900 text-gray-50">
    <!-- Main Footer Content -->
    <div class="bg-gray-900 py-16">
        <Container size="lg">
            <div class="px-4 md:px-12">
                <!-- Logo and Tagline -->
                <div class="text-center mb-6 md:mb-8">
                    <div class="flex items-center justify-center mb-3 md:mb-4">
                        <img
                            src="/logo.png"
                            alt="Volt Edge Electrical"
                            class="h-12 md:h-16 w-auto object-contain"
                        />
                    </div>

                    <!-- Star Rating -->
                    <div class="flex items-center justify-center gap-1 mb-2">
                        {
                            [...Array(5)].map(() => (
                                <svg
                                    class="w-3 md:w-4 h-3 md:h-4 text-accent fill-current"
                                    viewBox="0 0 20 20"
                                >
                                    <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z" />
                                </svg>
                            ))
                        }
                    </div>

                    <Heading
                        level={4}
                        class="!text-white !text-xl md:!text-2xl mb-1 md:mb-2"
                    >
                        Trusted by 1000+ People Like You
                    </Heading>
                    <Text size="md" class="!text-white !md:text-xl">
                        Contact us Today to Get Free Estimate
                    </Text>
                </div>

                <!-- Navigation Links -->
                <nav
                    class="flex flex-wrap items-center justify-center gap-3 md:gap-8 mb-8 md:mb-12"
                >
                    {
                        footerLinks.map((link) => (
                            <Text
                                size="sm"
                                as="a"
                                href={link.href}
                                class="!text-sm md:!text-lg !text-white hover:!text-accent transition-colors !uppercase !tracking-wide cursor-pointer"
                            >
                                {link.label}
                            </Text>
                        ))
                    }
                </nav>

                <!-- CTA Buttons -->
                <div
                    class="grid grid-cols-1 md:grid-cols-3 gap-3 md:gap-4 mb-8 md:mb-12"
                >
                    <!-- Request Quote -->
                    <Button
                        href="/quote"
                        variant="outline"
                        class="!px-4 md:!px-6 !py-3 md:!py-4 !flex !items-center !gap-2 md:!gap-3 !transition-colors !justify-start !text-md md:!text-md"
                    >
                        <svg
                            class="w-4 md:w-5 h-4 md:h-5 shrink-0"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                        >
                            <path
                                d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z"
                            ></path>
                            <path
                                d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z"
                            ></path>
                        </svg>
                        <div class="text-left">
                            <Text
                                size="sm"
                                class="!text-xs !uppercase !tracking-wider !opacity-90"
                                as="div"
                            >
                                Simple & Free
                            </Text>
                            <Text
                                size="sm"
                                class="!font-bold !text-xs md:!text-sm"
                                as="div">Request a Quote</Text
                            >
                        </div>
                    </Button>

                    <!-- Call Us -->
                    <Button
                        href="tel:+14228208200"
                        variant="outline"
                        class="!px-4 md:!px-6 !py-3 md:!py-4 !flex !items-center !gap-2 md:!gap-3 !transition-colors !justify-start !text-md md:!text-md"
                    >
                        <svg
                            class="w-4 md:w-5 h-4 md:h-5 shrink-0"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                            ></path>
                        </svg>
                        <div class="text-left">
                            <Text
                                size="sm"
                                class="!text-xs !uppercase !tracking-wider !opacity-90"
                                as="div"
                            >
                                Call us
                            </Text>
                            <Text
                                size="sm"
                                class="!font-bold !text-xs md:!text-sm"
                                as="div">(422) 820 820</Text
                            >
                        </div>
                    </Button>

                    <!-- Email Us -->
                    <Button
                        href="mailto:office@voltedge.com"
                        variant="outline"
                        class="!px-4 md:!px-6 !py-3 md:!py-4 !flex !items-center !gap-2 md:!gap-3 !transition-colors !justify-start !text-md md:!text-md"
                    >
                        <svg
                            class="w-4 md:w-5 h-4 md:h-5 shrink-0"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                            ></path>
                        </svg>
                        <div class="text-left">
                            <Text
                                size="sm"
                                class="!text-xs !uppercase !tracking-wider !opacity-90"
                                as="div"
                            >
                                Email us
                            </Text>
                            <Text
                                size="sm"
                                class="!font-bold !text-xs md:!text-sm"
                                as="div"
                            >
                                office@voltedge.com
                            </Text>
                        </div>
                    </Button>
                </div>

                <!-- Address and Service Areas -->
                <div
                    class="flex flex-col md:flex-row md:flex-wrap items-start md:items-center justify-between gap-4 pt-6 md:pt-8 border-t border-gray-700"
                >
                    <!-- Address -->
                    <div class="flex items-center gap-2">
                        <svg
                            class="w-4 h-4 text-danger shrink-0"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"
                                clip-rule="evenodd"></path>
                        </svg>
                        <Text
                            size="sm"
                            class="!text-xs md:!text-sm !text-white"
                            as="span"
                        >
                            Address: Los Angeles, CA
                        </Text>
                    </div>

                    <!-- Service Areas -->
                    <div
                        class="flex flex-col md:flex-row items-start md:items-center gap-2 w-full md:w-auto"
                    >
                        <Text
                            size="sm"
                            class="!text-xs md:!text-sm !text-white"
                            as="span"
                        >
                            Areas We Service:
                        </Text>
                        <div class="flex flex-wrap gap-2">
                            {
                                serviceAreas.map((area) => (
                                    <a
                                        href={area.href}
                                        class="text-xs font-bold text-white hover:text-accent transition-colors px-2 md:px-3 py-1 border border-gray-700 hover:border-accent uppercase tracking-wider cursor-pointer"
                                    >
                                        {area.label}
                                        <svg
                                            class="inline-block w-2 md:w-3 h-2 md:h-3 ml-1"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            viewBox="0 0 24 24"
                                        >
                                            <path d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                        </svg>
                                    </a>
                                ))
                            }
                        </div>
                    </div>
                </div>
            </div>
        </Container>
    </div>

    <!-- Bottom Bar -->
    <div class="bg-gray-900 border-t border-gray-700 py-4 md:py-6">
        <Container size="lg">
            <div
                class="px-4 md:px-12 flex flex-col md:flex-row md:flex-wrap items-start md:items-center justify-between gap-4"
            >
                <!-- Copyright -->
                <Text size="sm" class="!text-xs md:!text-sm !text-white">
                    2026 © VoltEdge. All rights reserved
                </Text>

                <!-- Legal Links -->
                <div class="flex items-center gap-4 md:gap-6">
                    <Text
                        size="sm"
                        as="a"
                        href="/terms"
                        class="!text-xs md:!text-sm !text-white hover:!text-accent transition-colors cursor-pointer"
                    >
                        Terms & Conditions
                    </Text>
                    <Text
                        size="sm"
                        as="a"
                        href="/privacy"
                        class="!text-xs md:!text-sm !text-white hover:!text-accent transition-colors cursor-pointer"
                    >
                        Privacy Policy
                    </Text>
                </div>

                <!-- Social Links -->
                <div class="flex items-center gap-3 md:gap-4">
                    {
                        socialLinks.map((social) => (
                            <a
                                href={social.href}
                                class="text-white hover:text-accent transition-colors cursor-pointer"
                                aria-label={social.label}
                            >
                                <svg
                                    class="w-4 md:w-5 h-4 md:h-5"
                                    fill="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path d={social.icon} />
                                </svg>
                            </a>
                        ))
                    }
                </div>
            </div>
        </Container>
    </div>
</footer>
