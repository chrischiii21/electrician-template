---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";

const footerLinks = [
    { label: "Home", href: "/" },
    { label: "About Us", href: "/about" },
    { label: "Service Area", href: "/service-area" },
    { label: "Contact Us", href: "/contact" },
    { label: "Specials / Coupons", href: "/specials" },
    { label: "Financing", href: "/financing" },
];

const serviceAreas = [
    { label: "LOS ANGELES", href: "/service-area/los-angeles" },
    { label: "SAN DIEGO", href: "/service-area/san-diego" },
    { label: "SAN FRANCISCO", href: "/service-area/san-francisco" },
    { label: "SACRAMENTO", href: "/service-area/sacramento" },
];

const socialLinks = [
    {
        label: "Instagram",
        href: "#",
        icon: "M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z",
    },
    {
        label: "Yelp",
        href: "#",
        icon: "M12.271 17.659c.001.05-.003.1-.012.148l-1.266 4.537c-.044.159-.145.295-.282.379-.137.084-.299.109-.452.07l-3.996-1.063c-.153-.041-.283-.139-.363-.273-.08-.134-.103-.293-.064-.444l1.266-4.537c.044-.159.145-.295.282-.379.137-.084.299-.109.452-.07l3.996 1.063c.153.041.283.139.363.273.08.134.103.293.064.444l.012-.148zm-.813-5.678l3.894 2.411c.148.092.253.239.293.409.04.17.009.348-.086.496l-2.476 3.878c-.095.148-.246.253-.421.293-.175.04-.357.009-.508-.086l-3.894-2.411c-.148-.092-.253-.239-.293-.409-.04-.17-.009-.348.086-.496l2.476-3.878c.095-.148.246-.253.421-.293.175-.04.357-.009.508.086zm-3.168-5.203c.175-.04.357-.009.508.086l3.894 2.411c.148.092.253.239.293.409.04.17.009.348-.086.496l-2.476 3.878c-.095.148-.246.253-.421.293-.175.04-.357.009-.508-.086l-3.894-2.411c-.148-.092-.253-.239-.293-.409-.04-.17-.009-.348.086-.496l2.476-3.878c.095-.148.246-.253.421-.293zm8.982 2.745c.137.084.238.22.282.379l1.266 4.537c.039.151.016.31-.064.444-.08.134-.21.232-.363.273l-3.996 1.063c-.153.039-.315.014-.452-.07-.137-.084-.238-.22-.282-.379l-1.266-4.537c-.039-.151-.016-.31.064-.444.08-.134.21-.232.363-.273l3.996-1.063c.153-.039.315-.014.452.07z",
    },
    {
        label: "Facebook",
        href: "#",
        icon: "M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z",
    },
];
---

<footer class="bg-gray-900 text-gray-50">
    <!-- Main Footer Content -->
    <div class="bg-gray-900 py-16">
        <Container size="lg">
            <div class="px-4 md:px-12">
                <!-- Logo and Tagline -->
                <div class="text-center mb-6 md:mb-8">
                    <div class="flex items-center justify-center mb-3 md:mb-4">
                        <img
                            src="/logo.png"
                            alt="Volt Edge Electrical"
                            class="h-12 md:h-16 w-auto object-contain"
                        />
                    </div>

                    <!-- Star Rating -->
                    <div class="flex items-center justify-center gap-1 mb-2">
                        {
                            [...Array(5)].map(() => (
                                <svg
                                    class="w-3 md:w-4 h-3 md:h-4 text-accent fill-current"
                                    viewBox="0 0 20 20"
                                >
                                    <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z" />
                                </svg>
                            ))
                        }
                    </div>

                    <Heading
                        level={4}
                        class="!text-white !text-base md:!text-lg mb-1 md:mb-2"
                    >
                        Trusted by 1000+ People Like You
                    </Heading>
                    <Text size="sm" class="!text-gray-300 md:!text-base">
                        Contact us Today to Get Free Estimate
                    </Text>
                </div>

                <!-- Navigation Links -->
                <nav
                    class="flex flex-wrap items-center justify-center gap-3 md:gap-8 mb-8 md:mb-12"
                >
                    {
                        footerLinks.map((link) => (
                            <Text
                                size="sm"
                                as="a"
                                href={link.href}
                                class="!text-xs md:!text-sm !text-gray-50 hover:!text-primary transition-colors !uppercase !tracking-wide cursor-pointer"
                            >
                                {link.label}
                            </Text>
                        ))
                    }
                </nav>

                <!-- CTA Buttons -->
                <div
                    class="grid grid-cols-1 md:grid-cols-3 gap-3 md:gap-4 mb-8 md:mb-12"
                >
                    <!-- Request Quote -->
                    <Button
                        href="/quote"
                        variant="primary"
                        class="!bg-primary hover:!bg-accent !text-white !px-4 md:!px-6 !py-3 md:!py-4 !flex !items-center !gap-2 md:!gap-3 !transition-colors !justify-start !text-sm md:!text-base"
                    >
                        <svg
                            class="w-4 md:w-5 h-4 md:h-5 shrink-0"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                        >
                            <path
                                d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z"
                            ></path>
                            <path
                                d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z"
                            ></path>
                        </svg>
                        <div class="text-left">
                            <Text
                                size="sm"
                                class="!text-xs !uppercase !tracking-wider !opacity-90"
                                as="div"
                            >
                                Simple & Free
                            </Text>
                            <Text
                                size="sm"
                                class="!font-bold !text-xs md:!text-sm"
                                as="div">Request a Quote</Text
                            >
                        </div>
                    </Button>

                    <!-- Call Us -->
                    <Button
                        href="tel:+14228208200"
                        variant="primary"
                        class="!bg-primary hover:!bg-accent !text-white !px-4 md:!px-6 !py-3 md:!py-4 !flex !items-center !gap-2 md:!gap-3 !transition-colors !justify-start !text-sm md:!text-base"
                    >
                        <svg
                            class="w-4 md:w-5 h-4 md:h-5 shrink-0"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                            ></path>
                        </svg>
                        <div class="text-left">
                            <Text
                                size="sm"
                                class="!text-xs !uppercase !tracking-wider !opacity-90"
                                as="div"
                            >
                                Call us
                            </Text>
                            <Text
                                size="sm"
                                class="!font-bold !text-xs md:!text-sm"
                                as="div">(422) 820 820</Text
                            >
                        </div>
                    </Button>

                    <!-- Email Us -->
                    <Button
                        href="mailto:office@voltedge.com"
                        variant="primary"
                        class="!bg-primary hover:!bg-accent !text-white !px-4 md:!px-6 !py-3 md:!py-4 !flex !items-center !gap-2 md:!gap-3 !transition-colors !justify-start !text-sm md:!text-base"
                    >
                        <svg
                            class="w-4 md:w-5 h-4 md:h-5 shrink-0"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                            ></path>
                        </svg>
                        <div class="text-left">
                            <Text
                                size="sm"
                                class="!text-xs !uppercase !tracking-wider !opacity-90"
                                as="div"
                            >
                                Email us
                            </Text>
                            <Text
                                size="sm"
                                class="!font-bold !text-xs md:!text-sm"
                                as="div"
                            >
                                office@voltedge.com
                            </Text>
                        </div>
                    </Button>
                </div>

                <!-- Address and Service Areas -->
                <div
                    class="flex flex-col md:flex-row md:flex-wrap items-start md:items-center justify-between gap-4 pt-6 md:pt-8 border-t border-gray-700"
                >
                    <!-- Address -->
                    <div class="flex items-center gap-2">
                        <svg
                            class="w-4 h-4 text-danger shrink-0"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"
                                clip-rule="evenodd"></path>
                        </svg>
                        <Text
                            size="sm"
                            class="!text-xs md:!text-sm !text-gray-300"
                            as="span"
                        >
                            Address: Los Angeles, CA
                        </Text>
                    </div>

                    <!-- Service Areas -->
                    <div
                        class="flex flex-col md:flex-row items-start md:items-center gap-2 w-full md:w-auto"
                    >
                        <Text
                            size="sm"
                            class="!text-xs md:!text-sm !text-gray-300"
                            as="span"
                        >
                            Areas We Service:
                        </Text>
                        <div class="flex flex-wrap gap-2">
                            {
                                serviceAreas.map((area) => (
                                    <a
                                        href={area.href}
                                        class="text-xs font-bold text-gray-50 hover:text-primary transition-colors px-2 md:px-3 py-1 border border-gray-700 hover:border-primary uppercase tracking-wider cursor-pointer"
                                    >
                                        {area.label}
                                        <svg
                                            class="inline-block w-2 md:w-3 h-2 md:h-3 ml-1"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            viewBox="0 0 24 24"
                                        >
                                            <path d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                        </svg>
                                    </a>
                                ))
                            }
                        </div>
                    </div>
                </div>
            </div>
        </Container>
    </div>

    <!-- Bottom Bar -->
    <div class="bg-gray-900 border-t border-gray-700 py-4 md:py-6">
        <Container size="lg">
            <div
                class="px-4 md:px-12 flex flex-col md:flex-row md:flex-wrap items-start md:items-center justify-between gap-4"
            >
                <!-- Copyright -->
                <Text size="sm" class="!text-xs md:!text-sm !text-gray-300">
                    2026 © VoltEdge. All rights reserved
                </Text>

                <!-- Legal Links -->
                <div class="flex items-center gap-4 md:gap-6">
                    <Text
                        size="sm"
                        as="a"
                        href="/terms"
                        class="!text-xs md:!text-sm !text-gray-300 hover:!text-primary transition-colors cursor-pointer"
                    >
                        Terms & Conditions
                    </Text>
                    <Text
                        size="sm"
                        as="a"
                        href="/privacy"
                        class="!text-xs md:!text-sm !text-gray-300 hover:!text-primary transition-colors cursor-pointer"
                    >
                        Privacy Policy
                    </Text>
                </div>

                <!-- Social Links -->
                <div class="flex items-center gap-3 md:gap-4">
                    {
                        socialLinks.map((social) => (
                            <a
                                href={social.href}
                                class="text-gray-300 hover:text-primary transition-colors cursor-pointer"
                                aria-label={social.label}
                            >
                                <svg
                                    class="w-4 md:w-5 h-4 md:h-5"
                                    fill="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path d={social.icon} />
                                </svg>
                            </a>
                        ))
                    }
                </div>
            </div>
        </Container>
    </div>
</footer>
