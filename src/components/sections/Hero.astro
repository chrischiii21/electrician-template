---
import Button from "../ui/Button.astro";

// Placeholder images - replace with actual electrician/construction images
const carouselImages = [
    "https://33hb9xdnm4.ucarecd.net/10381cf7-194e-422f-bcc7-50df3498bff8/photo162190525191848416bd8575a", // Electrician working
    "https://33hb9xdnm4.ucarecd.net/cc7a1cf1-45a7-4dab-b0ac-f704b5a47b18/photo1473341304170971dccb5ac1e", // Construction site
    "https://33hb9xdnm4.ucarecd.net/e48c2232-5d04-4524-bbb9-685c07f82e5d/photo150430765125435680f356dfd", // Building architecture
];
---

<section
    class="relative bg-linear-to-br from-secondary to-secondary/90 text-gray-50 -mt-4 pt-20 min-h-screen flex items-center overflow-hidden z-0"
>
    <!-- Carousel Background -->
    <div class="absolute inset-0 carousel-container">
        {
            carouselImages.map((image, index) => (
                <div
                    class={`carousel-slide absolute inset-0 bg-cover bg-center transition-opacity duration-1000 ${index === 0 ? "opacity-100" : "opacity-0"}`}
                    style={`background-image: url('${image}');`}
                    data-slide={index}
                />
            ))
        }
    </div>

    <!-- Dark Overlay -->
    <div class="absolute inset-0 bg-gray-900/60"></div>

    <!-- Content -->
    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center w-full">
        <h1 class="text-5xl md:text-6xl font-bold leading-tight mb-6">
            The Leader in<br />
            Sophisticated<br />
            Custom Homes
        </h1>

        <p
            class="text-lg md:text-xl text-gray-100 mb-8 max-w-2xl mx-auto leading-relaxed"
        >
            Elite team of experienced construction professionals delivers
            excellence in design-build, design assist and specialty contracting
            for metal structures, concrete foundations and metal roofing.
        </p>

        <div class="flex items-center justify-center gap-4 flex-wrap">
            <Button
                href="/contact"
                variant="primary"
                size="lg"
                class="uppercase tracking-wider"
            >
                Schedule With Us
            </Button>

            <span class="text-gray-300 font-medium">or</span>

            <Button
                href="/news"
                variant="outline"
                size="lg"
                class="uppercase tracking-wider border-gray-50 text-gray-50 hover:bg-gray-50 hover:text-secondary"
            >
                Recent News
            </Button>
        </div>
    </div>

    <!-- Decorative Elements -->
    <div
        class="absolute bottom-0 left-0 w-full h-32 bg-linear-to-t from-gray-900/20 to-transparent"
    >
    </div>
</section>

<script>
    // Simple carousel functionality
    const slides = document.querySelectorAll(".carousel-slide");
    let currentSlide = 0;

    function nextSlide() {
        slides[currentSlide].classList.remove("opacity-100");
        slides[currentSlide].classList.add("opacity-0");

        currentSlide = (currentSlide + 1) % slides.length;

        slides[currentSlide].classList.remove("opacity-0");
        slides[currentSlide].classList.add("opacity-100");
    }

    // Change slide every 5 seconds
    setInterval(nextSlide, 5000);
</script>

<style>
    .carousel-slide {
        animation: kenburns 20s ease-in-out infinite;
    }

    @keyframes kenburns {
        0%,
        100% {
            transform: scale(1);
        }
        50% {
            transform: scale(1.1);
        }
    }
</style>
