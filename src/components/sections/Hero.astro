---
import Button from "../ui/Button.astro";

const heroImage =
    "https://33hb9xdnm4.ucarecd.net/10381cf7-194e-422f-bcc7-50df3498bff8/photo162190525191848416bd8575a";
---

<section
    class="relative text-gray-50 -mt-16 pt-16 min-h-screen flex items-center overflow-hidden"
>
    <!-- Background Image -->
    <div class="absolute inset-0">
        <div
            class="absolute inset-0 bg-cover bg-center hero-image"
            style={`background-image: url('${heroImage}');`}
        >
        </div>
        <!-- Solid dark overlay -->
        <div class="absolute inset-0 bg-gray-900/75"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-6xl mx-auto px-6 w-full py-32">
        <div class="max-w-2xl">
            <!-- Eyebrow label -->
            <p
                class="text-primary font-semibold text-sm uppercase tracking-widest mb-5 hero-eyebrow"
            >
                Licensed &amp; Insured Electricians
            </p>

            <h1
                class="font-heading font-bold text-5xl md:text-6xl lg:text-7xl leading-[1.1] mb-6 text-white hero-title"
            >
                Powering Homes.<br />
                <span class="text-primary">Built to Last.</span>
            </h1>

            <p
                class="font-body text-lg text-gray-300 mb-10 leading-relaxed hero-description"
            >
                Expert electrical solutions for residential and commercial
                properties. Safe, reliable, and code-compliant — every time.
            </p>

            <div class="flex items-center gap-4 flex-wrap hero-buttons">
                <Button
                    href="#contact"
                    variant="primary"
                    size="lg"
                    class="uppercase tracking-wider font-bold shadow-lg shadow-primary/20 hover:shadow-primary/40 transition-all duration-300 hover:-translate-y-0.5"
                >
                    Get a Free Quote
                </Button>

                <Button
                    href="tel:+15550000000"
                    variant="outline"
                    size="lg"
                    class="uppercase tracking-wider font-bold border-2 border-white/30 text-white hover:border-white hover:bg-white/10 transition-all duration-300"
                >
                    Call 24/7 Emergency
                </Button>
            </div>

            <!-- Trust signals -->
            <div class="flex items-center gap-6 mt-10 hero-trust">
                <div class="flex items-center gap-2 text-gray-400 text-sm">
                    <svg
                        class="w-4 h-4 text-primary shrink-0"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                            clip-rule="evenodd"></path>
                    </svg>
                    <span>Same-day service</span>
                </div>
                <div class="flex items-center gap-2 text-gray-400 text-sm">
                    <svg
                        class="w-4 h-4 text-primary shrink-0"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                            clip-rule="evenodd"></path>
                    </svg>
                    <span>Upfront pricing</span>
                </div>
                <div class="flex items-center gap-2 text-gray-400 text-sm">
                    <svg
                        class="w-4 h-4 text-primary shrink-0"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                            clip-rule="evenodd"></path>
                    </svg>
                    <span>100% satisfaction guarantee</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom fade into page -->
    <div
        class="absolute bottom-0 left-0 w-full h-24 bg-linear-to-t from-background to-transparent"
    >
    </div>
</section>

<!-- Flash Modal -->
<div
    id="flash-modal"
    class="fixed inset-0 bg-gray-900/60 backdrop-blur-sm z-50 flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-300"
>
    <div
        class="bg-white border border-gray-100 rounded-xl shadow-2xl max-w-md w-full p-8 relative transform scale-95 transition-transform duration-300"
        id="modal-content"
    >
        <button
            id="close-modal"
            class="absolute top-4 right-4 text-gray-400 hover:text-gray-700 transition-colors"
            aria-label="Close modal"
        >
            <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>

        <div class="text-center">
            <span class="inline-block text-4xl mb-3">⚡</span>
            <h2 class="font-heading font-bold text-2xl mb-3 text-text">
                Need Power Now?
            </h2>
            <p class="font-body text-gray-600 mb-6">
                <span class="text-primary font-bold text-xl">15% Off</span> emergency
                repairs for first-time customers.
            </p>
            <Button
                href="#contact"
                variant="primary"
                size="lg"
                class="w-full uppercase tracking-wider font-bold"
            >
                Claim Offer
            </Button>
        </div>
    </div>
</div>

<script>
    const modal = document.getElementById("flash-modal");
    const modalContent = document.getElementById("modal-content");
    const closeBtn = document.getElementById("close-modal");

    if (!sessionStorage.getItem("hasSeenFlashModal")) {
        setTimeout(() => {
            modal?.classList.remove("opacity-0", "pointer-events-none");
            modalContent?.classList.replace("scale-95", "scale-100");
        }, 1000);
        sessionStorage.setItem("hasSeenFlashModal", "true");
    }

    function closeModal() {
        modal?.classList.add("opacity-0", "pointer-events-none");
        modalContent?.classList.replace("scale-100", "scale-95");
    }

    closeBtn?.addEventListener("click", closeModal);
    modal?.addEventListener("click", (e) => {
        if (e.target === modal) closeModal();
    });
    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeModal();
    });
</script>

<style>
    .hero-eyebrow {
        animation: fadeInUp 0.8s ease-out 0.1s both;
    }
    .hero-title {
        animation: fadeInUp 0.8s ease-out 0.25s both;
    }
    .hero-description {
        animation: fadeInUp 0.8s ease-out 0.4s both;
    }
    .hero-buttons {
        animation: fadeInUp 0.8s ease-out 0.55s both;
    }
    .hero-trust {
        animation: fadeInUp 0.8s ease-out 0.7s both;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(24px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .hero-image {
        animation: kenBurns 20s ease-in-out infinite alternate;
    }

    @keyframes kenBurns {
        from {
            transform: scale(1);
        }
        to {
            transform: scale(1.08);
        }
    }
</style>
