---
import Container from "../ui/Container.astro";

const projects = [
    {
        id: "panel-upgrade",
        title: "Complete Panel Upgrade",
        location: "San Francisco, CA",
        category: "Residential",
        beforeImage:
            "https://images.unsplash.com/photo-1621905251918-48416bd8575a?w=800&h=600&fit=crop",
        afterImage:
            "https://images.unsplash.com/photo-1621905252507-b35492cc74b4?w=800&h=600&fit=crop",
        description:
            "Transformed outdated 100A panel to modern 200A system with smart breakers",
        stats: {
            duration: "2 Days",
            rating: "5.0",
        },
    },
    {
        id: "commercial-wiring",
        title: "Commercial Rewiring",
        location: "Los Angeles, CA",
        category: "Commercial",
        beforeImage:
            "https://images.unsplash.com/photo-1473341304170-971dccb5ac1e?w=800&h=600&fit=crop",
        afterImage:
            "https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=800&h=600&fit=crop",
        description:
            "Complete office building electrical system modernization with LED upgrades",
        stats: {
            duration: "5 Days",
            rating: "5.0",
        },
    },
    {
        id: "ev-charger",
        title: "EV Charger Installation",
        location: "San Diego, CA",
        category: "Smart Tech",
        beforeImage:
            "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=800&h=600&fit=crop",
        afterImage:
            "https://images.unsplash.com/photo-1593941707882-a5bba14938c7?w=800&h=600&fit=crop",
        description:
            "Level 2 EV charging station with smart monitoring and scheduling",
        stats: {
            duration: "1 Day",
            rating: "5.0",
        },
    },
];
---

<section class="bg-gray-900 py-16 md:py-24 relative overflow-hidden">
    <!-- Background effects -->
    <div
        class="absolute top-1/4 left-0 w-96 h-96 bg-primary/10 rounded-full blur-3xl"
    >
    </div>
    <div
        class="absolute bottom-1/4 right-0 w-96 h-96 bg-accent/10 rounded-full blur-3xl"
    >
    </div>

    <Container size="lg">
        <!-- Section Header -->
        <div class="text-center mb-16 relative z-10">
            <div class="inline-flex items-center gap-2 mb-4">
                <span class="text-4xl">⚡</span>
                <h2
                    class="font-heading font-bold text-3xl md:text-4xl text-gray-50"
                >
                    "Current" Projects
                </h2>
                <span class="text-4xl">⚡</span>
            </div>
            <p class="font-body text-lg text-gray-300 max-w-2xl mx-auto">
                See the transformation. Real projects, real results. Slide to
                reveal the power of professional electrical work.
            </p>
        </div>

        <!-- Projects Grid -->
        <div
            class="grid grid-cols-1 lg:grid-cols-2 gap-8 px-6 max-w-6xl mx-auto"
        >
            {
                projects.map((project, index) => (
                    <div
                        class="project-card group"
                        style={`animation-delay: ${index * 0.15}s`}
                    >
                        <div class="bg-gray-900 border-2 border-primary/30 rounded-2xl overflow-hidden hover:border-primary/60 transition-all duration-300 hover:shadow-2xl hover:shadow-primary/20">
                            {/* Before/After Slider */}
                            <div class="relative aspect-[4/3] overflow-hidden bg-gray-900">
                                {/* Before Image */}
                                <div class="absolute inset-0">
                                    <img
                                        src={project.beforeImage}
                                        alt={`${project.title} - Before`}
                                        class="w-full h-full object-cover"
                                    />
                                    <div class="absolute top-4 left-4 bg-danger text-gray-50 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider">
                                        Before
                                    </div>
                                </div>

                                {/* After Image (clipped) */}
                                <div
                                    class="absolute inset-0 after-image"
                                    style="clip-path: inset(0 50% 0 0);"
                                >
                                    <img
                                        src={project.afterImage}
                                        alt={`${project.title} - After`}
                                        class="w-full h-full object-cover"
                                    />
                                    <div class="absolute top-4 right-4 bg-primary text-gray-50 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider">
                                        After
                                    </div>
                                </div>

                                {/* Slider Handle */}
                                <div
                                    class="slider-container absolute inset-0 cursor-ew-resize"
                                    data-project={project.id}
                                >
                                    <div
                                        class="slider-line absolute top-0 bottom-0 w-1 bg-gray-50 shadow-lg"
                                        style="left: 50%;"
                                    >
                                        <div class="slider-handle absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-12 h-12 bg-gray-50 rounded-full shadow-2xl flex items-center justify-center border-4 border-primary">
                                            <svg
                                                class="w-6 h-6 text-primary"
                                                fill="none"
                                                stroke="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="3"
                                                    d="M8 9l4-4 4 4m0 6l-4 4-4-4"
                                                />
                                            </svg>
                                        </div>
                                    </div>
                                </div>

                                {/* Hover instruction */}
                                <div class="absolute bottom-4 left-1/2 -translate-x-1/2 bg-gray-900/90 text-gray-50 px-4 py-2 rounded-full text-xs font-bold uppercase tracking-wider opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none">
                                    ← Drag to Compare →
                                </div>
                            </div>

                            {/* Project Info */}
                            <div class="p-6">
                                {/* Category Badge */}
                                <div class="inline-flex items-center gap-2 mb-3">
                                    <span class="bg-primary/10 text-primary px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider">
                                        {project.category}
                                    </span>
                                    <span class="text-gray-500">•</span>
                                    <span class="text-gray-400 text-sm">
                                        {project.location}
                                    </span>
                                </div>

                                {/* Title */}
                                <h3 class="font-heading font-bold text-xl md:text-2xl text-gray-50 mb-3">
                                    {project.title}
                                </h3>

                                {/* Description */}
                                <p class="font-body text-gray-300 mb-4 leading-relaxed">
                                    {project.description}
                                </p>

                                {/* Stats */}
                                <div class="flex items-center justify-between pt-4 border-t border-gray-700">
                                    <div class="flex items-center gap-2">
                                        <svg
                                            class="w-5 h-5 text-accent"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                            />
                                        </svg>
                                        <span class="font-body text-sm text-gray-400">
                                            {project.stats.duration}
                                        </span>
                                    </div>
                                    <div class="flex items-center gap-1">
                                        {[...Array(5)].map(() => (
                                            <svg
                                                class="w-5 h-5 text-accent"
                                                fill="currentColor"
                                                viewBox="0 0 20 20"
                                            >
                                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                            </svg>
                                        ))}
                                        <span class="font-body text-sm text-gray-400 ml-1">
                                            {project.stats.rating}
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>

        {/* Bottom CTA */}
        <div class="text-center mt-16 relative z-10">
            <p class="font-body text-gray-300 mb-6">
                Ready to transform your electrical system?
            </p>
            <a
                href="#contact"
                class="inline-flex items-center gap-2 font-heading font-bold uppercase tracking-wider px-8 py-4 bg-primary text-gray-50 rounded-lg hover:bg-primary/90 transition-all duration-300 shadow-lg shadow-primary/30 hover:shadow-primary/50 hover:scale-105"
            >
                <span>Start Your Project</span>
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                </svg>
            </a>
        </div>
    </Container>
</section>

<script>
    // Before/After Slider functionality
    class BeforeAfterSlider {
        constructor(container: HTMLElement) {
            this.container = container;
            this.afterImage = container.querySelector(
                ".after-image",
            ) as HTMLElement;
            this.sliderLine = container.querySelector(
                ".slider-line",
            ) as HTMLElement;
            this.isDragging = false;

            this.init();
        }

        container: HTMLElement;
        afterImage: HTMLElement;
        sliderLine: HTMLElement;
        isDragging: boolean;

        init() {
            // Mouse events
            this.container.addEventListener("mousedown", (e) =>
                this.startDrag(e),
            );
            document.addEventListener("mousemove", (e) => this.drag(e));
            document.addEventListener("mouseup", () => this.stopDrag());

            // Touch events
            this.container.addEventListener("touchstart", (e) =>
                this.startDrag(e),
            );
            document.addEventListener("touchmove", (e) => this.drag(e));
            document.addEventListener("touchend", () => this.stopDrag());

            // Click to position
            this.container.addEventListener("click", (e) =>
                this.updatePosition(e),
            );
        }

        startDrag(e: MouseEvent | TouchEvent) {
            this.isDragging = true;
            this.container.style.cursor = "ew-resize";
        }

        stopDrag() {
            this.isDragging = false;
            this.container.style.cursor = "ew-resize";
        }

        drag(e: MouseEvent | TouchEvent) {
            if (!this.isDragging) return;
            this.updatePosition(e);
        }

        updatePosition(e: MouseEvent | TouchEvent) {
            const rect = this.container.getBoundingClientRect();
            const clientX = "touches" in e ? e.touches[0]?.clientX : e.clientX;

            if (!clientX) return;

            let x = clientX - rect.left;
            x = Math.max(0, Math.min(x, rect.width));

            const percentage = (x / rect.width) * 100;

            // Update clip path
            if (this.afterImage) {
                this.afterImage.style.clipPath = `inset(0 ${100 - percentage}% 0 0)`;
            }

            // Update slider line position
            if (this.sliderLine) {
                this.sliderLine.style.left = `${percentage}%`;
            }
        }
    }

    // Initialize all sliders
    document.querySelectorAll(".slider-container").forEach((container) => {
        new BeforeAfterSlider(container as HTMLElement);
    });
</script>

<style>
    /* Project card animation */
    .project-card {
        animation: fadeInUp 0.8s ease-out forwards;
        opacity: 0;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Slider handle pulse */
    .slider-handle {
        animation: pulse-handle 2s ease-in-out infinite;
    }

    @keyframes pulse-handle {
        0%,
        100% {
            transform: translate(-50%, -50%) scale(1);
            box-shadow: 0 0 20px rgba(255, 123, 0, 0.5);
        }
        50% {
            transform: translate(-50%, -50%) scale(1.1);
            box-shadow: 0 0 30px rgba(255, 123, 0, 0.8);
        }
    }

    /* Smooth transitions */
    .after-image,
    .slider-line {
        transition: none;
        will-change: clip-path, left;
    }

    /* Prevent image selection during drag */
    .slider-container img {
        user-select: none;
        -webkit-user-drag: none;
        pointer-events: none;
    }

    /* Hover effects */
    .project-card:hover {
        transform: translateY(-4px);
        transition: transform 0.3s ease;
    }

    /* Responsive adjustments */
    @media (max-width: 768px) {
        .slider-handle {
            width: 40px;
            height: 40px;
        }

        .slider-handle svg {
            width: 20px;
            height: 20px;
        }
    }
</style>
