---
import Container from "../ui/Container.astro";

const services = [
    {
        id: "residential",
        title: "The Home Circuit",
        category: "Residential",
        tagline: "Comfort & Safety",
        description:
            "Expert electrical solutions for your home. From lighting upgrades to complete rewiring, we keep your family safe and comfortable.",
        features: [
            "Panel Upgrades",
            "Lighting Design",
            "Outlet Installation",
            "Safety Inspections",
        ],
        icon: "🏠",
        price: "Starting at $89",
        badge: "Most Popular",
        color: "primary",
        size: "large", // Takes 2 columns on desktop
    },
    {
        id: "commercial",
        title: "The Grid Master",
        category: "Commercial",
        tagline: "Reliability & Uptime",
        description:
            "Keep your business powered 24/7. Industrial-grade solutions for maximum reliability and minimal downtime.",
        features: [
            "Emergency Service",
            "Preventive Maintenance",
            "Code Compliance",
            "Power Distribution",
        ],
        icon: "🏢",
        price: "Same Day Available",
        badge: "24/7 Service",
        color: "secondary",
        size: "medium",
    },
    {
        id: "smart-tech",
        title: "The Future Flow",
        category: "Smart Technology",
        tagline: "EV Chargers & Automation",
        description:
            "Embrace the future with smart home integration, EV charging stations, and cutting-edge automation systems.",
        features: [
            "EV Charger Install",
            "Smart Home Setup",
            "Energy Management",
            "Solar Integration",
        ],
        icon: "⚡",
        price: "Starting at $299",
        badge: "Trending",
        color: "accent",
        size: "medium",
    },
];
---

<section class="bg-gray-900 py-16 md:py-24 relative overflow-hidden">
    <!-- Background glow effects -->
    <div
        class="absolute top-0 right-0 w-96 h-96 bg-primary/10 rounded-full blur-3xl"
    >
    </div>
    <div
        class="absolute bottom-0 left-0 w-96 h-96 bg-secondary/10 rounded-full blur-3xl"
    >
    </div>

    <Container size="lg">
        <!-- Section Header -->
        <div class="text-center mb-12 relative z-10">
            <div class="inline-flex items-center gap-2 mb-4">
                <span class="text-4xl">⚡</span>
                <h2
                    class="font-heading font-bold text-3xl md:text-4xl text-gray-50"
                >
                    Choose Your Voltage
                </h2>
                <span class="text-4xl">⚡</span>
            </div>
            <p class="font-body text-lg text-gray-300 max-w-2xl mx-auto">
                Select the perfect electrical service for your needs. Expert
                solutions tailored to your space.
            </p>
        </div>

        <!-- Bento Grid -->
        <div class="bento-grid px-6">
            {
                services.map((service) => (
                    <div
                        class={`service-tile ${service.size} group cursor-pointer`}
                        data-service={service.id}
                    >
                        <div
                            class={`tile-content relative overflow-hidden rounded-2xl border-2 h-full ${
                                service.color === "primary"
                                    ? "border-primary bg-gradient-to-br from-gray-900 to-primary/20"
                                    : service.color === "secondary"
                                      ? "border-secondary bg-gradient-to-br from-gray-900 to-secondary/20"
                                      : "border-accent bg-gradient-to-br from-gray-900 to-accent/20"
                            } transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl ${
                                service.color === "primary"
                                    ? "hover:shadow-primary/30"
                                    : service.color === "secondary"
                                      ? "hover:shadow-secondary/30"
                                      : "hover:shadow-accent/30"
                            }`}
                        >
                            {/* Badge */}
                            <div class="absolute top-4 right-4 z-10">
                                <div
                                    class={`px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider ${
                                        service.color === "primary"
                                            ? "bg-primary text-gray-50"
                                            : service.color === "secondary"
                                              ? "bg-secondary text-gray-50"
                                              : "bg-accent text-gray-900"
                                    } shadow-lg`}
                                >
                                    {service.badge}
                                </div>
                            </div>

                            {/* Content */}
                            <div class="p-8 h-full flex flex-col">
                                {/* Icon */}
                                <div
                                    class={`w-16 h-16 md:w-20 md:h-20 rounded-2xl mb-6 flex items-center justify-center text-4xl md:text-5xl ${
                                        service.color === "primary"
                                            ? "bg-primary/20"
                                            : service.color === "secondary"
                                              ? "bg-secondary/20"
                                              : "bg-accent/20"
                                    } group-hover:scale-110 transition-transform duration-300`}
                                >
                                    {service.icon}
                                </div>

                                {/* Category */}
                                <div
                                    class={`text-xs uppercase tracking-wider font-bold mb-2 ${
                                        service.color === "primary"
                                            ? "text-primary"
                                            : service.color === "secondary"
                                              ? "text-secondary"
                                              : "text-accent"
                                    }`}
                                >
                                    {service.category}
                                </div>

                                {/* Title */}
                                <h3 class="font-heading font-bold text-2xl md:text-3xl text-gray-50 mb-2">
                                    {service.title}
                                </h3>

                                {/* Tagline */}
                                <div class="font-body text-sm text-gray-400 mb-4 italic">
                                    {service.tagline}
                                </div>

                                {/* Description */}
                                <p class="font-body text-gray-300 mb-6 leading-relaxed">
                                    {service.description}
                                </p>

                                {/* Features */}
                                <div class="grid grid-cols-2 gap-3 mb-6">
                                    {service.features.map((feature) => (
                                        <div class="flex items-center gap-2">
                                            <span
                                                class={`text-lg ${
                                                    service.color === "primary"
                                                        ? "text-primary"
                                                        : service.color ===
                                                            "secondary"
                                                          ? "text-secondary"
                                                          : "text-accent"
                                                }`}
                                            >
                                                ✓
                                            </span>
                                            <span class="font-body text-sm text-gray-300">
                                                {feature}
                                            </span>
                                        </div>
                                    ))}
                                </div>

                                {/* Spacer */}
                                <div class="flex-grow" />

                                {/* Price Tag */}
                                <div
                                    class={`mt-auto pt-6 border-t-2 border-dashed ${
                                        service.color === "primary"
                                            ? "border-primary/30"
                                            : service.color === "secondary"
                                              ? "border-secondary/30"
                                              : "border-accent/30"
                                    }`}
                                >
                                    <div class="flex items-center justify-between">
                                        <div>
                                            <div class="text-xs text-gray-400 uppercase tracking-wider mb-1">
                                                Pricing
                                            </div>
                                            <div
                                                class={`font-heading font-bold text-xl ${
                                                    service.color === "primary"
                                                        ? "text-primary"
                                                        : service.color ===
                                                            "secondary"
                                                          ? "text-secondary"
                                                          : "text-accent"
                                                }`}
                                            >
                                                {service.price}
                                            </div>
                                        </div>
                                        <div
                                            class={`w-12 h-12 rounded-full flex items-center justify-center ${
                                                service.color === "primary"
                                                    ? "bg-primary"
                                                    : service.color ===
                                                        "secondary"
                                                      ? "bg-secondary"
                                                      : "bg-accent"
                                            } group-hover:scale-110 transition-transform duration-300`}
                                        >
                                            <svg
                                                class={`w-6 h-6 ${
                                                    service.color === "accent"
                                                        ? "text-gray-900"
                                                        : "text-gray-50"
                                                }`}
                                                fill="none"
                                                stroke="currentColor"
                                                viewBox="0 0 24 24"
                                            >
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d="M9 5l7 7-7 7"
                                                />
                                            </svg>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            {/* Hover glow effect */}
                            <div
                                class={`absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none ${
                                    service.color === "primary"
                                        ? "bg-gradient-to-t from-primary/20 to-transparent"
                                        : service.color === "secondary"
                                          ? "bg-gradient-to-t from-secondary/20 to-transparent"
                                          : "bg-gradient-to-t from-accent/20 to-transparent"
                                }`}
                            />
                        </div>
                    </div>
                ))
            }
        </div>

        {/* Bottom CTA */}
        <div class="text-center mt-12 relative z-10">
            <p class="font-body text-gray-300 mb-4">
                Not sure which service you need?
            </p>
            <a
                href="#contact"
                class="inline-flex items-center gap-2 font-heading font-bold uppercase tracking-wider px-8 py-4 bg-primary text-gray-50 rounded-lg hover:bg-primary/90 transition-all duration-300 shadow-lg shadow-primary/30 hover:shadow-primary/50 hover:scale-105"
            >
                <span>Get Free Consultation</span>
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
            </a>
        </div>
    </Container>
</section>

<script>
    // Add click interaction for service tiles
    document.querySelectorAll(".service-tile").forEach((tile) => {
        tile.addEventListener("click", () => {
            const serviceId = tile.getAttribute("data-service");
            // Scroll to contact form or service detail page
            const contactSection = document.querySelector("#contact");
            if (contactSection) {
                contactSection.scrollIntoView({ behavior: "smooth" });
            }
        });
    });
</script>

<style>
    /* Bento Grid Layout */
    .bento-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    @media (min-width: 768px) {
        .bento-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 2rem;
        }

        .service-tile.large {
            grid-column: span 2;
        }

        .service-tile.large .tile-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
        }

        .service-tile.large .tile-content > div {
            grid-column: span 2;
        }

        .service-tile.large .p-8 {
            grid-column: 1 / -1;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            align-items: start;
        }

        .service-tile.large .p-8 > * {
            grid-column: span 1;
        }

        .service-tile.large .p-8 > :first-child,
        .service-tile.large .p-8 > :nth-child(2),
        .service-tile.large .p-8 > :nth-child(3),
        .service-tile.large .p-8 > :nth-child(4),
        .service-tile.large .p-8 > :nth-child(5) {
            grid-column: 1;
        }

        .service-tile.large .p-8 > :nth-child(6),
        .service-tile.large .p-8 > :nth-child(7) {
            grid-column: 2;
            grid-row: 2 / span 2;
        }

        .service-tile.large .p-8 > :last-child {
            grid-column: 1 / -1;
        }
    }

    /* Tile animations */
    .service-tile {
        animation: fadeInUp 0.6s ease-out forwards;
        opacity: 0;
    }

    .service-tile:nth-child(1) {
        animation-delay: 0.1s;
    }

    .service-tile:nth-child(2) {
        animation-delay: 0.2s;
    }

    .service-tile:nth-child(3) {
        animation-delay: 0.3s;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Pulse effect on hover */
    .tile-content::before {
        content: "";
        position: absolute;
        inset: -2px;
        border-radius: 1rem;
        padding: 2px;
        background: linear-gradient(
            45deg,
            transparent,
            currentColor,
            transparent
        );
        -webkit-mask:
            linear-gradient(#fff 0 0) content-box,
            linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        opacity: 0;
        transition: opacity 0.3s;
    }

    .service-tile:hover .tile-content::before {
        opacity: 0.3;
        animation: rotate 3s linear infinite;
    }

    @keyframes rotate {
        to {
            transform: rotate(360deg);
        }
    }
</style>
