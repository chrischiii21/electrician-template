---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Badge from "../ui/Badge.astro";
import Button from "../ui/Button.astro";

const iconMap: Record<string, string> = {
    "building": `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
    "home": `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
    "star": `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>`,
    "alert": `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>`,
};

const rawContent = await import("../../content/services-catalog.md?raw").then(
    (m) => m.default,
);

const services = rawContent
    .split("\n")
    .filter((line: string) => line.startsWith("## "))
    .map((line: string, index: number) => {
        const label = line.replace("## ", "").trim();
        const id = label.toLowerCase();
        const lines = rawContent.split("\n");
        const lineIndex = lines.indexOf(line);
        
        let icon = "";
        let badge = "";
        let tagline = "";
        let description = "";
        let pitch = "";
        let image = "";
        let servicesStr = "";
        let ctaLabel = "";
        let ctaHref = "";
        
        for (let i = lineIndex + 1; i < lines.length; i++) {
            const currentLine = lines[i];
            if (currentLine.includes("**Icon**")) {
                icon = currentLine.match(/\*\*Icon\*\*:\s*(.+)/)?.[1]?.trim() || "";
            }
            if (currentLine.includes("**Badge**")) {
                badge = currentLine.match(/\*\*Badge\*\*:\s*(.+)/)?.[1]?.trim() || "";
            }
            if (currentLine.includes("**Tagline**")) {
                tagline = currentLine.match(/\*\*Tagline\*\*:\s*(.+)/)?.[1]?.trim() || "";
            }
            if (currentLine.includes("**Description**")) {
                description = currentLine.match(/\*\*Description\*\*:\s*(.+)/)?.[1]?.trim() || "";
            }
            if (currentLine.includes("**Pitch**")) {
                pitch = currentLine.match(/\*\*Pitch\*\*:\s*(.+)/)?.[1]?.trim() || "";
            }
            if (currentLine.includes("**Image**")) {
                image = currentLine.match(/\*\*Image\*\*:\s*(.+)/)?.[1]?.trim() || "";
            }
            if (currentLine.includes("**Services**")) {
                servicesStr = currentLine.match(/\*\*Services\*\*:\s*(.+)/)?.[1]?.trim() || "";
            }
            if (currentLine.includes("**CTA Label**")) {
                ctaLabel = currentLine.match(/\*\*CTA Label\*\*:\s*(.+)/)?.[1]?.trim() || "";
            }
            if (currentLine.includes("**CTA Href**")) {
                ctaHref = currentLine.match(/\*\*CTA Href\*\*:\s*(.+)/)?.[1]?.trim() || "";
            }
            if (currentLine.startsWith("## ") && currentLine !== line) break;
        }
        
        const servicesList = servicesStr.split(",").map((s: string) => s.trim()).filter((s: string) => s);

        return {
            id,
            label,
            icon: iconMap[icon] || iconMap["building"],
            badge: badge || null,
            tagline,
            description,
            pitch,
            image,
            services: servicesList,
            cta: { label: ctaLabel, href: ctaHref },
        };
    });
---

<section class="bg-white py-20" id="services">
    <Container size="lg">

        <!-- Header -->
        <div class="text-center mb-10 scroll-animate">
            <Badge variant="primary" class="mb-3">What We Do</Badge>
            <Heading level={2} class="text-4xl md:text-5xl mb-4">
                Every Electrical Need. <span class="text-primary">One Trusted Team.</span>
            </Heading>
            <Text size="xl" class="text-gray-700 max-w-2xl mx-auto">
                From emergency callouts to full commercial builds — we've got the crew, the tools, and the track record.
            </Text>
        </div>

        <!-- Pill Tab Nav -->
        <div class="flex flex-wrap justify-center gap-2 mb-10 scroll-animate" role="tablist">
            {services.map((s, i) => (
                <button
                    role="tab"
                    aria-selected={i === 0}
                    aria-controls={`panel-${s.id}`}
                    data-tab={s.id}
                    class:list={[
                        "services-tab inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold font-heading border transition-all duration-200 whitespace-nowrap",
                        i === 0
                            ? "bg-primary text-white border-primary"
                            : "bg-white text-gray-500 border-gray-200 hover:border-primary hover:text-text",
                    ]}
                >
                    <span set:html={s.icon} />
                    {s.label}
                    {s.badge && (
                        <span class:list={[
                            "tab-badge text-md font-bold px-1.5 py-0.5 leading-none",
                            i === 0 ? "bg-gray-900 text-white" : "bg-primary text-white"
                        ]}>
                            {s.badge}
                        </span>
                    )}
                </button>
            ))}
        </div>

        <!-- Panels -->
        <div class="panels-wrapper scroll-animate">
            {services.map((s, i) => (
                <div
                    id={`panel-${s.id}`}
                    role="tabpanel"
                    data-panel={s.id}
                    class:list={["services-panel", i === 0 ? "is-active" : "is-inactive"]}
                    aria-hidden={i !== 0}
                >
                    <div class="grid md:grid-cols-2 border border-gray-200">
                        <!-- Image -->
                        <div class="relative overflow-hidden h-72 md:h-auto">
                            <img
                                src={s.image}
                                alt={s.label}
                                class="w-full h-full object-cover"
                                loading="lazy"
                            />
                        </div>

                        <!-- Content -->
                        <div class="p-8 md:p-10 flex flex-col justify-center bg-white">
                            <Badge variant="primary" class="mb-4 self-start">{s.label} Services</Badge>
                            <Heading level={3} class="mb-3">{s.tagline}</Heading>
                            <Text class="text-gray-700 mb-2">{s.description}</Text>
                            <Text size="md" class="text-gray-400 mb-6 italic">{s.pitch}</Text>

                            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-2 mb-8">
                                {s.services.map((item) => (
                                    <li class="flex items-center gap-2">
                                        <svg class="w-4 h-4 text-primary shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                        </svg>
                                        <Text size="md" class="text-gray-700" as="span">{item}</Text>
                                    </li>
                                ))}
                            </ul>

                            <div class="self-start">
                                <Button
                                    href={s.cta.href}
                                    variant="primary"
                                    size="md"
                                    class="uppercase tracking-wider font-bold inline-flex items-center gap-2 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-primary/30 transition-all duration-200"
                                >
                                    {s.cta.label}
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                                    </svg>
                                </Button>
                            </div>
                        </div>
                    </div>
                </div>
            ))}
        </div>

    </Container>
</section>

<script>
    const tabs = document.querySelectorAll<HTMLButtonElement>(".services-tab");
    const panels = document.querySelectorAll<HTMLElement>(".services-panel");

    tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
            const target = tab.dataset.tab;
            const current = document.querySelector<HTMLElement>(".services-panel.is-active");
            const next = document.querySelector<HTMLElement>(`.services-panel[data-panel="${target}"]`);

            if (!next || current === next) return;

            // Update tab pill styles
            tabs.forEach((t) => {
                const active = t.dataset.tab === target;
                t.setAttribute("aria-selected", String(active));

                if (active) {
                    t.classList.add("bg-primary", "text-white", "border-primary");
                    t.classList.remove("bg-white", "text-gray-500", "border-gray-200");
                } else {
                    t.classList.remove("bg-primary", "text-white", "border-primary");
                    t.classList.add("bg-white", "text-gray-500", "border-gray-200");
                }

                // Badge inside tab: dark bg when tab is active so it's visible on primary
                const badge = t.querySelector<HTMLElement>(".tab-badge");
                if (badge) {
                    badge.classList.toggle("bg-gray-900", active);
                    badge.classList.toggle("bg-primary", !active);
                }
            });

            // Swap panels
            current?.classList.replace("is-active", "is-inactive");
            current?.setAttribute("aria-hidden", "true");
            next.classList.replace("is-inactive", "is-active");
            next.setAttribute("aria-hidden", "false");
        });
    });
</script>

<style>
    .panels-wrapper {
        position: relative;
    }

    .services-panel {
        transition: opacity 0.3s ease, transform 0.3s ease;
        will-change: opacity, transform;
    }

    .services-panel.is-active {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
        position: relative;
    }

    .services-panel.is-inactive {
        opacity: 0;
        transform: translateY(10px);
        pointer-events: none;
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        visibility: hidden;
    }
</style>
