---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Badge from "../ui/Badge.astro";
import Grid from "../ui/Grid.astro";
import Card from "../ui/Card.astro";

const features = [
    {
        icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
        title: "Licensed & Insured",
        body: "Full coverage. Zero risk to you.",
    },
    {
        icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
        title: "Same-Day Service",
        body: "Most jobs completed within 24 hours.",
    },
    {
        icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
        title: "Upfront Pricing",
        body: "No hidden fees. Know the cost before we start.",
    },
    {
        icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>`,
        title: "Lifetime Warranty",
        body: "We stand behind every job we do.",
    },
    {
        icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
        title: "Background-Checked",
        body: "Every electrician is vetted and certified.",
    },
    {
        icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
        title: "Clean Work Sites",
        body: "We leave your home cleaner than we found it.",
    },
];

const comparison = [
    { feature: "Licensed & Insured", us: true, them: false },
    { feature: "Same-Day Service", us: true, them: false },
    { feature: "Upfront Flat-Rate Pricing", us: true, them: false },
    { feature: "Lifetime Workmanship Warranty", us: true, them: false },
    { feature: "Background-Checked Techs", us: true, them: true },
    { feature: "24/7 Emergency Response", us: true, them: false },
    { feature: "Permit-Ready Work", us: true, them: false },
    { feature: "Clean Job Site Guarantee", us: true, them: false },
];
---

<section class="bg-white py-20" id="why-us">
    <Container size="lg">
        <!-- Header -->
        <div class="text-center mb-12 scroll-animate">
            <Badge variant="accent" class="mb-3">Why Choose Us</Badge>
            <Heading level={2} class="text-4xl md:text-5xl mb-4">
                The <span class="text-accent">Difference</span>
            </Heading>
            <Text size="xl" class="text-gray-700 max-w-xl mx-auto">
                Not all electricians are equal. Here's what sets us apart.
            </Text>
        </div>

        <!-- Feature Grid -->
        <Grid cols={3} gap="md" class="mb-20 scroll-stagger">
            {
                features.map((f) => (
                    <Card
                        padding="lg"
                        class="group hover:border-accent hover:shadow-md transition-all duration-200 border border-gray-100 rounded-none"
                    >
                        <div class="w-10 h-10 flex items-center justify-center text-accent mb-4 border border-accent/20 bg-accent/5 group-hover:bg-accent group-hover:text-white transition-all duration-200 rounded-none">
                            <div class="w-5 h-5" set:html={f.icon} />
                        </div>
                        <Heading level={4} class="mb-2">
                            {f.title}
                        </Heading>
                        <Text size="lg" class="text-gray-400">
                            {f.body}
                        </Text>
                    </Card>
                ))
            }
        </Grid>

        <!-- Comparison Table -->
        <div class="scroll-animate">
            <Heading level={3} class="mb-6">Us vs. The Other Guys</Heading>

            <div class="border border-gray-200 overflow-hidden">
                <!-- Table header -->
                <div
                    class="grid grid-cols-3 bg-gray-50 border-b border-gray-200"
                >
                    <div
                        class="px-6 py-3 text-xs font-bold uppercase tracking-wider text-gray-400"
                    >
                        Feature
                    </div>
                    <div
                        class="px-6 py-3 text-xs font-bold uppercase tracking-wider text-primary text-center border-l border-gray-200"
                    >
                        Us
                    </div>
                    <div
                        class="px-6 py-3 text-xs font-bold uppercase tracking-wider text-gray-400 text-center border-l border-gray-200"
                    >
                        Others
                    </div>
                </div>

                {
                    comparison.map((row, i) => (
                        <div
                            class:list={[
                                "grid grid-cols-3 border-b border-gray-100 last:border-0",
                                i % 2 === 0 ? "bg-white" : "bg-gray-50/50",
                            ]}
                        >
                            <div class="px-6 py-4 text-lg font-medium text-text">
                                {row.feature}
                            </div>
                            <div class="px-6 py-4 flex items-center justify-center border-l border-gray-100">
                                {row.us ? (
                                    <svg
                                        class="w-5 h-5 text-accent"
                                        fill="currentColor"
                                        viewBox="0 0 20 20"
                                    >
                                        <path
                                            fill-rule="evenodd"
                                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                            clip-rule="evenodd"
                                        />
                                    </svg>
                                ) : (
                                    <svg
                                        class="w-5 h-5 text-gray-300"
                                        fill="currentColor"
                                        viewBox="0 0 20 20"
                                    >
                                        <path
                                            fill-rule="evenodd"
                                            d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                                            clip-rule="evenodd"
                                        />
                                    </svg>
                                )}
                            </div>
                            <div class="px-6 py-4 flex items-center justify-center border-l border-gray-100">
                                {row.them ? (
                                    <svg
                                        class="w-5 h-5 text-gray-400"
                                        fill="currentColor"
                                        viewBox="0 0 20 20"
                                    >
                                        <path
                                            fill-rule="evenodd"
                                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                            clip-rule="evenodd"
                                        />
                                    </svg>
                                ) : (
                                    <svg
                                        class="w-5 h-5 text-gray-300"
                                        fill="currentColor"
                                        viewBox="0 0 20 20"
                                    >
                                        <path
                                            fill-rule="evenodd"
                                            d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                                            clip-rule="evenodd"
                                        />
                                    </svg>
                                )}
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </Container>
</section>
