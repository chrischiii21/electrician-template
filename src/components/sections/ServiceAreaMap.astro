---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Badge from "../ui/Badge.astro";

interface Neighborhood {
    name: string;
    lat: number;
    lng: number;
    electricians?: number;
    avgResponse?: string;
}

interface Props {
    city: string;
    neighborhoods: Neighborhood[];
    totalElectricians?: number;
}

const { city, neighborhoods, totalElectricians = 6 } = Astro.props;
---

<section class="bg-white py-20" id="service-area-map">
    <Container size="lg">
        <!-- Header -->
        <div class="text-center mb-12 scroll-animate">
            <Badge variant="accent" class="mb-3">Service Coverage Map</Badge>
            <Heading level={2} class="text-4xl md:text-5xl mb-4">
                Our <span class="text-accent">{city}</span> Coverage Area
            </Heading>
            <Text size="xl" class="text-gray-700 max-w-2xl mx-auto">
                Click on any neighborhood to see our service coverage. We
                proudly serve the entire {city} metropolitan area.
            </Text>
        </div>

        <!-- Map Container -->
        <div class="grid md:grid-cols-3 gap-8 scroll-animate">
            <!-- Left: Neighborhood List -->
            <div class="md:col-span-1">
                <div class="bg-gray-50 border border-gray-200 p-6 h-full">
                    <Heading level={4} class="mb-4">Neighborhoods</Heading>
                    <div class="space-y-2 max-h-96 overflow-y-auto">
                        {
                            neighborhoods.map((neighborhood, index) => (
                                <button
                                    class="neighborhood-btn w-full text-left px-4 py-3 border border-gray-200 bg-white hover:border-accent hover:bg-accent/5 transition-all duration-200 text-sm font-medium text-gray-700 hover:text-accent"
                                    data-index={index}
                                    data-lat={neighborhood.lat}
                                    data-lng={neighborhood.lng}
                                    data-name={neighborhood.name}
                                    data-electricians={
                                        neighborhood.electricians ||
                                        Math.floor(Math.random() * 5) + 3
                                    }
                                    data-response={
                                        neighborhood.avgResponse ||
                                        `${Math.floor(Math.random() * 10) + 10}-${Math.floor(Math.random() * 10) + 15} min`
                                    }
                                >
                                    <span class="flex items-center gap-2">
                                        <span class="w-2 h-2 bg-accent opacity-0 group-hover:opacity-100 transition-opacity" />
                                        {neighborhood.name}
                                    </span>
                                </button>
                            ))
                        }
                    </div>
                </div>
            </div>

            <!-- Right: Map -->
            <div class="md:col-span-2">
                <div
                    class="relative overflow-hidden shadow-lg border border-gray-200 h-96 md:h-full min-h-96 group"
                >
                    <!-- Map Container -->
                    <div id="map" class="w-full h-full bg-gray-200"></div>

                    <!-- Info Card -->
                    <div
                        id="info-card"
                        class="absolute bottom-4 left-4 right-4 bg-white shadow-lg p-4 opacity-0 transition-opacity duration-300 pointer-events-none"
                    >
                        <div class="flex items-start justify-between gap-4">
                            <div class="flex-1">
                                <Heading
                                    level={5}
                                    id="neighborhood-name"
                                    class="mb-1">Select a neighborhood</Heading
                                >
                                <Text
                                    size="sm"
                                    id="neighborhood-info"
                                    class="text-gray-600 mb-2"
                                    >Click on a neighborhood to see details</Text
                                >
                                <div class="flex items-center gap-2">
                                    <div
                                        id="electrician-indicators"
                                        class="flex gap-1"
                                    >
                                    </div>
                                    <Text
                                        size="sm"
                                        class="text-gray-700 font-medium"
                                    >
                                        <span id="electrician-count">0</span> electricians
                                        active
                                    </Text>
                                </div>
                            </div>
                            <svg
                                class="w-5 h-5 text-accent shrink-0"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"
                                    clip-rule="evenodd"></path>
                            </svg>
                        </div>
                    </div>

                    <!-- Loading indicator -->
                    <div
                        id="map-loading"
                        class="absolute inset-0 flex items-center justify-center bg-white/50 backdrop-blur"
                    >
                        <div class="text-center">
                            <div
                                class="w-8 h-8 border-4 border-accent border-t-transparent animate-spin mx-auto mb-2"
                            >
                            </div>
                            <Text size="sm" class="text-gray-600"
                                >Loading map...</Text
                            >
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Stats -->
        <div class="grid md:grid-cols-4 gap-4 mt-8">
            <div
                class="bg-gray-50 border border-gray-200 p-6 text-center hover:border-accent hover:shadow-lg hover:shadow-accent/20 transition-all duration-300"
            >
                <div
                    id="total-electrician-indicators"
                    class="flex items-center justify-center gap-2 mb-3"
                >
                    {
                        [...Array(totalElectricians)].map(() => (
                            <div class="w-6 h-6 bg-accent" />
                        ))
                    }
                </div>
                <div
                    id="total-electrician-count"
                    class="text-2xl font-bold text-accent mb-1"
                >
                    {totalElectricians}
                </div>
                <Text size="sm" class="text-gray-600">
                    Licensed Electricians Active
                </Text>
            </div>
            <div
                class="bg-gray-50 border border-gray-200 p-6 text-center hover:border-accent hover:shadow-lg hover:shadow-accent/20 transition-all duration-300"
            >
                <div class="text-3xl font-bold text-accent mb-2">
                    {neighborhoods.length}+
                </div>
                <Text size="sm" class="text-gray-600">Neighborhoods Served</Text
                >
            </div>
            <div
                class="bg-gray-50 border border-gray-200 p-6 text-center hover:border-accent hover:shadow-lg hover:shadow-accent/20 transition-all duration-300"
            >
                <div class="text-3xl font-bold text-accent mb-2">24/7</div>
                <Text size="sm" class="text-gray-600">Emergency Response</Text>
            </div>
            <div
                class="bg-gray-50 border border-gray-200 p-6 text-center hover:border-accent hover:shadow-lg hover:shadow-accent/20 transition-all duration-300"
            >
                <div
                    id="avg-response-time"
                    class="text-3xl font-bold text-accent mb-2"
                >
                    10-15 min
                </div>
                <Text size="sm" class="text-gray-600">Avg Response Time</Text>
            </div>
        </div>
    </Container>
</section>

<script>
    // Initialize map with Leaflet
    const script = document.createElement("script");
    script.src = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js";
    script.onload = () => {
        const link = document.createElement("link");
        link.rel = "stylesheet";
        link.href = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css";
        document.head.appendChild(link);

        setTimeout(() => {
            const mapElement = document.getElementById("map");
            const loadingElement = document.getElementById("map-loading");

            if (!mapElement) return;

            // Initialize map centered on Los Angeles
            const map = (window as any).L.map(mapElement).setView(
                [34.0522, -118.2437],
                11,
            );

            // Add tile layer
            (window as any).L.tileLayer(
                "https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png",
                {
                    attribution: "© OpenStreetMap contributors",
                    maxZoom: 19,
                },
            ).addTo(map);

            // Add markers for each neighborhood
            const buttons = document.querySelectorAll(".neighborhood-btn");
            const infoCard = document.getElementById("info-card");
            const neighborhoodName =
                document.getElementById("neighborhood-name");
            const neighborhoodInfo =
                document.getElementById("neighborhood-info");
            let currentMarker: any = null;

            buttons.forEach((button) => {
                const lat = parseFloat(button.getAttribute("data-lat") || "0");
                const lng = parseFloat(button.getAttribute("data-lng") || "0");
                const name = button.getAttribute("data-name") || "";
                const electricians = parseInt(
                    button.getAttribute("data-electricians") || "5",
                );
                const response =
                    button.getAttribute("data-response") || "10-15 min";

                // Add marker
                const marker = (window as any).L.circleMarker([lat, lng], {
                    radius: 6,
                    fillColor: "#D52212",
                    color: "#fff",
                    weight: 2,
                    opacity: 1,
                    fillOpacity: 0.8,
                }).addTo(map);

                // Marker click handler
                marker.on("click", () => {
                    map.setView([lat, lng], 13);
                    updateInfo(name, electricians, response);
                    highlightButton(button);
                    currentMarker = marker;
                });

                // Button click handler
                button.addEventListener("click", () => {
                    map.setView([lat, lng], 13);
                    updateInfo(name, electricians, response);
                    highlightButton(button);
                    currentMarker = marker;
                });
            });

            function updateInfo(
                name: string,
                electricians: number,
                response: string,
            ) {
                if (neighborhoodName && neighborhoodInfo && infoCard) {
                    neighborhoodName.textContent = name;
                    neighborhoodInfo.textContent = `We proudly serve ${name} with 24/7 emergency response and same-day service availability.`;

                    // Update electrician count in info card
                    const electricianCount =
                        document.getElementById("electrician-count");
                    const electricianIndicators = document.getElementById(
                        "electrician-indicators",
                    );
                    if (electricianCount) {
                        electricianCount.textContent = electricians.toString();
                    }
                    if (electricianIndicators) {
                        electricianIndicators.innerHTML = "";
                        for (let i = 0; i < electricians; i++) {
                            const indicator = document.createElement("div");
                            indicator.className = "w-4 h-4 bg-accent";
                            electricianIndicators.appendChild(indicator);
                        }
                    }

                    // Update total stats
                    const totalCount = document.getElementById(
                        "total-electrician-count",
                    );
                    const totalIndicators = document.getElementById(
                        "total-electrician-indicators",
                    );
                    const avgResponseTime =
                        document.getElementById("avg-response-time");

                    if (totalCount) {
                        totalCount.textContent = electricians.toString();
                    }
                    if (totalIndicators) {
                        totalIndicators.innerHTML = "";
                        const indicatorsContainer =
                            document.createElement("div");
                        indicatorsContainer.className =
                            "flex items-center justify-center gap-2";
                        for (let i = 0; i < electricians; i++) {
                            const indicator = document.createElement("div");
                            indicator.className = "w-6 h-6 bg-accent";
                            indicatorsContainer.appendChild(indicator);
                        }
                        totalIndicators.appendChild(indicatorsContainer);
                    }
                    if (avgResponseTime) {
                        avgResponseTime.textContent = response;
                    }

                    infoCard.classList.remove("opacity-0");
                    infoCard.classList.add("opacity-100");
                }
            }

            function highlightButton(button: Element) {
                buttons.forEach((btn) => {
                    btn.classList.remove("border-accent", "bg-accent/5");
                    btn.classList.add("border-gray-200", "bg-white");
                });
                button.classList.remove("border-gray-200", "bg-white");
                button.classList.add("border-accent", "bg-accent/5");
            }

            // Hide loading indicator
            if (loadingElement) {
                loadingElement.style.display = "none";
            }
        }, 100);
    };
    document.head.appendChild(script);
</script>

<style>
    #map {
        z-index: 1;
    }

    .neighborhood-btn {
        position: relative;
    }

    .neighborhood-btn:hover span:first-child {
        opacity: 1;
    }
</style>
