---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Badge from "../ui/Badge.astro";
import Grid from "../ui/Grid.astro";

const iconMap: Record<string, string> = {
    home: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
    building: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
    alert: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>`,
    star: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>`,
};

const rawContent = await import("../../content/local-services.md?raw").then(
    (m) => m.default,
);

const services = rawContent
    .split("\n")
    .filter((line: string) => line.startsWith("## "))
    .map((line: string) => {
        const title = line.replace("## ", "").trim();
        const lines = rawContent.split("\n");
        const lineIndex = lines.indexOf(line);

        let description = "";
        let iconKey = "";
        let link = "";

        for (let i = lineIndex + 1; i < lines.length; i++) {
            const currentLine = lines[i];
            if (currentLine.includes("**Description**")) {
                description =
                    currentLine
                        .match(/\*\*Description\*\*:\s*(.+)/)?.[1]
                        ?.trim() || "";
            }
            if (currentLine.includes("**Icon**")) {
                iconKey =
                    currentLine.match(/\*\*Icon\*\*:\s*(.+)/)?.[1]?.trim() ||
                    "";
            }
            if (currentLine.includes("**Link**")) {
                link =
                    currentLine.match(/\*\*Link\*\*:\s*(.+)/)?.[1]?.trim() ||
                    "";
            }
            if (currentLine.startsWith("## ") && currentLine !== line) break;
        }

        return {
            title,
            description,
            icon: iconMap[iconKey] || iconMap["home"],
            link,
        };
    });
---

<section class="bg-gray-50 py-20" id="local-services">
    <Container size="lg">
        <!-- Header -->
        <div class="text-center mb-16 scroll-animate">
            <Badge variant="accent" class="mb-3">Available Services</Badge>
            <Heading level={2} class="text-4xl md:text-5xl mb-4">
                Complete Electrical Solutions in <span class="text-accent"
                    >Los Angeles</span
                >
            </Heading>
            <Text size="xl" class="text-gray-700 max-w-2xl mx-auto">
                Whatever your electrical needs, we have the expertise and
                experience to help.
            </Text>
        </div>

        <!-- Services Grid -->
        <Grid cols={2} gap="lg" class="scroll-stagger">
            {
                services.map((service) => (
                    <a
                        href={service.link}
                        class="group bg-white border border-gray-200 p-8 hover:border-accent hover:shadow-lg hover:shadow-accent/20 transition-all duration-300"
                    >
                        <div class="w-14 h-14 bg-accent/10 flex items-center justify-center text-accent mb-4 border border-accent/20 group-hover:bg-accent group-hover:text-white transition-all duration-300">
                            <div class="w-7 h-7" set:html={service.icon} />
                        </div>
                        <Heading
                            level={4}
                            class="mb-2 group-hover:text-accent transition-colors duration-300"
                        >
                            {service.title}
                        </Heading>
                        <Text size="sm" class="text-gray-600">
                            {service.description}
                        </Text>
                        <div class="mt-4 flex items-center gap-2 text-accent font-semibold text-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                            Learn More
                            <svg
                                class="w-4 h-4"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9 5l7 7-7 7"
                                />
                            </svg>
                        </div>
                    </a>
                ))
            }
        </Grid>
    </Container>
</section>
