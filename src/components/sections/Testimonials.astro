---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Badge from "../ui/Badge.astro";
import Button from "../ui/Button.astro";

const rawContent = await import("../../content/testimonials.md?raw").then(
    (m) => m.default,
);

const testimonials = rawContent
    .split("\n")
    .filter((line: string) => line.startsWith("## "))
    .map((line: string) => {
        const name = line.replace("## ", "").trim();
        const lines = rawContent.split("\n");
        const lineIndex = lines.indexOf(line);
        
        let location = "";
        let job = "";
        let rating = 5;
        let quote = "";
        let avatar = "";
        
        for (let i = lineIndex + 1; i < lines.length; i++) {
            const currentLine = lines[i];
            if (currentLine.includes("**Location**")) {
                location = currentLine.match(/\*\*Location\*\*:\s*(.+)/)?.[1]?.trim() || "";
            }
            if (currentLine.includes("**Job**")) {
                job = currentLine.match(/\*\*Job\*\*:\s*(.+)/)?.[1]?.trim() || "";
            }
            if (currentLine.includes("**Rating**")) {
                rating = parseInt(currentLine.match(/\*\*Rating\*\*:\s*(.+)/)?.[1]?.trim() || "5");
            }
            if (currentLine.includes("**Quote**")) {
                quote = currentLine.match(/\*\*Quote\*\*:\s*(.+)/)?.[1]?.trim() || "";
            }
            if (currentLine.includes("**Avatar**")) {
                avatar = currentLine.match(/\*\*Avatar\*\*:\s*(.+)/)?.[1]?.trim() || "";
            }
            if (currentLine.startsWith("## ") && currentLine !== line) break;
        }

        return {
            name,
            location,
            job,
            rating,
            quote,
            avatar,
        };
    });
---

<section class="bg-white py-20 overflow-hidden" id="testimonials">
    <Container size="lg">

        <!-- Header -->
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12 scroll-animate">
            <div>
                <Badge variant="accent" class="mb-3">Customer Reviews</Badge>
                <Heading level={2} class="!text-text text-4xl md:text-5xl">
                    What Our Customers <span class="text-accent">Are Saying</span>
                </Heading>
            </div>
            <div class="flex items-center gap-4 shrink-0">
                <!-- Prev / Next -->
                <button id="t-prev" aria-label="Previous review"
                    class="w-11 h-11 border border-gray-200 flex items-center justify-center text-gray-400 hover:border-accent hover:text-accent transition-all duration-200 cursor-pointer">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                    </svg>
                </button>
                <button id="t-next" aria-label="Next review"
                    class="w-11 h-11 border border-gray-200 flex items-center justify-center text-gray-400 hover:border-accent hover:text-accent transition-all duration-200 cursor-pointer">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Carousel track -->
        <div class="relative scroll-animate">
            <!-- Big quote mark -->
            <div class="absolute -top-4 left-0 text-accent/10 font-heading font-bold leading-none select-none pointer-events-none" style="font-size: 12rem; line-height: 1">"</div>

            <div class="grid md:grid-cols-3 gap-8 items-start">

                <!-- Left: sliding quotes (2 cols) -->
                <div class="md:col-span-2">
                    <div id="t-track" class="relative overflow-hidden">
                        <div id="t-inner" class="flex transition-transform duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]">
                            {testimonials.map((t) => (
                                <div class="t-slide w-full shrink-0">
                                    <!-- Stars -->
                                    <div class="flex gap-1 mb-6">
                                        {Array.from({ length: t.rating }).map(() => (
                                            <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20">
                                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                            </svg>
                                        ))}
                                    </div>
                                    <p class="font-heading font-bold !text-text text-2xl md:text-3xl leading-snug mb-8">
                                        "{t.quote}"
                                    </p>
                                    <!-- Author -->
                                    <div class="flex items-center gap-4">
                                        <div class="w-12 h-12 bg-primary flex items-center justify-center shrink-0">
                                            <span class="text-white font-heading font-bold">{t.avatar}</span>
                                        </div>
                                        <div>
                                            <Heading level={5} class="!text-text">
                                                {t.name}
                                            </Heading>
                                            <Text size="sm" class="!text-gray-400" as="p">{t.job} · {t.location}</Text>
                                        </div>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>

                    <!-- Dot nav + progress bar -->
                    <div class="mt-10 flex items-center gap-6">
                        <div class="flex gap-1" id="t-dots">
                            {testimonials.map((_, i) => (
                                <button
                                    class:list={["t-dot h-2 transition-all duration-300 cursor-pointer", i === 0 ? "bg-accent w-6" : "bg-gray-200 w-2"]}
                                    data-index={i}
                                    aria-label={`Go to review ${i + 1}`}
                                ></button>
                            ))}
                        </div>
                        <div class="flex-1 h-px bg-gray-100 relative overflow-hidden">
                            <div id="t-progress" class="absolute left-0 top-0 h-full bg-accent" style="width: 0%; transition: width linear"></div>
                        </div>
                        <Text size="xs" class="!text-gray-400 !font-mono shrink-0" as="span" id="t-counter">1 / {testimonials.length}</Text>
                    </div>
                </div>

                <!-- Right: static stat card -->
                <div class="hidden md:flex flex-col gap-4">
                    <div class="bg-gray-50 border border-gray-100 p-6">
                        <Heading level={3} class="!text-accent text-5xl mb-1">
                            4.9
                        </Heading>
                        <div class="flex gap-0.5 mb-2">
                            {Array.from({ length: 5 }).map(() => (
                                <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                </svg>
                            ))}
                        </div>
                        <Text size="sm" class="!text-gray-400" as="p">Average across 1,200+ reviews</Text>
                    </div>
                    <Button href="/reviews" variant="outline" size="md" class="uppercase tracking-wider font-bold text-center">
                        Read All Reviews
                    </Button>
                </div>

            </div>
        </div>

    </Container>
</section>

<script>
    const slides = document.querySelectorAll<HTMLElement>(".t-slide");
    const inner = document.getElementById("t-inner") as HTMLElement;
    const dots = document.querySelectorAll<HTMLButtonElement>(".t-dot");
    const counter = document.getElementById("t-counter");
    const progress = document.getElementById("t-progress") as HTMLElement;
    const total = slides.length;
    const AUTOPLAY_MS = 5000;
    let current = 0;
    let timer: ReturnType<typeof setTimeout> | undefined;
    let progressTimer: ReturnType<typeof setInterval> | undefined;

    function goTo(index: number) {
        current = (index + total) % total;
        inner.style.transform = `translateX(-${current * 100}%)`;

        dots.forEach((d, i) => {
            d.classList.toggle("bg-primary", i === current);
            d.classList.toggle("w-6", i === current);
            d.classList.toggle("bg-gray-200", i !== current);
            d.classList.toggle("w-2", i !== current);
        });

        if (counter) counter.textContent = `${current + 1} / ${total}`;
        resetProgress();
    }

    function resetProgress() {
        clearTimeout(timer);
        clearInterval(progressTimer);
        progress.style.transition = "none";
        progress.style.width = "0%";

        // Force reflow
        progress.offsetHeight;

        progress.style.transition = `width ${AUTOPLAY_MS}ms linear`;
        progress.style.width = "100%";

        timer = setTimeout(() => goTo(current + 1), AUTOPLAY_MS);
    }

    dots.forEach((dot) => {
        dot.addEventListener("click", () => goTo(parseInt(dot.dataset.index ?? "0")));
    });

    document.getElementById("t-prev")?.addEventListener("click", () => goTo(current - 1));
    document.getElementById("t-next")?.addEventListener("click", () => goTo(current + 1));

    // Pause on hover
    const section = document.getElementById("testimonials");
    section?.addEventListener("mouseenter", () => {
        clearTimeout(timer);
        clearInterval(progressTimer);
        progress.style.transition = "none";
    });
    section?.addEventListener("mouseleave", () => resetProgress());

    // Swipe support
    let touchStartX = 0;
    inner.addEventListener("touchstart", (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    inner.addEventListener("touchend", (e) => {
        const diff = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 50) goTo(diff > 0 ? current + 1 : current - 1);
    });

    // Init
    goTo(0);
</script>
