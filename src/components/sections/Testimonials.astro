---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Badge from "../ui/Badge.astro";
import Button from "../ui/Button.astro";

const { default: rawContent } = await import("../../content/testimonials.md?raw");

const testimonials = rawContent
    .split("\n")
    .filter((line: string) => line.startsWith("## "))
    .map((line: string) => {
        const name = line.replace("## ", "").trim();
        const lines = rawContent.split("\n");
        const lineIndex = lines.indexOf(line);
        
        let location = "";
        let job = "";
        let rating = 5;
        let quote = "";
        let avatar = "";
        let date = "";
        
        for (let i = lineIndex + 1; i < lines.length; i++) {
            const currentLine = lines[i];
            if (currentLine.includes("**Location**")) {
                location = currentLine.match(/\*\*Location\*\*:\s*(.+)/)?.[1]?.trim() || "";
            }
            if (currentLine.includes("**Job**")) {
                job = currentLine.match(/\*\*Job\*\*:\s*(.+)/)?.[1]?.trim() || "";
            }
            if (currentLine.includes("**Rating**")) {
                rating = parseInt(currentLine.match(/\*\*Rating\*\*:\s*(.+)/)?.[1]?.trim() || "5");
            }
            if (currentLine.includes("**Quote**")) {
                quote = currentLine.match(/\*\*Quote\*\*:\s*(.+)/)?.[1]?.trim() || "";
            }
            if (currentLine.includes("**Avatar**")) {
                avatar = currentLine.match(/\*\*Avatar\*\*:\s*(.+)/)?.[1]?.trim() || "";
            }
            if (currentLine.startsWith("## ") && currentLine !== line) break;
        }

        // Generate a realistic date (within last 3 months)
        const daysAgo = Math.floor(Math.random() * 90);
        const reviewDate = new Date();
        reviewDate.setDate(reviewDate.getDate() - daysAgo);
        date = reviewDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

        return {
            name,
            location,
            job,
            rating,
            quote,
            avatar,
            date,
        };
    });

// Duplicate for infinite scroll
const duplicated = [...testimonials, ...testimonials];

// Google Business Profile URL (replace with actual URL)
const googleBusinessUrl = "https://www.google.com/maps/place/Your+Business+Name";
---

<section class="bg-gray-50 py-16 overflow-hidden" id="testimonials">
    <Container size="lg">

        <!-- Header -->
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10 scroll-animate">
            <div class="flex-1">
                <div class="flex items-center gap-3 mb-3">
                    <Badge variant="accent">Testimonials</Badge>
                    <div class="flex items-center gap-2 px-3 py-1 bg-gray-50 border border-gray-200 rounded-full">
                        <svg class="w-4 h-4" viewBox="0 0 24 24">
                            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                        </svg>
                        <span class="text-sm font-semibold text-gray-700">Google Reviews</span>
                    </div>
                </div>
                <Heading level={2} class="!text-text text-4xl md:text-5xl mb-3">
                    What Our Clients <span class="text-accent">Are Saying</span>
                </Heading>
                <Text size="xl" class="!text-gray-600 max-w-xl">
                    Real reviews from real customers. See why homeowners and businesses trust our electrical services.
                </Text>
            </div>
            <div class="flex flex-col items-end gap-2 shrink-0">
                <div class="flex items-center gap-2">
                    <div class="flex gap-0.5">
                        {Array.from({ length: 5 }).map(() => (
                            <svg class="w-7 h-7 text-accent" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                            </svg>
                        ))}
                    </div>
                    <span class="text-3xl font-bold text-text">4.8</span>
                </div>
                <div class="text-right">
                    <div class="text-sm text-gray-600 font-medium">Based on 203 reviews</div>
                    <a href={googleBusinessUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-accent hover:text-accent/80 font-medium hover:underline transition-colors">
                        View on Google →
                    </a>
                </div>
            </div>
        </div>

        <!-- Scrolling Testimonials -->
        <div class="relative mb-10 py-4">
            <div class="absolute left-0 top-0 bottom-0 w-20 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none"></div>
            <div class="absolute right-0 top-0 bottom-0 w-20 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none"></div>

            <div class="testimonial-track">
                <div class="testimonial-track-inner">
                    {duplicated.map((t) => (
                        <a href={googleBusinessUrl} target="_blank" rel="noopener noreferrer" class="testimonial-item">
                            <div class="testimonial-card">
                                <!-- Header -->
                                <div class="flex items-start justify-between mb-3">
                                    <div class="flex items-start gap-3 flex-1 min-w-0">
                                        <div class="w-11 h-11 bg-primary rounded-full flex items-center justify-center shrink-0">
                                            <span class="text-white font-heading font-bold text-base">{t.avatar}</span>
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <div class="font-heading font-bold text-text mb-0.5 truncate">{t.name}</div>
                                            <div class="flex items-center gap-1.5">
                                                <div class="flex gap-0.5">
                                                    {Array.from({ length: t.rating }).map(() => (
                                                        <svg class="w-3.5 h-3.5 text-accent" fill="currentColor" viewBox="0 0 20 20">
                                                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                                        </svg>
                                                    ))}
                                                </div>
                                                <span class="text-xs text-gray-400">•</span>
                                                <span class="text-xs text-gray-500">{t.date}</span>
                                            </div>
                                        </div>
                                    </div>
                                    <svg class="w-5 h-5 shrink-0 ml-2" viewBox="0 0 24 24">
                                        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                                        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                                        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                                        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                                    </svg>
                                </div>
                                
                                <!-- Quote -->
                                <Text size="sm" class="!text-gray-700 leading-relaxed mb-4">
                                    "{t.quote}"
                                </Text>
                                
                                <!-- Footer -->
                                <div class="flex items-center gap-1.5 pt-3 border-t border-gray-200">
                                    <svg class="w-3.5 h-3.5 text-accent" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                                    </svg>
                                    <span class="text-xs text-gray-500 font-medium">Verified Google Review</span>
                                </div>
                            </div>
                        </a>
                    ))}
                </div>
            </div>
        </div>

        <!-- CTA -->
        <div class="text-center scroll-animate">
            <Button href="/reviews" variant="primary" size="lg" class="uppercase tracking-wider font-bold">
                Read All Reviews
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
            </Button>
        </div>

    </Container>
</section>

<style>
    .testimonial-track {
        overflow: hidden;
        width: 100%;
    }

    .testimonial-track-inner {
        display: flex;
        gap: 1.5rem;
        animation: scroll-left 40s linear infinite;
        width: fit-content;
    }

    .testimonial-track:hover .testimonial-track-inner {
        animation-play-state: paused;
    }

    @keyframes scroll-left {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(-50%);
        }
    }

    .testimonial-item {
        flex-shrink: 0;
        width: 380px;
        text-decoration: none;
        display: block;
    }

    .testimonial-card {
        background: white;
        border: 2px solid #e5e7eb;
        padding: 1.25rem;
        height: 100%;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .testimonial-card:hover {
        border-color: var(--accent);
        box-shadow: 0 8px 24px rgba(213, 34, 18, 0.15);
        transform: translateY(-4px);
    }
</style>
