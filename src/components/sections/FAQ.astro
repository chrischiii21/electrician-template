// Get the appropriate FAQ set based on page type
const { faqs, categories } = faqSets[pageType] || faqSets.home;
---

<section class="bg-background py-20" id="faq">
    <Container size="lg">
        <div class="bg-background">
            <!-- Header -->
            <div class="text-center mb-12 scroll-animate">
                <Badge variant="accent" class="mb-3 uppercase tracking-wider"
                    >Fill Every Call with Joy</Badge
                >
                <Heading level={2} class="!text-text text-4xl md:text-5xl mb-4">
                    Frequently <span class="text-accent">Asked Questions</span>
                </Heading>
                <Text size="xl" class="!text-gray-600 max-w-5xl mx-auto">
                    Find answers to common questions about our electrical
                    services and how we can benefit your business.
                </Text>
            </div>

            <!-- Main Layout: Sidebar + Content -->
            <div class="grid lg:grid-cols-4 gap-8 lg:gap-12">
                <!-- Left Sidebar - Categories -->
                <div class="lg:col-span-1">
                    <div class="lg:sticky lg:top-24">
                        <Heading level={5} class="!text-text mb-4 text-lg">
                            Categories
                        </Heading>
                        <nav class="space-y-1">
                            {
                                categories.map((category, index) => (
                                    <button
                                        class:list={[
                                            "category-btn w-full text-left px-4 py-3 text-lg transition-all duration-200 border-l-4",
                                            {
                                                "border-accent bg-accent/5 text-accent font-bold":
                                                    index === 0,
                                                "border-transparent text-gray-600 hover:border-gray-300 hover:bg-gray-50":
                                                    index !== 0,
                                            },
                                        ]}
                                        data-category={category}
                                    >
                                        {category}
                                    </button>
                                ))
                            }
                        </nav>
                    </div>
                </div>

                <!-- Right Content - FAQ Items -->
                <div class="lg:col-span-3">
                    <div class="space-y-4">
                        {
                            faqs.map((faq, index) => {
                                const firstCategory = categories[0];
                                const isFirstCategoryItem =
                                    faq.category === firstCategory;
                                const isFirstItemInCategory =
                                    faqs.findIndex(
                                        (f) => f.category === faq.category,
                                    ) === index;

                                return (
                                    <div
                                        class:list={[
                                            "faq-item border border-gray-200 transition-all duration-300",
                                            {
                                                hidden: !isFirstCategoryItem,
                                            },
                                        ]}
                                        data-category={faq.category}
                                    >
                                        <button
                                            class="faq-question w-full text-left px-6 py-5 flex items-center justify-between gap-4 group hover:bg-gray-50 transition-colors"
                                            aria-expanded={
                                                isFirstCategoryItem &&
                                                isFirstItemInCategory
                                                    ? "true"
                                                    : "false"
                                            }
                                        >
                                            <Heading
                                                level={5}
                                                class="!text-text text-lg group-hover:!text-accent transition-colors"
                                            >
                                                {faq.question}
                                            </Heading>
                                            <div class="shrink-0 w-8 h-8 flex items-center justify-center">
                                                <svg
                                                    class:list={[
                                                        "faq-icon w-5 h-5 text-gray-400 group-hover:text-accent transition-all duration-300",
                                                        {
                                                            "rotate-180":
                                                                isFirstCategoryItem &&
                                                                isFirstItemInCategory,
                                                        },
                                                    ]}
                                                    fill="none"
                                                    stroke="currentColor"
                                                    viewBox="0 0 24 24"
                                                >
                                                    <path
                                                        stroke-linecap="round"
                                                        stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M19 9l-7 7-7-7"
                                                    />
                                                </svg>
                                            </div>
                                        </button>
                                        <div
                                            class:list={[
                                                "faq-answer px-6 pb-5",
                                                {
                                                    hidden: !(
                                                        isFirstCategoryItem &&
                                                        isFirstItemInCategory
                                                    ),
                                                },
                                            ]}
                                        >
                                            <Text
                                                size="md"
                                                class="!text-gray-600 leading-relaxed"
                                            >
                                                <span set:html={faq.answer} />
                                            </Text>
                                        </div>
                                    </div>
                                );
                            })
                        }
                    </div>

                    <!-- Still Have Questions CTA -->
                    <div
                        class="mt-8 bg-gray-100 p-6 flex items-center justify-between gap-6 flex-wrap"
                    >
                        <div class="flex items-center gap-4">
                            <svg
                                class="w-8 h-8 text-text shrink-0"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path>
                            </svg>
                            <div>
                                <Heading
                                    level={5}
                                    class="!text-text text-lg mb-1"
                                >
                                    Still have a question?
                                </Heading>
                                <Text size="sm" class="!text-gray-600">
                                    If you didn't find your answer, feel free to
                                    reach out.
                                </Text>
                            </div>
                        </div>
                        <Button href="/contact" variant="primary" size="md">
                            Contact us
                        </Button>
                    </div>
                </div>
            </div>
        </div>
    </Container>
</section>

<script>
    // FAQ accordion functionality
    const faqQuestions =
        document.querySelectorAll<HTMLElement>(".faq-question");

    faqQuestions.forEach((question) => {
        question.addEventListener("click", () => {
            const faqItem = question.closest(".faq-item");
            const answer = faqItem?.querySelector<HTMLElement>(".faq-answer");
            const icon = question.querySelector<HTMLElement>(".faq-icon");
            const isExpanded =
                question.getAttribute("aria-expanded") === "true";

            // Toggle current item
            question.setAttribute("aria-expanded", String(!isExpanded));
            answer?.classList.toggle("hidden");
            icon?.classList.toggle("rotate-180");

            // Toggle active state styling
            if (!isExpanded) {
                faqItem?.classList.add("border-accent", "bg-accent/5");
                faqItem?.classList.remove("border-gray-200");
                question.classList.add("bg-accent/5");
                question.classList.remove("hover:bg-gray-50");
            } else {
                faqItem?.classList.remove("border-accent", "bg-accent/5");
                faqItem?.classList.add("border-gray-200");
                question.classList.remove("bg-accent/5");
                question.classList.add("hover:bg-gray-50");
            }
        });
    });

    // Category filter functionality
    const categoryButtons =
        document.querySelectorAll<HTMLElement>(".category-btn");
    const faqItems = document.querySelectorAll<HTMLElement>(".faq-item");

    categoryButtons.forEach((button) => {
        button.addEventListener("click", () => {
            const category = button.dataset.category;

            // Update active button
            categoryButtons.forEach((btn) => {
                btn.classList.remove(
                    "border-accent",
                    "bg-accent/5",
                    "text-accent",
                    "font-bold",
                );
                btn.classList.add(
                    "border-transparent",
                    "text-gray-600",
                    "hover:border-gray-300",
                    "hover:bg-gray-50",
                );
            });
            button.classList.remove(
                "border-transparent",
                "text-gray-600",
                "hover:border-gray-300",
                "hover:bg-gray-50",
            );
            button.classList.add(
                "border-accent",
                "bg-accent/5",
                "text-accent",
                "font-bold",
            );

            // Filter FAQ items
            faqItems.forEach((item) => {
                const itemCategory = item.dataset.category;
                if (itemCategory === category) {
                    item.classList.remove("hidden");
                } else {
                    item.classList.add("hidden");
                    // Close any open items when filtering
                    const question =
                        item.querySelector<HTMLElement>(".faq-question");
                    const answer =
                        item.querySelector<HTMLElement>(".faq-answer");
                    const icon = item.querySelector<HTMLElement>(".faq-icon");
                    question?.setAttribute("aria-expanded", "false");
                    answer?.classList.add("hidden");
                    icon?.classList.remove("rotate-180");
                }
            });
        });
    });
</script>
