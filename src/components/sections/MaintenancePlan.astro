---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Badge from "../ui/Badge.astro";
import Button from "../ui/Button.astro";
import Card from "../ui/Card.astro";

const plans = [
    {
        name: "Basic Plan",
        price: "$9.99",
        period: "per month",
        description:
            "Essential maintenance for homeowners who want peace of mind.",
        features: [
            "Annual safety inspection",
            "Priority scheduling",
            "10% off all repairs",
            "Email service reminders",
            "Basic electrical assessment",
            "Safety checklist report",
        ],
        cta: "Get Started",
        ctaLink: "/contact",
        highlighted: false,
        image: "https://images.unsplash.com/photo-1621905252507-b35492cc74b4?w=400&h=300&fit=crop",
    },
    {
        name: "Premium Plan",
        price: "$14.33",
        period: "per month",
        description:
            "Complete protection with priority service and maximum savings.",
        features: [
            "Bi-annual safety inspections",
            "Priority scheduling",
            "15% off all repairs",
            "No overtime charges",
            "24/7 emergency support",
            "Transferable membership",
        ],
        cta: "Most Popular",
        ctaLink: "/contact",
        highlighted: true,
        badge: "Best Value",
        image: "https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=400&h=300&fit=crop",
    },
    {
        name: "Commercial Plan",
        price: "$49.99",
        period: "per month",
        description:
            "Comprehensive maintenance for businesses and commercial properties.",
        features: [
            "Quarterly safety inspections",
            "Priority emergency response",
            "20% off all repairs",
            "Dedicated account manager",
            "Compliance documentation",
            "Preventive maintenance reports",
        ],
        cta: "Contact Sales",
        ctaLink: "/contact",
        highlighted: false,
        image: "https://images.unsplash.com/photo-1581092918056-0c4c3acd3789?w=400&h=300&fit=crop",
    },
];

const benefits = [
    {
        icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
        title: "Prevent Costly Repairs",
        description:
            "Regular inspections catch small issues before they become expensive emergencies.",
    },
    {
        icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
        title: "Extend Equipment Life",
        description:
            "Proper maintenance keeps your electrical systems running efficiently for years longer.",
    },
    {
        icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
        title: "Save Money Long-Term",
        description:
            "Members save an average of $500 annually on electrical services and repairs.",
    },
    {
        icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
        title: "Priority Service",
        description:
            "Skip the line with priority scheduling and faster emergency response times.",
    },
];

const whatsCovered = [
    "Electrical panel inspection and testing",
    "Circuit breaker functionality check",
    "GFCI and AFCI outlet testing",
    "Smoke and CO detector inspection",
    "Lighting system assessment",
    "Wiring and connection inspection",
    "Grounding system verification",
    "Load capacity evaluation",
    "Safety hazard identification",
    "Energy efficiency recommendations",
    "Code compliance review",
    "Detailed inspection report",
];
---

<section class="bg-white py-20" id="maintenance-plan">
    <Container size="lg">
        <!-- Header -->
        <div class="text-center mb-16 scroll-animate">
            <Badge variant="accent" class="mb-3 uppercase tracking-wider">
                Maintenance Plans
            </Badge>
            <Heading level={2} class="text-4xl md:text-5xl mb-4">
                Keep Your Electrical System <span class="text-accent"
                    >Running Smoothly</span
                >
            </Heading>
            <Text size="xl" class="text-gray-700 max-w-3xl mx-auto">
                Regular maintenance prevents emergencies, extends equipment
                life, and saves you money. Choose the plan that fits your needs.
            </Text>
        </div>

        <!-- Benefits Grid -->
        <div
            class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16 scroll-stagger"
        >
            {
                benefits.map((benefit) => (
                    <Card
                        padding="lg"
                        class="border border-gray-200 hover:border-accent hover:shadow-lg hover:shadow-accent/10 transition-all duration-300 group"
                    >
                        <div class="w-12 h-12 flex items-center justify-center bg-accent/10 border border-accent/20 mb-4 group-hover:bg-accent group-hover:border-accent transition-all duration-300">
                            <div
                                class="w-6 h-6 text-accent group-hover:text-white transition-colors"
                                set:html={benefit.icon}
                            />
                        </div>
                        <Heading level={4} class="text-lg font-bold mb-2">
                            {benefit.title}
                        </Heading>
                        <Text size="sm" class="text-gray-600 leading-relaxed">
                            {benefit.description}
                        </Text>
                    </Card>
                ))
            }
        </div>

        <!-- Pricing Cards -->
        <div class="grid md:grid-cols-3 gap-8 mb-16 scroll-stagger">
            {
                plans.map((plan) => (
                    <div
                        class:list={[
                            "relative bg-white border-2 overflow-hidden transition-all duration-300 hover:shadow-2xl group",
                            {
                                "border-accent shadow-xl": plan.highlighted,
                                "border-gray-200 hover:border-accent":
                                    !plan.highlighted,
                            },
                        ]}
                    >
                        {/* Recommended Badge */}
                        {plan.highlighted && plan.badge && (
                            <div class="absolute top-0 right-0 bg-accent text-white px-4 py-1 text-sm font-bold uppercase tracking-wider z-20">
                                {plan.badge}
                            </div>
                        )}

                        {/* Top Accent Bar */}
                        <div
                            class:list={[
                                "h-2 w-full",
                                {
                                    "bg-gradient-to-r from-accent via-primary to-accent":
                                        plan.highlighted,
                                    "bg-gray-300": !plan.highlighted,
                                },
                            ]}
                        />

                        {/* Image */}
                        <div class="relative h-48 overflow-hidden">
                            <img
                                src={plan.image}
                                alt={`${plan.name} - professional electrical maintenance services`}
                                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                            />
                            <div class="absolute inset-0 bg-gradient-to-t from-gray-900/80 to-transparent" />

                            {/* Plan Name Overlay */}
                            <div class="absolute bottom-4 left-4 right-4">
                                <Heading
                                    level={3}
                                    class="text-white text-2xl font-black mb-1"
                                >
                                    {plan.name}
                                </Heading>
                            </div>
                        </div>

                        {/* Content */}
                        <div class="p-6">
                            {/* Price */}
                            <div class="mb-6 text-center">
                                <div class="flex items-baseline justify-center gap-2">
                                    <span
                                        class:list={[
                                            "font-black leading-none",
                                            {
                                                "text-5xl text-accent":
                                                    plan.highlighted,
                                                "text-4xl text-text":
                                                    !plan.highlighted,
                                            },
                                        ]}
                                    >
                                        {plan.price}
                                    </span>
                                </div>
                                <Text
                                    size="sm"
                                    class="text-gray-500 uppercase tracking-wide font-semibold mt-2"
                                >
                                    {plan.period}
                                </Text>
                            </div>

                            {/* Description */}
                            <Text
                                size="base"
                                class="text-gray-600 mb-6 text-center leading-relaxed"
                            >
                                {plan.description}
                            </Text>

                            {/* Features */}
                            <ul class="space-y-3 mb-8">
                                {plan.features.map((feature) => (
                                    <li class="flex items-start gap-3">
                                        <svg
                                            class:list={[
                                                "w-5 h-5 shrink-0 mt-0.5",
                                                {
                                                    "text-accent":
                                                        plan.highlighted,
                                                    "text-primary":
                                                        !plan.highlighted,
                                                },
                                            ]}
                                            fill="currentColor"
                                            viewBox="0 0 20 20"
                                        >
                                            <path
                                                fill-rule="evenodd"
                                                d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                                clip-rule="evenodd"
                                            />
                                        </svg>
                                        <Text
                                            size="sm"
                                            class="text-gray-700 font-medium"
                                        >
                                            {feature}
                                        </Text>
                                    </li>
                                ))}
                            </ul>

                            {/* CTA Button */}
                            <Button
                                href={plan.ctaLink}
                                variant={
                                    plan.highlighted ? "accent" : "primary"
                                }
                                size="lg"
                                class="w-full justify-center font-bold uppercase tracking-wider"
                            >
                                {plan.cta}
                                <svg
                                    class="w-5 h-5 ml-2"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M13 7l5 5m0 0l-5 5m5-5H6"
                                    />
                                </svg>
                            </Button>
                        </div>

                        {/* Bottom Accent for Highlighted */}
                        {plan.highlighted && (
                            <div class="h-1 w-full bg-gradient-to-r from-accent via-primary to-accent" />
                        )}
                    </div>
                ))
            }
        </div>
    </Container>
</section>
