---
import Container from "../ui/Container.astro";

const features = [
    {
        icon: "shield",
        label: "Features",
        title: "Safety Installation & Best Service",
        description:
            "Licensed and insured professionals ensuring code-compliant installations",
    },
    {
        icon: "tools",
        label: "Features",
        title: "Expert Mechanics & Best Efforts",
        description:
            "Certified electricians with years of experience in residential and commercial work",
    },
    {
        icon: "support",
        label: "Features",
        title: "Budget Friendly & 24/7 Support",
        description:
            "Competitive pricing with emergency services available around the clock",
    },
];
---

<section class="bg-background py-0 relative -mt-12 z-10">
    <Container size="lg">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 px-12">
            {
                features.map((feature) => (
                    <div class="bg-gray-50 flex items-stretch overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
                        {/* Orange accent bar */}
                        <div class="bg-primary w-24 flex-shrink-0 flex items-center justify-center">
                            {feature.icon === "shield" && (
                                <svg
                                    class="w-12 h-12 text-gray-50"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    viewBox="0 0 24 24"
                                >
                                    <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                                </svg>
                            )}
                            {feature.icon === "tools" && (
                                <svg
                                    class="w-12 h-12 text-gray-50"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    viewBox="0 0 24 24"
                                >
                                    <path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                                    <path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                            )}
                            {feature.icon === "support" && (
                                <svg
                                    class="w-12 h-12 text-gray-50"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    viewBox="0 0 24 24"
                                >
                                    <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            )}
                        </div>

                        {/* Content */}
                        <div class="flex-1 p-6 bg-gray-900">
                            <div class="text-xs text-gray-300 uppercase tracking-wider mb-2">
                                {feature.label}
                            </div>
                            <h3 class="text-xl font-bold text-gray-50 mb-3 leading-tight">
                                {feature.title}
                            </h3>
                            <p class="text-sm text-gray-300 leading-relaxed">
                                {feature.description}
                            </p>
                        </div>
                    </div>
                ))
            }
        </div>
    </Container>
</section>
