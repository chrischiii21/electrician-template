---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Badge from "../ui/Badge.astro";
import Card from "../ui/Card.astro";
import Button from "../ui/Button.astro";

interface CustomService {
    title: string;
    description: string;
    link: string;
    icon: string;
}

interface Props {
    currentCategory?: "Commercial" | "Residential" | "Specialty" | "Emergency";
    title?: string;
    services?: CustomService[];
}

const { currentCategory, title: customTitle, services: customServices } = Astro.props;

// Icon SVG paths
const icons = {
    commercial: '<path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />',
    residential: '<path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />',
    specialty: '<path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />',
    emergency: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />'
};

// All service categories
const allServices = [
    {
        category: "Commercial",
        title: "Commercial Services",
        description: "Professional electrical solutions for businesses, offices, and industrial facilities.",
        icon: icons.commercial,
        href: "/commercial",
        color: "primary" as const,
        bgColor: "bg-primary",
        services: ["Ground-up Construction", "HVAC Electrical", "Panel Upgrades", "Power Systems"]
    },
    {
        category: "Residential",
        title: "Residential Services",
        description: "Expert electrical work for homes, apartments, and residential properties.",
        icon: icons.residential,
        href: "/residential",
        color: "accent" as const,
        bgColor: "bg-accent",
        services: ["EV Charging", "Ceiling Fans", "GFCI Outlets", "Generators"]
    },
    {
        category: "Specialty",
        title: "Specialty Services",
        description: "Specialized electrical installations for unique projects and requirements.",
        icon: icons.specialty,
        href: "/specialty",
        color: "primary" as const,
        bgColor: "bg-primary",
        services: ["Holiday Lighting", "Landscape Lighting", "Pool & Spa", "Property Management"]
    },
    {
        category: "Emergency",
        title: "Emergency Services",
        description: "24/7 emergency electrical repairs and urgent service calls.",
        icon: icons.emergency,
        href: "/emergency",
        color: "accent" as const,
        bgColor: "bg-accent",
        services: ["24-Hour Response", "HVAC Emergency", "Heating Repairs", "Water Heater"]
    }
];

// Filter out the current category or use custom services
const relatedServices = customServices 
    ? customServices.map(service => ({
        title: service.title,
        description: service.description,
        href: service.link,
        icon: service.icon,
        category: "",
        color: "primary" as const,
        bgColor: "bg-primary"
    }))
    : allServices.filter(service => service.category !== currentCategory);

const sectionTitle = customTitle || "Other <span class='text-accent'>Services</span> We Offer";
const sectionDescription = customServices 
    ? "Explore our other commercial electrical services"
    : "From residential to emergency services, we've got all your electrical needs covered";
---

<section class="bg-gray-50 py-20">
    <Container size="lg">
        <!-- Section Header -->
        <div class="text-center mb-12 scroll-animate">
            <Badge variant="accent" class="mb-4 uppercase tracking-wider">
                Explore More
            </Badge>
            <Heading level={2} class="text-text! text-4xl md:text-5xl mb-4 font-black">
                <Fragment set:html={sectionTitle} />
            </Heading>
            <Text size="xl" class="text-gray-600! max-w-3xl mx-auto">
                {sectionDescription}
            </Text>
        </div>

        <!-- Services Grid -->
        <div class="grid md:grid-cols-3 gap-8 scroll-animate">
            {relatedServices.map((service) => (
                <a href={service.href} class="block group">
                    <Card padding="lg" class="h-full border-2 border-gray-200 hover:border-primary transition-all duration-300 rounded-none bg-white relative">
                        <!-- Left accent bar that appears on hover -->
                        <div class="absolute left-0 top-0 bottom-0 w-1 bg-primary transform scale-y-0 group-hover:scale-y-100 transition-transform duration-300 origin-top"></div>
                        
                        <div class="text-center">
                            <!-- Icon Container -->
                            <div class={`w-20 h-20 ${service.bgColor} mx-auto mb-6 flex items-center justify-center transition-all duration-300 group-hover:shadow-lg`}>
                                <svg class="w-10 h-10 text-white transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                    <Fragment set:html={service.icon} />
                                </svg>
                            </div>
                            
                            {service.category && (
                                <Badge variant={service.color} class="mb-4 text-xs font-black uppercase tracking-wider mx-auto">
                                    {service.category}
                                </Badge>
                            )}
                            
                            <Heading level={3} class="text-text! text-2xl font-black mb-4 transition-colors duration-300 group-hover:text-primary">
                                <Fragment set:html={service.title} />
                            </Heading>

                            <Text size="base" class="text-gray-600! mb-6">
                                {service.description}
                            </Text>

                            <!-- Arrow indicator -->
                            <div class="flex items-center justify-center gap-2 mt-6 pt-6 border-t-2 border-gray-200 transition-colors duration-300 group-hover:border-primary">
                                <span class="text-sm font-bold text-gray-600 transition-colors duration-300 group-hover:text-primary uppercase tracking-wide">
                                    Learn More
                                </span>
                                <svg class="w-5 h-5 text-gray-600 transition-all duration-300 group-hover:text-primary group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                                </svg>
                            </div>
                        </div>
                    </Card>
                </a>
            ))}
        </div>

        <!-- Bottom CTA -->
        {!customServices && (
            <div class="text-center mt-16 scroll-animate">
                <div class="max-w-2xl mx-auto border-t-4 border-primary pt-8">
                    <Text size="lg" class="text-gray-700! mb-6 font-semibold">
                        Can't find what you're looking for?
                    </Text>
                    <Button
                        href="/services"
                        variant="primary"
                        size="lg"
                        class="rounded-none"
                    >
                        View All Services
                    </Button>
                </div>
            </div>
        )}

