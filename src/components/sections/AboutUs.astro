---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Badge from "../ui/Badge.astro";
import Button from "../ui/Button.astro";

interface Stat {
    number: string;
    label: string;
    icon: string;
}

const stats: Stat[] = [
    {
        number: "32",
        label: "Awards Won",
        icon: "trophy",
    },
    {
        number: "250+",
        label: "Skilled Engineers",
        icon: "team",
    },
    {
        number: "99%",
        label: "Satisfied Clients",
        icon: "satisfaction",
    },
    {
        number: "500+",
        label: "Handled Projects",
        icon: "projects",
    },
];

const visionSlides = [
    {
        title: "Our Vision",
        description:
            "In the context of ever-changing modernization and increasing demands, we stay ahead of industry trends to create iconic projects and build lasting trust with every client.",
    },
    {
        title: "Our Mission",
        description:
            "To deliver exceptional electrical services that exceed expectations, combining technical expertise with unwavering commitment to safety and customer satisfaction.",
    },
    {
        title: "Our Values",
        description:
            "Quality, innovation, and precision guide everything we do. We believe in building long-term relationships through reliable service and transparent communication.",
    },
];
---

<section class="bg-neutral-50 py-20 overflow-hidden" id="about-us">
    <Container size="lg">
        <div class="grid lg:grid-cols-2 gap-12 items-center mb-20">
            <!-- Left: Image with overlay effect -->
            <div class="relative scroll-fade-left">
                <div class="relative">
                    <!-- Main image container with artistic overlay -->
                    <div class="relative z-10">
                        <img
                            src="/images/hero-1.avif"
                            alt="Professional Electrician"
                            class="w-full h-[500px] object-cover"
                        />
                        <!-- Artistic brush stroke overlay -->
                        <div
                            class="absolute inset-0 bg-gradient-to-br from-primary/80 via-transparent to-transparent mix-blend-multiply"
                        >
                        </div>
                        <!-- Double exposure cityscape effect -->
                        <div
                            class="absolute bottom-0 left-0 right-0 h-48 bg-gradient-to-t from-primary to-transparent opacity-90"
                        >
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Content -->
            <div class="scroll-fade-right">
                <Badge variant="accent" class="mb-4 uppercase tracking-wider">
                    Heritage — Established 1990
                </Badge>
                <Heading level={2} class="!text-text text-4xl md:text-5xl mb-6">
                    Shaping The Future.<br />
                    <span class="text-accent">Turn Ideas Into Reality.</span>
                </Heading>
                <Text size="lg" class="!text-gray-600 mb-8 leading-relaxed">
                    Heritage stands apart through our unwavering commitment to
                    quality, innovation, and precision. Our clients benefit from
                    a trusted partner with deep industry expertise, proven
                    project management capabilities, and strong financial
                    stability. With a focus on excellence and long-term value,
                    we deliver construction solutions that meet the highest
                    standards across every project.
                </Text>
                <Button
                    href="/about"
                    variant="accent"
                    size="lg"
                    class="gap-2 uppercase tracking-wider"
                >
                    More About Us
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                </Button>
            </div>
        </div>

        <!-- Vision/Mission Carousel -->
        <div class="mb-20 scroll-animate">
            <div class="bg-primary text-white p-12 relative overflow-hidden">
                <!-- Background pattern -->
                <div
                    class="absolute inset-0 opacity-5"
                    style="background-image: linear-gradient(#D52212 1px, transparent 1px), linear-gradient(90deg, #D52212 1px, transparent 1px); background-size: 40px 40px;"
                >
                </div>

                <div class="relative z-10">
                    <div id="vision-carousel" class="min-h-[200px]">
                        {
                            visionSlides.map((slide, index) => (
                                <div
                                    class:list={[
                                        "vision-slide",
                                        { hidden: index !== 0 },
                                    ]}
                                    data-index={index}
                                >
                                    <div class="flex items-start justify-between mb-6">
                                        <div class="flex items-center gap-4">
                                            <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center">
                                                <svg
                                                    class="w-8 h-8 text-accent"
                                                    fill="currentColor"
                                                    viewBox="0 0 20 20"
                                                >
                                                    <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
                                                    <path
                                                        fill-rule="evenodd"
                                                        d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z"
                                                        clip-rule="evenodd"
                                                    />
                                                </svg>
                                            </div>
                                            <Heading
                                                level={3}
                                                class="!text-white text-3xl"
                                            >
                                                {slide.title}
                                            </Heading>
                                        </div>
                                        <div class="flex gap-2">
                                            <button
                                                class="carousel-prev p-2 hover:bg-white/10 transition-colors"
                                                aria-label="Previous"
                                            >
                                                <svg
                                                    class="w-5 h-5"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    viewBox="0 0 24 24"
                                                >
                                                    <path
                                                        stroke-linecap="round"
                                                        stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M15 19l-7-7 7-7"
                                                    />
                                                </svg>
                                            </button>
                                            <button
                                                class="carousel-next p-2 hover:bg-white/10 transition-colors"
                                                aria-label="Next"
                                            >
                                                <svg
                                                    class="w-5 h-5"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    viewBox="0 0 24 24"
                                                >
                                                    <path
                                                        stroke-linecap="round"
                                                        stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M9 5l7 7-7 7"
                                                    />
                                                </svg>
                                            </button>
                                        </div>
                                    </div>
                                    <Text
                                        size="xl"
                                        class="!text-white/90 leading-relaxed max-w-3xl"
                                    >
                                        {slide.description}
                                    </Text>
                                </div>
                            ))
                        }
                    </div>

                    <!-- Carousel indicators -->
                    <div class="flex gap-2 mt-8">
                        {
                            visionSlides.map((_, index) => (
                                <button
                                    class:list={[
                                        "carousel-indicator w-12 h-1 transition-all duration-300",
                                        {
                                            "bg-accent": index === 0,
                                            "bg-white/30 hover:bg-white/50":
                                                index !== 0,
                                        },
                                    ]}
                                    data-index={index}
                                    aria-label={`Go to slide ${index + 1}`}
                                />
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Stats Grid -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 scroll-stagger">
            {
                stats.map((stat) => (
                    <div class="bg-white border border-gray-200 p-8 text-center hover:shadow-lg transition-shadow duration-300 group">
                        <div class="flex justify-center mb-4">
                            {stat.icon === "trophy" && (
                                <svg
                                    class="w-12 h-12 text-gray-400 group-hover:text-accent transition-colors"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"
                                    />
                                </svg>
                            )}
                            {stat.icon === "team" && (
                                <svg
                                    class="w-12 h-12 text-gray-400 group-hover:text-accent transition-colors"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                                    />
                                </svg>
                            )}
                            {stat.icon === "satisfaction" && (
                                <svg
                                    class="w-12 h-12 text-gray-400 group-hover:text-accent transition-colors"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                                    />
                                </svg>
                            )}
                            {stat.icon === "projects" && (
                                <svg
                                    class="w-12 h-12 text-gray-400 group-hover:text-accent transition-colors"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                                    />
                                </svg>
                            )}
                        </div>
                        <Heading
                            level={3}
                            class="!text-text text-4xl md:text-5xl mb-2 font-bold"
                        >
                            {stat.number}
                        </Heading>
                        <Text size="md" class="!text-gray-500">
                            {stat.label}
                        </Text>
                    </div>
                ))
            }
        </div>
    </Container>
</section>

<script>
    // Vision carousel functionality
    let currentSlide = 0;
    const slides = document.querySelectorAll<HTMLElement>(".vision-slide");
    const indicators = document.querySelectorAll<HTMLElement>(
        ".carousel-indicator",
    );
    const prevBtn = document.querySelector<HTMLElement>(".carousel-prev");
    const nextBtn = document.querySelector<HTMLElement>(".carousel-next");

    function showSlide(index: number) {
        slides.forEach((slide, i) => {
            slide.classList.toggle("hidden", i !== index);
        });

        indicators.forEach((indicator, i) => {
            if (i === index) {
                indicator.classList.remove("bg-white/30", "hover:bg-white/50");
                indicator.classList.add("bg-accent");
            } else {
                indicator.classList.remove("bg-accent");
                indicator.classList.add("bg-white/30", "hover:bg-white/50");
            }
        });

        currentSlide = index;
    }

    function nextSlide() {
        const next = (currentSlide + 1) % slides.length;
        showSlide(next);
    }

    function prevSlide() {
        const prev = (currentSlide - 1 + slides.length) % slides.length;
        showSlide(prev);
    }

    nextBtn?.addEventListener("click", nextSlide);
    prevBtn?.addEventListener("click", prevSlide);

    indicators.forEach((indicator) => {
        indicator.addEventListener("click", () => {
            const index = parseInt(indicator.dataset.index || "0");
            showSlide(index);
        });
    });

    // Auto-advance carousel every 5 seconds
    setInterval(nextSlide, 5000);
</script>
