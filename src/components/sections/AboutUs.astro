---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Badge from "../ui/Badge.astro";
import Button from "../ui/Button.astro";

interface Stat {
    number: string;
    label: string;
    icon: string;
}

const stats: Stat[] = [
    {
        number: "32",
        label: "Awards Won",
        icon: "trophy",
    },
    {
        number: "250+",
        label: "Skilled Engineers",
        icon: "team",
    },
    {
        number: "99%",
        label: "Satisfied Clients",
        icon: "satisfaction",
    },
    {
        number: "500+",
        label: "Handled Projects",
        icon: "projects",
    },
];
---

<section class="bg-background py-20 overflow-hidden" id="about-us">
    <Container size="lg">
        <!-- Top Section: Content + Image -->
        <div class="grid lg:grid-cols-2 gap-16 items-center mb-20">
            <!-- Left: Content -->
            <div class="scroll-fade-left">
                <Badge variant="accent" class="mb-4 uppercase tracking-wider">
                    Trusted Since 1990
                </Badge>
                <Heading level={2} class="!text-text text-4xl md:text-5xl mb-4">
                    Powering Communities.<br />
                    <span class="text-accent">One Connection at a Time.</span>
                </Heading>
                <Text size="xl" class="!text-gray-600 mb-6 leading-relaxed">
                    We're more than electricians — we're your partners in power.
                    With over three decades of experience, our licensed
                    professionals deliver safe, reliable electrical solutions
                    for homes, businesses, and specialty projects throughout the
                    region.
                </Text>
                <Button
                    href="/about"
                    variant="accent"
                    size="lg"
                    class="gap-2 uppercase tracking-wider"
                >
                    More About Us
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                </Button>
            </div>

            <!-- Right: Image -->
            <div class="relative scroll-fade-right">
                <div class="relative">
                    <img
                        src="/images/hero-1.avif"
                        alt="Licensed professional electrician working on residential electrical panel upgrade"
                        class="w-full h-[500px] object-cover shadow-2xl"
                    />
                    <!-- Accent overlay corner -->
                    <div
                        class="absolute top-0 right-0 w-32 h-32 bg-accent opacity-90"
                    >
                    </div>
                    <div
                        class="absolute bottom-0 left-0 w-32 h-32 bg-primary opacity-90"
                    >
                    </div>
                </div>
            </div>
        </div>

        <!-- Bottom Section: Vision Cards -->
        <div class="grid md:grid-cols-3 gap-6 scroll-stagger">
            <!-- Vision Card -->
            <div
                class="bg-primary text-white p-8 relative overflow-hidden group hover:shadow-xl transition-all duration-300"
            >
                <div
                    class="absolute top-0 right-0 w-24 h-24 bg-accent opacity-20 transform translate-x-8 -translate-y-8 group-hover:scale-150 transition-transform duration-500"
                >
                </div>
                <div class="relative z-10">
                    <div
                        class="w-12 h-12 bg-accent rounded-full flex items-center justify-center mb-4"
                    >
                        <svg
                            class="w-6 h-6 text-white"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                        >
                            <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"></path>
                            <path
                                fill-rule="evenodd"
                                d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z"
                                clip-rule="evenodd"></path>
                        </svg>
                    </div>
                    <Heading level={4} class="!text-white text-2xl mb-3">
                        Our Vision
                    </Heading>
                    <Text size="base" class="!text-white/90 leading-relaxed">
                        To be the most trusted electrical service provider,
                        setting the standard for safety, innovation, and
                        customer care.
                    </Text>
                </div>
            </div>

            <!-- Mission Card -->
            <div
                class="bg-accent text-white p-8 relative overflow-hidden group hover:shadow-xl transition-all duration-300"
            >
                <div
                    class="absolute top-0 right-0 w-24 h-24 bg-primary opacity-20 transform translate-x-8 -translate-y-8 group-hover:scale-150 transition-transform duration-500"
                >
                </div>
                <div class="relative z-10">
                    <div
                        class="w-12 h-12 bg-white rounded-full flex items-center justify-center mb-4"
                    >
                        <svg
                            class="w-6 h-6 text-accent"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                clip-rule="evenodd"></path>
                        </svg>
                    </div>
                    <Heading level={4} class="!text-white text-2xl mb-3">
                        Our Mission
                    </Heading>
                    <Text size="base" class="!text-white/90 leading-relaxed">
                        Deliver exceptional electrical services with expert
                        craftsmanship, unwavering safety standards, and 24/7
                        emergency support.
                    </Text>
                </div>
            </div>

            <!-- Values Card -->
            <div
                class="bg-gray-900 text-white p-8 relative overflow-hidden group hover:shadow-xl transition-all duration-300"
            >
                <div
                    class="absolute top-0 right-0 w-24 h-24 bg-accent opacity-20 transform translate-x-8 -translate-y-8 group-hover:scale-150 transition-transform duration-500"
                >
                </div>
                <div class="relative z-10">
                    <div
                        class="w-12 h-12 bg-accent rounded-full flex items-center justify-center mb-4"
                    >
                        <svg
                            class="w-6 h-6 text-white"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                        >
                            <path
                                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                            ></path>
                        </svg>
                    </div>
                    <Heading level={4} class="!text-white text-2xl mb-3">
                        Our Values
                    </Heading>
                    <Text size="base" class="!text-white/90 leading-relaxed">
                        Safety first, quality always. We build lasting
                        relationships through honest work, transparent pricing,
                        and reliable service.
                    </Text>
                </div>
            </div>
        </div>
    </Container>
</section>
