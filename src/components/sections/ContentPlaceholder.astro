---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Badge from "../ui/Badge.astro";

interface Props {
    title?: string;
    message?: string;
}

const {
    title = "Content Coming Soon",
    message = "This section's content will be determined based on client requirements and discussions.",
} = Astro.props;
---

<section class="bg-white py-20">
    <Container size="lg">
        <div class="max-w-3xl mx-auto text-center scroll-animate">
            <div class="mb-8 flex justify-center">
                <div class="relative">
                    <div
                        class="w-20 h-20 border-2 border-accent/20 bg-accent/5 flex items-center justify-center"
                    >
                        <svg
                            class="w-10 h-10 text-accent"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="1.5"
                                d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
                            ></path>
                        </svg>
                    </div>
                    <div
                        class="absolute -top-2 -right-2 w-8 h-8 bg-brand-yellow flex items-center justify-center"
                    >
                        <svg
                            class="w-5 h-5 text-primary"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z"
                                clip-rule="evenodd"></path>
                        </svg>
                    </div>
                </div>
            </div>

            <Badge variant="accent" class="mb-4">In Development</Badge>

            <Heading level={2} class="text-4xl md:text-5xl mb-6 font-black">
                {title}
            </Heading>

            <Text size="xl" class="text-gray-700! mb-8 leading-relaxed">
                {message}
            </Text>

            <div
                class="inline-flex items-center gap-3 px-6 py-4 bg-gray-50 border-2 border-gray-200"
            >
                <svg
                    class="w-6 h-6 text-accent shrink-0"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1.5"
                        d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                    ></path>
                </svg>
                <Text
                    size="base"
                    class="text-gray-700! font-bold uppercase tracking-wide"
                >
                    Pending Client Consultation
                </Text>
            </div>
        </div>
    </Container>
</section>
