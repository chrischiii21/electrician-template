---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";
import { getCollection } from "astro:content";

// Get service categories from content collection
const servicesEntries = await getCollection("services");
const serviceCategories = servicesEntries
    .sort((a, b) => a.data.order - b.data.order)
    .map((entry) => ({
        label: entry.data.category,
        href: entry.data.href,
        services: entry.data.services,
    }));

// Flatten all services into one array for the Services dropdown
const allServices = serviceCategories.flatMap((category) =>
    category.services.map((service) => ({
        label: service.label,
        href: service.href,
        category: category.label,
    })),
);

// Get service areas from content collection
const serviceAreasEntries = await getCollection("serviceAreas");
const serviceAreasSubmenu = serviceAreasEntries
    .sort((a, b) => a.data.order - b.data.order)
    .map((entry) => ({
        label: entry.data.name,
        href: entry.data.href,
    }));

const secondaryNavLinks = [
    { label: "Specials / Coupons", href: "/specials" },
    { label: "Financing", href: "/financing" },
];

// About Us submenu
const aboutUsSubmenu = [
    { label: "Careers", href: "/careers" },
    { label: "Reviews / Testimonials", href: "/reviews" },
    { label: "Meet The Team", href: "/team" },
];
---

