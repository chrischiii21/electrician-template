                        <!-- Call Us -->
                        <a
                            href="tel:+15550000000"
                            class="flex items-center gap-2 group"
                        >
                            <div class="text-gray-700">
                                <svg
                                    class="w-4 h-4"
                                    fill="none"
                                    stroke="currentColor"
