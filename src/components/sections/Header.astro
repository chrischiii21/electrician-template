            <!-- 3rd Level Navigation: Home, About Us, Services, Service Area, and CTA -->
            <div
                class="flex px-12 gap-0 header-nav-row transition-all duration-500 ease-in-out"
            >
                <nav class="flex flex-1">
                    <!-- Home Link -->
                    <div class="flex-1 bg-primary nav-item">
                        <a
                            href="/"
                            class="flex items-center justify-center text-center px-6 py-4 min-h-16 text-sm font-bold text-gray-50 uppercase tracking-wide hover:bg-white/10 transition-all duration-300"
                        >
                            Home
                        </a>
                    </div>

                    <!-- About Us Dropdown -->
                    <div
                        class="flex-1 bg-primary border-l border-gray-50/30 group relative nav-item"
                    >
                        <a
                            href="/about"
                            class="flex items-center justify-center text-center px-6 py-4 min-h-16 text-sm font-bold text-gray-50 uppercase tracking-wide hover:bg-white/10 transition-all duration-300"
                        >
                            About Us
                            <svg
                                class="w-4 h-4 ml-2"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                viewBox="0 0 24 24"
                            >
                                <path d="M19 9l-7 7-7-7"></path>
