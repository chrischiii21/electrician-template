                </nav>

                <!-- Book Now CTA Button -->
                <Button
                    href="/book"
                    variant="accent"
                    size="lg"
                    class="whitespace-nowrap uppercase tracking-wider"
                >
                    BOOK NOW
                </Button>
            </div>
        </Container>
