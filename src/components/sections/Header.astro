---
import Button from "../ui/Button.astro";
import Container from "../ui/Container.astro";
---

<header class="fixed top-0 left-0 right-0 w-full bg-background shadow-md z-50">
    <!-- Mobile Promotional Top Bar -->
    <div
        class="lg:hidden w-full h-10 bg-primary text-background overflow-hidden relative"
    >
        <div class="animate-scroll whitespace-nowrap flex items-center h-full">
            <div class="flex items-center gap-3 text-xs px-4">
                <svg
                    class="w-4 h-4 text-accent shrink-0"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                >
                    <path
                        fill-rule="evenodd"
                        d="M5 2a1 1 0 011 1v1h1a1 1 0 010 2H6v1a1 1 0 01-2 0V6H3a1 1 0 010-2h1V3a1 1 0 011-1zm0 10a1 1 0 011 1v1h1a1 1 0 110 2H6v1a1 1 0 11-2 0v-1H3a1 1 0 110-2h1v-1a1 1 0 011-1zM12 2a1 1 0 01.967.744L14.146 7.2 17.5 9.134a1 1 0 010 1.732l-3.354 1.935-1.18 4.455a1 1 0 01-1.933 0L9.854 12.8 6.5 10.866a1 1 0 010-1.732l3.354-1.935 1.18-4.455A1 1 0 0112 2z"
                        clip-rule="evenodd"></path>
                </svg>
                <span class="font-bold">SPRING SPECIAL:</span>
                <span class="text-background/80"
                    >20% OFF any electrical panel upgrade — Use code:</span
                >
                <span
                    class="bg-accent text-background px-2 py-0.5 text-xs font-bold"
                    >SPRING20</span
                >
                <span class="mx-8">•</span>
                <svg
                    class="w-4 h-4 text-accent shrink-0"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                >
                    <path
                        fill-rule="evenodd"
                        d="M5 2a1 1 0 011 1v1h1a1 1 0 010 2H6v1a1 1 0 01-2 0V6H3a1 1 0 010-2h1V3a1 1 0 011-1zm0 10a1 1 0 011 1v1h1a1 1 0 110 2H6v1a1 1 0 11-2 0v-1H3a1 1 0 110-2h1v-1a1 1 0 011-1zM12 2a1 1 0 01.967.744L14.146 7.2 17.5 9.134a1 1 0 010 1.732l-3.354 1.935-1.18 4.455a1 1 0 01-1.933 0L9.854 12.8 6.5 10.866a1 1 0 010-1.732l3.354-1.935 1.18-4.455A1 1 0 0112 2z"
                        clip-rule="evenodd"></path>
                </svg>
                <span class="font-bold">SPRING SPECIAL:</span>
                <span class="text-background/80"
                    >20% OFF any electrical panel upgrade — Use code:</span
                >
                <span
                    class="bg-accent text-background px-2 py-0.5 text-xs font-bold"
                    >SPRING20</span
                >
            </div>
        </div>
    </div>

    <!-- Mobile Header -->
    <div
        class="lg:hidden flex items-center justify-between px-4 py-3 border-b border-text/10 bg-background"
    >
        <a
            href="/"
            class="flex items-center gap-3 hover:opacity-80 transition-opacity"
        >
            <img
                src="/logo.png"
                alt="ElectriTrade Logo"
                class="w-12 h-12 object-contain"
            />
            <div>
                <h1
                    class="text-xl font-heading font-bold text-accent leading-tight"
                >
                    ElecTrade
                </h1>
                <p class="text-xs font-body text-text/70">
                    Professional Electrical
                </p>
            </div>
        </a>
        <button
            id="hamburger-menu-btn"
            class="text-text hover:text-accent transition-colors p-2"
        >
            <svg
                class="w-7 h-7"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
        </button>
    </div>

    <!-- Promo Top Bar -->
    <div
        id="promo-bar"
        class="bg-gray-900 border-b border-gray-700 transition-all duration-300 overflow-hidden promo-bar-visible"
    >
        <Container size="lg">
            <div class="flex items-center justify-between py-2.5 px-4 gap-4">
                <div class="flex items-center gap-3 flex-1 min-w-0">
                    <svg
                        class="w-4 h-4 text-accent shrink-0"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z"
                            clip-rule="evenodd"></path>
                    </svg>
                    <p
                        class="text-sm text-gray-300 whitespace-nowrap overflow-hidden text-ellipsis"
                    >
                        <span
                            class="text-accent font-bold uppercase tracking-wider"
                            >Spring Special:</span
                        >
                        <span class="ml-1"
                            >$75 OFF any electrical panel upgrade — Use code</span
                        >
                        <span
                            class="inline-flex items-center mx-2 px-2 py-0.5 bg-accent text-white text-xs font-bold tracking-widest cursor-pointer promo-code-copy"
                            data-code="SPRING75"
                            title="Click to copy">SPRING75</span
                        >
                        <span
                            class="promo-copied text-xs text-accent opacity-0 transition-opacity duration-200"
                            >✓ Copied!</span
                        >
                    </p>
                </div>
                <div class="flex items-center gap-4 shrink-0">
                    <div
                        class="flex items-center gap-1.5 text-gray-400 text-xs uppercase tracking-wider"
                    >
                        <span>Ends In:</span>
                        <span
                            class="promo-unit bg-accent text-white font-heading font-bold text-xs w-7 h-6 flex items-center justify-center"
                            data-unit="hours">00</span
                        >
                        <span class="text-gray-500 font-bold">:</span>
                        <span
                            class="promo-unit bg-accent text-white font-heading font-bold text-xs w-7 h-6 flex items-center justify-center"
                            data-unit="mins">00</span
                        >
                        <span class="text-gray-500 font-bold">:</span>
                        <span
                            class="promo-unit bg-accent text-white font-heading font-bold text-xs w-7 h-6 flex items-center justify-center"
                            data-unit="secs">00</span
                        >
                    </div>
                    <button
                        id="promo-close"
                        class="text-gray-500 hover:text-white transition-colors ml-2"
                        aria-label="Dismiss"
                    >
                        <svg
                            class="w-4 h-4"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>
            </div>
        </Container>
    </div>

    <!-- Main Header Container -->
    <div class="w-full border-b border-text/10 hidden lg:block">
        <div class="w-full flex items-stretch">
            <!-- Logo Section -->
            <a
                href="/"
                class="logo-section w-96 border-r border-text/10 flex items-center px-10 py-7 bg-background transition-all duration-300 hover:bg-accent/5"
            >
                <div class="flex items-center gap-5 w-full">
                    <img
                        src="/logo.png"
                        alt="ElectriTrade Logo"
                        class="logo-img w-20 h-20 object-contain shrink-0 transition-all duration-300"
                    />
                    <div class="flex flex-col gap-1">
                        <h1
                            class="logo-text text-3xl font-heading font-bold text-accent leading-tight transition-all duration-300"
                        >
                            ElecTrade
                        </h1>
                        <p
                            class="logo-subtext text-base font-body text-text/70 transition-all duration-300"
                        >
                            Professional Electrical
                        </p>
                    </div>
                </div>
            </a>

            <!-- Right Side Content -->
            <div class="flex-1 flex flex-col min-w-0">
                <!-- Top Row: Specials & Financing -->
                <div
                    class="flex items-center justify-between px-16 py-5 border-b border-text/10 bg-background"
                >
                    <div class="flex items-center gap-8">
                        <a
                            href="/specials"
                            class="flex items-center gap-3 px-6 py-3 bg-accent/10 border-l-4 border-accent hover:bg-accent/20 hover:shadow-lg transform hover:scale-105 transition-all duration-300 group"
                        >
                            <svg
                                class="w-6 h-6 text-accent group-hover:animate-pulse"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z"
                                    clip-rule="evenodd"></path>
                            </svg>
                            <div>
                                <span
                                    class="block text-lg font-bold text-accent uppercase tracking-wider group-hover:text-accent/80"
                                    >Specials / Coupons</span
                                >
                                <span
                                    class="block text-xs text-gray-600 font-medium"
                                    >Save big on electrical services</span
                                >
                            </div>
                        </a>
                        <a
                            href="/financing"
                            class="flex items-center gap-3 px-6 py-3 bg-primary/10 border-l-4 border-primary hover:bg-primary/20 hover:shadow-lg transform hover:scale-105 transition-all duration-300 group"
                        >
                            <svg
                                class="w-6 h-6 text-primary group-hover:animate-pulse"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    d="M4 4a2 2 0 00-2 2v1h16V6a2 2 0 00-2-2H4z"
                                ></path>
                                <path
                                    fill-rule="evenodd"
                                    d="M18 9H2v5a2 2 0 002 2h12a2 2 0 002-2V9zM4 13a1 1 0 011-1h1a1 1 0 110 2H5a1 1 0 01-1-1zm5-1a1 1 0 100 2h1a1 1 0 100-2H9z"
                                    clip-rule="evenodd"></path>
                            </svg>
                            <div>
                                <span
                                    class="block text-lg font-bold text-primary uppercase tracking-wider group-hover:text-primary/80"
                                    >Financing Available</span
                                >
                                <span
                                    class="block text-xs text-gray-600 font-medium"
                                    >Flexible payment options</span
                                >
                            </div>
                        </a>
                    </div>

                    <!-- Contact Info -->
                    <div class="flex items-center gap-10 text-text">
                        <a
                            href="tel:+1234567890"
                            class="flex items-center gap-3 hover:text-accent transition-colors"
                        >
                            <svg
                                class="w-5 h-5"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"
                                ></path>
                            </svg>
                            <span class="text-sm font-body font-bold"
                                >(123) 456-7890</span
                            >
                        </a>
                        <a
                            href="mailto:info@electritrade.com"
                            class="flex items-center gap-3 hover:text-accent transition-colors"
                        >
                            <svg
                                class="w-5 h-5"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"
                                ></path>
                                <path
                                    d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"
                                ></path>
                            </svg>
                            <span class="text-sm font-body font-bold"
                                >info@electritrade.com</span
                            >
                        </a>
                    </div>
                </div>

                <!-- Bottom Row: Main Navigation -->
                <div
                    class="nav-row flex items-stretch justify-between bg-background transition-all duration-300"
                >
                    <nav
                        class="flex items-center gap-14 px-16 py-5 transition-all duration-300"
                    >
                        <a
                            href="/"
                            class="text-base font-body text-text hover:text-accent transition-colors whitespace-nowrap"
                        >
                            Home
                        </a>
                        <div class="relative group">
                            <a
                                href="/about"
                                class="text-base font-body text-text hover:text-accent transition-colors whitespace-nowrap flex items-center gap-2"
                            >
                                About Us
                                <svg
                                    class="w-4 h-4 transition-transform group-hover:rotate-180"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M19 9l-7 7-7-7"></path>
                                </svg>
                            </a>
                            <div
                                class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50"
                            >
                                <div
                                    class="bg-background border border-accent/20 shadow-lg py-2 min-w-50"
                                >
                                    <a
                                        href="/careers"
                                        class="block px-6 py-3 text-base font-body text-text hover:text-accent hover:bg-accent/5 transition-colors whitespace-nowrap"
                                        >Careers</a
                                    >
                                    <a
                                        href="/reviews"
                                        class="block px-6 py-3 text-base font-body text-text hover:text-accent hover:bg-accent/5 transition-colors whitespace-nowrap"
                                    >
                                        Reviews/Testimonials
                                    </a>
                                    <a
                                        href="/team"
                                        class="block px-6 py-3 text-base font-body text-text hover:text-accent hover:bg-accent/5 transition-colors whitespace-nowrap"
                                    >
                                        Meet The Team
                                    </a>
                                </div>
                            </div>
                        </div>
                        <div class="relative group">
                            <a
                                href="/services"
                                class="text-base font-body text-text hover:text-accent transition-colors whitespace-nowrap flex items-center gap-2"
                            >
                                Services
                                <svg
                                    class="w-4 h-4 transition-transform group-hover:rotate-180"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M19 9l-7 7-7-7"></path>
                                </svg>
                            </a>
                            <div
                                class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50"
                            >
                                <div
                                    class="bg-background border border-accent/20 shadow-lg overflow-hidden min-w-max"
                                >
                                    <div class="grid grid-cols-2 gap-0">
                                        <!-- Commercial Section -->
                                        <div
                                            class="border-r border-gray-200 w-64"
                                        >
                                            <a
                                                href="/commercial"
                                                class="block px-4 py-3 text-md font-bold text-text hover:bg-accent/5 hover:text-accent transition-colors bg-gray-50 border-b border-gray-200"
                                            >
                                                Commercial Electrical Services
                                            </a>
                                            <div class="space-y-0">
                                                <a
                                                    href="/commercial/construction"
                                                    class="block px-4 py-2 text-sm font-body text-text hover:text-accent hover:bg-accent/5 transition-colors whitespace-nowrap"
                                                >
                                                    Ground-up Construction
                                                </a>
                                                <a
                                                    href="/commercial/power-systems"
                                                    class="block px-4 py-2 text-sm font-body text-text hover:text-accent hover:bg-accent/5 transition-colors whitespace-nowrap"
                                                >
                                                    Standby Power
                                                </a>
                                                <a
                                                    href="/commercial/hvac"
                                                    class="block px-4 py-2 text-sm font-body text-text hover:text-accent hover:bg-accent/5 transition-colors whitespace-nowrap"
                                                >
                                                    HVAC Electrical
                                                </a>
                                                <a
                                                    href="/commercial/panels"
                                                    class="block px-4 py-2 text-sm font-body text-text hover:text-accent hover:bg-accent/5 transition-colors whitespace-nowrap"
                                                >
                                                    Electrical Panels
                                                </a>
                                            </div>
                                        </div>

                                        <!-- Residential Section -->
                                        <div class="w-64">
                                            <a
                                                href="/residential"
                                                class="block px-4 py-3 text-md font-bold text-text hover:bg-accent/5 hover:text-accent transition-colors bg-gray-50 border-b border-gray-200"
                                            >
                                                Residential Electrical Services
                                            </a>
                                            <div class="space-y-0">
                                                <a
                                                    href="/residential/ev-charging"
                                                    class="block px-4 py-2 text-sm font-body text-text hover:text-accent hover:bg-accent/5 transition-colors whitespace-nowrap"
                                                >
                                                    EV Charging
                                                </a>
                                                <a
                                                    href="/residential/ceiling-fan"
                                                    class="block px-4 py-2 text-sm font-body text-text hover:text-accent hover:bg-accent/5 transition-colors whitespace-nowrap"
                                                >
                                                    Ceiling Fans
                                                </a>
                                                <a
                                                    href="/residential/gfci"
                                                    class="block px-4 py-2 text-sm font-body text-text hover:text-accent hover:bg-accent/5 transition-colors whitespace-nowrap"
                                                >
                                                    GFCI Outlets
                                                </a>
                                                <a
                                                    href="/residential/generators"
                                                    class="block px-4 py-2 text-sm font-body text-text hover:text-accent hover:bg-accent/5 transition-colors whitespace-nowrap"
                                                >
                                                    Generators
                                                </a>
                                            </div>
                                        </div>

                                        <!-- Specialty Section -->
                                        <div
                                            class="border-r border-gray-200 border-t border-gray-200 w-64"
                                        >
                                            <a
                                                href="/specialty"
                                                class="block px-4 py-3 text-md font-bold text-text hover:bg-accent/5 hover:text-accent transition-colors bg-gray-50 border-b border-gray-200"
                                            >
                                                Specialty Services
                                            </a>
                                            <div class="space-y-0">
                                                <a
                                                    href="/specialty/holiday-lighting"
                                                    class="block px-4 py-2 text-sm font-body text-text hover:text-accent hover:bg-accent/5 transition-colors whitespace-nowrap"
                                                >
                                                    Holiday Lighting
                                                </a>
                                                <a
                                                    href="/specialty/landscape"
                                                    class="block px-4 py-2 text-sm font-body text-text hover:text-accent hover:bg-accent/5 transition-colors whitespace-nowrap"
                                                >
                                                    Landscape Lighting
                                                </a>
                                                <a
                                                    href="/specialty/pool-spa"
                                                    class="block px-4 py-2 text-sm font-body text-text hover:text-accent hover:bg-accent/5 transition-colors whitespace-nowrap"
                                                >
                                                    Pool & Spa
                                                </a>
                                                <a
                                                    href="/specialty/property-management"
                                                    class="block px-4 py-2 text-sm font-body text-text hover:text-accent hover:bg-accent/5 transition-colors whitespace-nowrap"
                                                >
                                                    Property Management
                                                </a>
                                            </div>
                                        </div>

                                        <!-- Emergency Section -->
                                        <div
                                            class="border-t border-gray-200 w-64"
                                        >
                                            <a
                                                href="/emergency"
                                                class="block px-4 py-3 text-md font-bold text-text hover:bg-accent/5 hover:text-accent transition-colors bg-gray-50 border-b border-gray-200"
                                            >
                                                Emergency
                                            </a>
                                            <div class="space-y-0">
                                                <a
                                                    href="/emergency/24-hour"
                                                    class="block px-4 py-2 text-sm font-body text-text hover:text-accent hover:bg-accent/5 transition-colors whitespace-nowrap"
                                                >
                                                    24-hour Service
                                                </a>
                                                <a
                                                    href="/emergency/hvac"
                                                    class="block px-4 py-2 text-sm font-body text-text hover:text-accent hover:bg-accent/5 transition-colors whitespace-nowrap"
                                                >
                                                    HVAC Emergency
                                                </a>
                                                <a
                                                    href="/emergency/heating"
                                                    class="block px-4 py-2 text-sm font-body text-text hover:text-accent hover:bg-accent/5 transition-colors whitespace-nowrap"
                                                >
                                                    Heating Emergency
                                                </a>
                                                <a
                                                    href="/emergency/water-heater"
                                                    class="block px-4 py-2 text-sm font-body text-text hover:text-accent hover:bg-accent/5 transition-colors whitespace-nowrap"
                                                >
                                                    Water Heater
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="relative group">
                            <a
                                href="/service-area"
                                class="text-base font-body text-text hover:text-accent transition-colors whitespace-nowrap flex items-center gap-2"
                            >
                                Service Area
                                <svg
                                    class="w-4 h-4 transition-transform group-hover:rotate-180"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M19 9l-7 7-7-7"></path>
                                </svg>
                            </a>
                            <div
                                class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50"
                            >
                                <div
                                    class="bg-background border border-accent/20 shadow-lg py-2 min-w-50"
                                >
                                    <a
                                        href="/service-area/los-angeles"
                                        class="block px-6 py-3 text-base font-body text-text hover:text-accent hover:bg-accent/5 transition-colors whitespace-nowrap"
                                        >Los Angeles</a
                                    >
                                    <a
                                        href="/service-area/san-diego"
                                        class="block px-6 py-3 text-base font-body text-text hover:text-accent hover:bg-accent/5 transition-colors whitespace-nowrap"
                                    >
                                        San Diego
                                    </a>
                                    <a
                                        href="/service-area/san-francisco"
                                        class="block px-6 py-3 text-base font-body text-text hover:text-accent hover:bg-accent/5 transition-colors whitespace-nowrap"
                                    >
                                        San Francisco
                                    </a>
                                    <a
                                        href="/service-area/sacramento"
                                        class="block px-6 py-3 text-base font-body text-text hover:text-accent hover:bg-accent/5 transition-colors whitespace-nowrap"
                                    >
                                        Sacramento
                                    </a>
                                </div>
                            </div>
                        </div>
                    </nav>
                    <Button
                        href="/contact"
                        variant="primary"
                        size="lg"
                        class="px-20! rounded-none">GET A QUOTE</Button
                    >
                </div>
            </div>
        </div>
    </div>
</header>

<script>
    // Header scroll collapse functionality
    let lastScrollTop = 0;
    const header = document.querySelector("header");
    const promoBar = header?.querySelector(".lg\\:block.bg-primary");
    const specialsRow = header?.querySelector(
        ".flex.items-center.justify-between.px-16",
    );

    window.addEventListener("scroll", () => {
        const scrollTop =
            window.pageYOffset || document.documentElement.scrollTop;

        if (scrollTop > 100) {
            // Scrolled down - compact mode
            header?.classList.add("header-compact");
            promoBar?.classList.add("hidden");
            specialsRow?.classList.add("hidden");
        } else {
            // At top - full mode
            header?.classList.remove("header-compact");
            promoBar?.classList.remove("hidden");
            specialsRow?.classList.remove("hidden");
        }

        lastScrollTop = scrollTop;
    });

    // Promo bar close functionality
    const promoCloseBtn = document.getElementById("promo-close");
    const promoBarElement = document.getElementById("promo-bar");

    promoCloseBtn?.addEventListener("click", () => {
        promoBarElement?.classList.add("hidden");
    });
</script>

