---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";

const mainNavLinks = [
    {
        label: "Home",
        href: "/",
        submenu: [],
    },
    {
        label: "About Us",
        href: "/about",
        submenu: [
            { label: "Careers", href: "/careers" },
            { label: "Reviews / Testimonials", href: "/reviews" },
            { label: "Meet The Team", href: "/team" },
        ],
    },
    {
        label: "Service Area",
        href: "/service-area",
        submenu: [
            { label: "Los Angeles", href: "/service-area/los-angeles" },
            { label: "San Diego", href: "/service-area/san-diego" },
            { label: "San Francisco", href: "/service-area/san-francisco" },
            { label: "Sacramento", href: "/service-area/sacramento" },
            { label: "Fresno", href: "/service-area/fresno" },
            { label: "Oakland", href: "/service-area/oakland" },
        ],
    },
    {
        label: "Contact Us",
        href: "/contact",
        submenu: [],
    },
];

const secondaryNavLinks = [
    { label: "Specials / Coupons", href: "/specials" },
    { label: "Financing", href: "/financing" },
];

const serviceCategories = [
    {
        label: "Commercial Electrical Services",
        href: "/commercial",
        services: [
            {
                label: "Ground-up Electrical Construction",
                href: "/commercial/construction",
            },
            {
                label: "Emergency & Standby Power Generating Systems",
                href: "/commercial/power-systems",
            },
            { label: "Commercial HVAC Electrical", href: "/commercial/hvac" },
            {
                label: "Commercial Electrical Panels",
                href: "/commercial/panels",
            },
        ],
    },
    {
        label: "Residential Electrical Services",
        href: "/residential",
        services: [
            {
                label: "Car Charging Stations/ EV",
                href: "/residential/ev-charging",
            },
            { label: "Ceiling Fan", href: "/residential/ceiling-fan" },
            { label: "GFCI Outlets", href: "/residential/gfci" },
            { label: "Backup Generators", href: "/residential/generators" },
        ],
    },
    {
        label: "Specialty Services",
        href: "/specialty",
        services: [
            {
                label: "Holiday Lighting Installation Services",
                href: "/specialty/holiday-lighting",
            },
            { label: "Landscape Lighting", href: "/specialty/landscape" },
            { label: "Pool & Spa Electrical", href: "/specialty/pool-spa" },
            {
                label: "Property Management",
                href: "/specialty/property-management",
            },
        ],
    },
    {
        label: "Emergency",
        href: "/emergency",
        services: [
            { label: "24-hour Emergency Service", href: "/emergency/24-hour" },
            { label: "HVAC", href: "/emergency/hvac" },
            { label: "Heating", href: "/emergency/heating" },
            { label: "Water Heater", href: "/emergency/water-heater" },
        ],
    },
];
---

<header class="bg-gray-50 relative z-50">
    <!-- Top Bar - White Background -->
    <div class="bg-gray-50 border-b border-gray-100">
        <Container size="lg">
            <div class="flex items-center justify-between py-3 px-12">
                <!-- Left: Icon + Tagline -->
                <div class="flex items-center gap-2.5">
                    <svg
                        class="w-4 h-4 text-gray-300"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        viewBox="0 0 20 20"
                    >
                        <circle cx="10" cy="10" r="8"></circle>
                    </svg>
                    <span
                        class="text-sm text-gray-400 uppercase tracking-wider font-normal"
                        >CONSTRUCTION & BUILDING BUSINESS WORDPRESS THEME</span
                    >
                </div>

                <!-- Right: Main Navigation Links -->
                <div class="flex items-center gap-1">
                    {
                        mainNavLinks.map((link) => (
                            <div class="relative group">
                                <a
                                    href={link.href}
                                    class="flex items-center gap-1 px-4 py-2 text-sm font-bold uppercase tracking-wider transition-colors text-gray-700 hover:text-primary"
                                >
                                    {link.label}
                                    {link.submenu.length > 0 && (
                                        <svg
                                            class="w-3 h-3"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            viewBox="0 0 24 24"
                                        >
                                            <path d="M19 9l-7 7-7-7" />
                                        </svg>
                                    )}
                                </a>
                                {link.submenu.length > 0 && (
                                    <div class="absolute top-full left-0 min-w-full bg-gray-50 border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-40">
                                        {link.submenu.map((sublink) => (
                                            <a
                                                href={sublink.href}
                                                class="block px-6 py-3 text-sm text-gray-700 hover:bg-gray-100 hover:text-primary transition-colors whitespace-nowrap border-b border-gray-100 last:border-b-0"
                                            >
                                                {sublink.label}
                                            </a>
                                        ))}
                                    </div>
                                )}
                            </div>
                        ))
                    }
                </div>
            </div>
        </Container>
    </div>

    <!-- Main Header + Navigation Combined -->
    <div class="relative">
        <Container size="lg">
            <div class="px-12">
                <!-- Logo, Secondary Navigation, and Contact Info Row -->
                <div class="flex items-stretch">
                    <!-- Logo - Orange Box -->
                    <a href="/" class="shrink-0">
                        <div
                            class="bg-primary w-45 h-full flex flex-col items-center justify-center py-6"
                        >
                            <!-- Circle with CA -->
                            <div
                                class="w-10 h-10 border-2 border-gray-50 rounded-full flex items-center justify-center mb-2"
                            >
                                <span
                                    class="text-gray-50 text-base font-bold leading-none"
                                    >CA</span
                                >
                            </div>
                            <!-- CON ARCH Text -->
                            <div
                                class="text-gray-50 text-xs font-bold tracking-widest leading-tight text-center"
                            >
                                <div>VECTOR</div>
                            </div>
                        </div>
                    </a>

                    <!-- Secondary Navigation -->
                    <nav class="bg-gray-50 border-b border-gray-100">
                        <ul class="flex items-center h-full">
                            {
                                secondaryNavLinks.map((link) => (
                                    <li class="border-r border-gray-100">
                                        <a
                                            href={link.href}
                                            class="flex items-center gap-2 px-8 py-3 text-sm font-bold text-link hover:text-primary transition-colors"
                                        >
                                            {link.label ===
                                                "Specials / Coupons" && (
                                                <svg
                                                    class="w-4 h-4"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    stroke-width="2"
                                                    viewBox="0 0 24 24"
                                                >
                                                    <path d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                                                </svg>
                                            )}
                                            {link.label === "Financing" && (
                                                <svg
                                                    class="w-4 h-4"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    stroke-width="2"
                                                    viewBox="0 0 24 24"
                                                >
                                                    <path d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" />
                                                </svg>
                                            )}
                                            {link.label}
                                        </a>
                                    </li>
                                ))
                            }
                        </ul>
                    </nav>

                    <!-- Contact Info -->
                    <div
                        class="flex items-center gap-8 px-8 bg-gray-50 border-b border-gray-100 flex-1 justify-end"
                    >
                        <!-- Contact Us -->
                        <a
                            href="/contact"
                            class="flex items-center gap-2 group"
                        >
                            <div class="text-gray-700">
                                <svg
                                    class="w-4 h-4"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                    ></path>
                                    <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                                    ></path>
                                </svg>
                            </div>
                            <div class="text-left">
                                <div
                                    class="text-xs text-gray-300 uppercase tracking-wider font-normal"
                                >
                                    Contact Us
                                </div>
                                <div
                                    class="text-sm font-normal text-gray-700 group-hover:text-primary transition-colors"
                                >
                                    info@yoursite.com
                                </div>
                            </div>
                        </a>

                        <!-- Call Us -->
                        <a
                            href="tel:+15550000000"
                            class="flex items-center gap-2 group"
                        >
                            <div class="text-gray-700">
                                <svg
                                    class="w-4 h-4"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                                    ></path>
                                </svg>
                            </div>
                            <div class="text-left">
                                <div
                                    class="text-xs text-gray-300 uppercase tracking-wider font-normal"
                                >
                                    Call Us
                                </div>
                                <div
                                    class="text-sm font-normal text-gray-700 group-hover:text-primary transition-colors"
                                >
                                    Call: 987 654 321
                                </div>
                            </div>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Service Categories Navigation with CTA -->
            <div class="flex px-12 gap-0">
                <nav class="flex flex-1">
                    {
                        serviceCategories.map((category, index) => (
                            <div
                                class={`flex-1 bg-primary group relative ${index > 0 ? "border-l border-gray-50/30" : ""}`}
                            >
                                <a
                                    href={category.href}
                                    class="flex items-center justify-center text-center px-6 py-4 min-h-16 text-sm font-bold text-gray-50 uppercase tracking-wide hover:opacity-90 transition-opacity"
                                >
                                    {category.label}
                                </a>
                                <div class="absolute top-full left-0 right-0 bg-primary opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-30">
                                    {category.services.map((service) => (
                                        <a
                                            href={service.href}
                                            class="flex items-center justify-center text-center px-6 py-3 text-sm text-gray-50 hover:bg-gray-900/10 transition-colors border-t border-gray-50/20"
                                        >
                                            {service.label}
                                        </a>
                                    ))}
                                </div>
                            </div>
                        ))
                    }
                </nav>

                <!-- Book Now CTA Button -->
                <Button
                    href="/book"
                    variant="secondary"
                    size="lg"
                    class="whitespace-nowrap uppercase tracking-wider"
                >
                    BOOK NOW
                </Button>
            </div>
        </Container>
    </div>
</header>
