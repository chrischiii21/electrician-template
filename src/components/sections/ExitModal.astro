---
import Button from "../ui/Button.astro";

interface Props {
    discount: string;
    discountType: "percentage" | "amount";
    code: string;
    title: string;
    subtitle?: string;
    description: string;
    features: string[];
    ctaText?: string;
    dismissText?: string;
    ctaLink?: string;
    expiresIn?: string;
}

const {
    discount,
    discountType,
    code,
    title,
    subtitle,
    description,
    features,
    ctaText = "Claim My Offer",
    dismissText = "No thanks",
    ctaLink = "#contact",
    expiresIn = "47:59:59",
} = Astro.props;

const discountSymbol = discountType === "percentage" ? "%" : "$";
const discountSize = discountType === "percentage" ? "text-8xl" : "text-6xl";
---

<div
    id="exit-modal"
    class="fixed inset-0 z-50 flex items-center justify-center p-4"
    aria-modal="true"
    role="dialog"
    aria-labelledby="exit-title"
    style="display:none"
>
    <!-- Backdrop -->
    <div
        id="exit-backdrop"
        class="absolute inset-0 bg-gray-900/70 backdrop-blur-sm"
    >
    </div>

    <!-- Card -->
    <div
        id="exit-card"
        class="relative w-full max-w-xs md:max-w-2xl bg-white shadow-2xl overflow-hidden max-h-[85vh] md:max-h-none overflow-y-auto md:overflow-y-visible"
    >
        <!-- Animated gradient glow -->
        <div
            class="absolute -inset-1 bg-gradient-to-r from-accent via-primary to-accent opacity-75 blur-xl animate-pulse"
        >
        </div>

        <!-- Card content wrapper -->
        <div class="relative bg-white">
            <!-- Top accent bar with gradient -->
            <div
                class="h-2 bg-gradient-to-r from-accent via-primary to-accent w-full"
            >
            </div>

            <!-- Close -->
            <button
                id="exit-close"
                class="absolute top-4 right-4 text-gray-400 hover:text-text transition-colors z-10"
                aria-label="Close"
            >
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>

            <div class="grid md:grid-cols-2">
                <!-- Left: big offer -->
                <div
                    class="relative bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 p-4 md:p-8 flex flex-col justify-center items-center text-center overflow-hidden"
                >
                    <!-- Accent glow effects -->
                    <div
                        class="absolute top-0 right-0 w-32 h-32 bg-accent/20 rounded-full blur-3xl"
                    >
                    </div>
                    <div
                        class="absolute bottom-0 left-0 w-40 h-40 bg-primary/20 rounded-full blur-3xl"
                    >
                    </div>

                    <p
                        class="relative text-accent font-semibold text-xs uppercase tracking-widest mb-2 md:mb-3 z-10"
                    >
                        Wait — Exclusive Offer
                    </p>
                    <div
                        class="relative font-heading font-bold leading-none mb-1 z-10"
                    >
                        <span
                            class={`text-white ${discountSize.replace("text-8xl", "md:text-8xl text-6xl").replace("text-6xl", "md:text-6xl text-4xl")}`}
                            >{discount}</span
                        ><span
                            class="text-accent md:text-5xl text-3xl drop-shadow-lg"
                            >{discountSymbol}</span
                        >
                    </div>
                    <div
                        class="relative text-white font-heading font-bold md:text-3xl text-2xl mb-4 md:mb-5 z-10"
                    >
                        OFF
                    </div>
                    <p
                        class="relative text-gray-400 text-xs md:text-sm leading-relaxed mb-4 md:mb-6 z-10"
                    >
                        {description}
                    </p>

                    <!-- Dashed coupon code -->
                    <div
                        class="relative border-2 border-dashed border-accent/60 bg-accent/5 px-4 md:px-5 py-2 md:py-3 w-full shadow-lg z-10"
                    >
                        <div
                            class="absolute inset-0 bg-gradient-to-r from-accent/10 to-primary/10"
                        >
                        </div>
                        <div class="relative">
                            <p
                                class="text-gray-400 text-xs uppercase tracking-widest mb-1"
                            >
                                One-time code
                            </p>
                            <p
                                class="text-accent font-heading font-bold md:text-2xl text-lg tracking-[0.2em] drop-shadow-sm"
                            >
                                {code}
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Right: details -->
                <div class="relative p-4 md:p-8 flex flex-col justify-between">
                    <!-- Subtle accent decoration -->
                    <div
                        class="absolute top-0 right-0 w-24 h-24 bg-accent/5 rounded-full blur-2xl"
                    >
                    </div>

                    <div class="relative">
                        <div
                            class="inline-block bg-gradient-to-r from-accent to-primary bg-clip-text"
                        >
                            <p
                                class="text-transparent font-semibold text-xs uppercase tracking-widest mb-2"
                            >
                                Don't Leave Yet
                            </p>
                        </div>
                        <h2
                            id="exit-title"
                            class="font-heading font-bold md:text-2xl text-xl text-text mb-1 leading-tight"
                        >
                            {title}
                        </h2>
                        {
                            subtitle && (
                                <p class="text-primary font-semibold md:text-lg text-base mb-3">
                                    {subtitle}
                                </p>
                            )
                        }
                        <p
                            class="text-gray-700 text-xs md:text-sm leading-relaxed mb-4 md:mb-5"
                        >
                            {description}
                        </p>

                        <ul class="space-y-2 mb-4 md:mb-6">
                            {
                                features.map((item) => (
                                    <li class="flex items-center gap-2 text-xs md:text-sm text-gray-700">
                                        <div class="relative">
                                            <div class="absolute inset-0 bg-accent/20 rounded-full blur-sm" />
                                            <svg
                                                class="relative w-4 h-4 text-accent shrink-0"
                                                fill="currentColor"
                                                viewBox="0 0 20 20"
                                            >
                                                <path
                                                    fill-rule="evenodd"
                                                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                                    clip-rule="evenodd"
                                                />
                                            </svg>
                                        </div>
                                        {item}
                                    </li>
                                ))
                            }
                        </ul>
                    </div>

                    <div class="space-y-3">
                        <Button
                            href={ctaLink}
                            variant="accent"
                            size="md"
                            class="w-full uppercase tracking-wider font-bold exit-cta-btn text-sm md:text-base"
                        >
                            {ctaText}
                        </Button>
                        <button
                            id="exit-dismiss"
                            class="w-full text-center text-xs text-gray-400 hover:text-gray-600 transition-colors py-1"
                        >
                            {dismissText}
                        </button>
                    </div>
                </div>
            </div>

            <!-- Footer note -->
            <div
                class="relative bg-gradient-to-r from-gray-50 via-accent/5 to-gray-50 border-t border-accent/20 px-4 md:px-8 py-2 md:py-3 flex flex-col md:flex-row items-start md:items-center justify-between gap-2 md:gap-0 overflow-hidden"
            >
                <div
                    class="absolute inset-0 bg-gradient-to-r from-transparent via-accent/10 to-transparent animate-pulse"
                >
                </div>
                <p
                    class="relative text-xs text-gray-500 uppercase tracking-wider font-semibold"
                >
                    Offer expires in
                </p>
                <p
                    class="relative font-heading font-bold text-accent text-sm tabular-nums drop-shadow-sm"
                    id="exit-timer"
                >
                    {expiresIn}
                </p>
            </div>
        </div>
    </div>

    <script>
        // Exit modal controls
        const exitModal = document.getElementById("exit-modal");
        const exitBackdrop = document.getElementById("exit-backdrop");
        const exitCloseBtn = document.getElementById("exit-close");
        const exitDismissBtn = document.getElementById("exit-dismiss");
        const exitTimerElement = document.getElementById("exit-timer");

        let exitCountdownInterval: number | null = null;

        function closeExitModal() {
            if (exitModal) {
                exitModal.style.display = "none";
            }
            if (exitCountdownInterval) {
                clearInterval(exitCountdownInterval);
                exitCountdownInterval = null;
            }
        }

        function startExitCountdown(initialTime: string) {
            // Parse initial time (format: HH:MM:SS)
            const parts = initialTime.split(":");
            let totalSeconds =
                parseInt(parts[0]) * 3600 +
                parseInt(parts[1]) * 60 +
                parseInt(parts[2]);

            function updateTimer() {
                if (totalSeconds <= 0) {
                    if (exitCountdownInterval) {
                        clearInterval(exitCountdownInterval);
                    }
                    if (exitTimerElement) {
                        exitTimerElement.textContent = "00:00:00";
                    }
                    return;
                }

                const hours = Math.floor(totalSeconds / 3600);
                const minutes = Math.floor((totalSeconds % 3600) / 60);
                const seconds = totalSeconds % 60;

                if (exitTimerElement) {
                    exitTimerElement.textContent = `${String(hours).padStart(2, "0")}:${String(minutes).padStart(2, "0")}:${String(seconds).padStart(2, "0")}`;
                }

                totalSeconds--;
            }

            // Update immediately
            updateTimer();

            // Then update every second
            exitCountdownInterval = setInterval(
                updateTimer,
                1000,
            ) as unknown as number;
        }

        function openExitModal() {
            if (exitModal) {
                exitModal.style.display = "flex";
                // Start countdown when modal opens
                const initialTime = exitTimerElement?.textContent || "47:59:59";
                startExitCountdown(initialTime);
            }
        }

        // Close on button click
        exitCloseBtn?.addEventListener("click", closeExitModal);
        exitDismissBtn?.addEventListener("click", closeExitModal);
        exitBackdrop?.addEventListener("click", closeExitModal);

        // Expose to window for external control
        (window as any).exitModal = {
            open: openExitModal,
            close: closeExitModal,
        };

        // Detect when user scrolls near footer (80% down the page)
        let exitModalShown = false;

        window.addEventListener("scroll", () => {
            if (exitModalShown) return;

            const scrollPercentage =
                (window.scrollY /
                    (document.documentElement.scrollHeight -
                        window.innerHeight)) *
                100;

            // Show modal when user scrolls to 80% of page
            if (scrollPercentage >= 80) {
                openExitModal();
                exitModalShown = true;
            }
        });

        // Reset flag when page is reloaded or navigated
        window.addEventListener("beforeunload", () => {
            exitModalShown = false;
        });
    </script>
</div>
