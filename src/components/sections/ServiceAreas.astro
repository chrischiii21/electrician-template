---
import { getCollection } from "astro:content";
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Badge from "../ui/Badge.astro";
import Button from "../ui/Button.astro";

const entries = await getCollection("serviceAreas");
const areas = entries
    .sort((a, b) => a.data.order - b.data.order)
    .map((e) => ({ name: e.data.name, href: e.data.href }));

const areaDetails: Record<
    string,
    {
        tagline: string;
        neighborhoods: string[];
        lat: number;
        lng: number;
        zoom: number;
    }
> = {
    "Los Angeles": {
        tagline: "From Hollywood to the Harbor",
        neighborhoods: ["Downtown LA", "Santa Monica", "Burbank", "Pasadena"],
        lat: 34.0522,
        lng: -118.2437,
        zoom: 11,
    },
    "San Diego": {
        tagline: "Coastal to Inland — We Cover It All",
        neighborhoods: ["Chula Vista", "El Cajon", "La Jolla", "Escondido"],
        lat: 32.7157,
        lng: -117.1611,
        zoom: 11,
    },
    "San Francisco": {
        tagline: "Bay Area's Trusted Electricians",
        neighborhoods: ["SoMa", "Mission District", "Oakland", "Daly City"],
        lat: 37.7749,
        lng: -122.4194,
        zoom: 12,
    },
    Sacramento: {
        tagline: "Serving the Capital Region",
        neighborhoods: ["Elk Grove", "Roseville", "Folsom", "Citrus Heights"],
        lat: 38.5816,
        lng: -121.4944,
        zoom: 11,
    },
};
---

<section class="bg-gray-50 py-20" id="service-areas">
    <Container size="lg">
        <!-- Header -->
        <div class="text-center mb-12 scroll-animate">
            <Badge variant="primary" class="mb-3">Where We Work</Badge>
            <Heading level={2} class="text-4xl md:text-5xl mb-4">
                Serving All of <span class="text-primary">California</span>
            </Heading>
            <Text size="xl" class="text-gray-700 max-w-xl mx-auto">
                Licensed electricians on call across four major metro areas.
                Same-day service, local crews, zero travel fees.
            </Text>
        </div>

        <!-- Main layout: city list + map -->
        <div
            class="grid md:grid-cols-5 gap-0 border border-gray-200 scroll-animate"
        >
            <!-- City list (2 cols) -->
            <div class="md:col-span-2 flex flex-col divide-y divide-gray-200">
                {
                    areas.map((area, i) => {
                        const d = areaDetails[area.name];
                        return (
                            <button
                                class="area-tab group text-left px-6 py-5 transition-all duration-200 hover:bg-primary/5 focus:outline-none"
                                data-lat={d?.lat}
                                data-lng={d?.lng}
                                data-zoom={d?.zoom}
                                data-name={area.name}
                                data-index={i}
                            >
                                <div class="flex items-start justify-between gap-4">
                                    <div class="flex-1">
                                        <div class="flex items-center gap-3 mb-1">
                                            <span class="area-num font-heading font-bold text-sm text-gray-300 group-hover:text-primary transition-colors">
                                                {String(i + 1).padStart(2, "0")}
                                            </span>
                                            <p class="area-name font-heading font-bold text-text group-hover:text-primary transition-colors">
                                                {area.name}
                                            </p>
                                        </div>
                                        <p class="text-xs text-gray-400 mb-3 pl-8">
                                            {d?.tagline}
                                        </p>
                                        <div class="flex flex-wrap gap-1 pl-8">
                                            {d?.neighborhoods.map((n) => (
                                                <span class="text-xs bg-gray-100 text-gray-500 px-2 py-0.5 group-hover:bg-primary/10 group-hover:text-primary transition-colors">
                                                    {n}
                                                </span>
                                            ))}
                                        </div>
                                        <div class="pl-8 mt-3">
                                            <a
                                                href={area.href}
                                                class="inline-flex items-center gap-1 text-xs font-bold uppercase tracking-wider text-primary border border-primary px-3 py-1.5 hover:bg-primary hover:text-white transition-all duration-150"
                                                onclick="event.stopPropagation()"
                                            >
                                                View {area.name}
                                                <svg
                                                    class="w-3 h-3"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    viewBox="0 0 24 24"
                                                >
                                                    <path
                                                        stroke-linecap="round"
                                                        stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M17 8l4 4m0 0l-4 4m4-4H3"
                                                    />
                                                </svg>
                                            </a>
                                        </div>
                                    </div>
                                    <svg
                                        class="w-4 h-4 text-gray-300 group-hover:text-primary shrink-0 mt-1 translate-x-0 group-hover:translate-x-1 transition-all duration-200"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M9 5l7 7-7 7"
                                        />
                                    </svg>
                                </div>
                            </button>
                        );
                    })
                }
            </div>

            <!-- Map (3 cols) -->
            <div
                class="md:col-span-3 relative min-h-96 border-l border-gray-200"
            >
                <div id="service-map" class="w-full h-full min-h-96"></div>
                <!-- City label overlay -->
                <div
                    id="map-label"
                    class="absolute top-4 left-4 z-[1000] bg-white border border-gray-200 shadow-sm px-4 py-2 pointer-events-none"
                >
                    <p
                        class="font-heading font-bold text-sm text-text"
                        id="map-city-name"
                    >
                        Los Angeles
                    </p>
                    <p class="text-xs text-gray-400">Service Area</p>
                </div>
            </div>
        </div>

        <!-- Bottom strip -->
        <div
            class="flex flex-col sm:flex-row items-center justify-between gap-4 border border-gray-200 border-t-0 px-6 py-4 scroll-animate"
        >
            <div class="flex items-center gap-3">
                <svg
                    class="w-5 h-5 text-primary shrink-0"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                    ></path>
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <Text size="sm" class="text-gray-500">
                    Don't see your city? We may still cover your area — give us
                    a call.
                </Text>
            </div>
            <Button
                href="/service-area"
                variant="primary"
                size="md"
                class="uppercase tracking-wider font-bold whitespace-nowrap shrink-0"
            >
                Check My Area
            </Button>
        </div>
    </Container>
</section>

<!-- Leaflet CSS -->
<link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
/>

<script>
    // Dynamically load Leaflet
    const script = document.createElement("script");
    script.src = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js";
    script.onload = initMap;
    document.head.appendChild(script);

    const areas = [
        { name: "Los Angeles", lat: 34.0522, lng: -118.2437, zoom: 11 },
        { name: "San Diego", lat: 32.7157, lng: -117.1611, zoom: 11 },
        { name: "San Francisco", lat: 37.7749, lng: -122.4194, zoom: 12 },
        { name: "Sacramento", lat: 38.5816, lng: -121.4944, zoom: 11 },
    ];

    let map: any;
    let marker: any;

    function initMap() {
        const L = (window as any).L;

        map = L.map("service-map", {
            center: [areas[0].lat, areas[0].lng],
            zoom: areas[0].zoom,
            zoomControl: true,
            scrollWheelZoom: false,
        });

        // Clean light tile layer
        L.tileLayer(
            "https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png",
            {
                attribution:
                    '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/">CARTO</a>',
                maxZoom: 19,
            },
        ).addTo(map);

        // Custom primary-colored marker
        const icon = L.divIcon({
            className: "",
            html: `<div style="width:16px;height:16px;background:#F96939;border:3px solid white;box-shadow:0 2px 8px rgba(249,105,57,0.5);"></div>`,
            iconSize: [16, 16],
            iconAnchor: [8, 8],
        });

        marker = L.marker([areas[0].lat, areas[0].lng], { icon }).addTo(map);

        // Activate first tab
        activateTab(0);

        // Tab click handlers
        document.querySelectorAll<HTMLElement>(".area-tab").forEach((tab) => {
            tab.addEventListener("click", () => {
                const idx = parseInt(tab.dataset.index ?? "0");
                activateTab(idx);
            });
        });
    }

    function activateTab(idx: number) {
        const area = areas[idx];
        const tabs = document.querySelectorAll<HTMLElement>(".area-tab");
        const cityLabel = document.getElementById("map-city-name");

        // Update tab styles
        tabs.forEach((t, i) => {
            const isActive = i === idx;
            t.classList.toggle("bg-primary/5", isActive);
            t.classList.toggle("border-l-2", isActive);
            t.classList.toggle("border-primary", isActive);
            t.querySelector<HTMLElement>(".area-name")?.classList.toggle(
                "text-primary",
                isActive,
            );
            t.querySelector<HTMLElement>(".area-num")?.classList.toggle(
                "text-primary",
                isActive,
            );
        });

        // Fly map to location
        if (map) {
            map.flyTo([area.lat, area.lng], area.zoom, { duration: 1.2 });
            marker?.setLatLng([area.lat, area.lng]);
        }

        // Update label
        if (cityLabel) cityLabel.textContent = area.name;
    }
</script>

<style>
    /* Override Leaflet attribution font */
    .leaflet-control-attribution {
        font-size: 10px !important;
    }
</style>
