---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Badge from "../ui/Badge.astro";
import Button from "../ui/Button.astro";

interface Project {
    title: string;
    category: string;
    date: string;
    image: string;
    featured?: boolean;
}

const projects: Project[] = [
    {
        title: "Downtown Tech Hub - Complete Electrical Infrastructure",
        category: "COMMERCIAL",
        date: "Apr 15, 2026",
        image: "https://images.unsplash.com/photo-1621905251189-08b45d6a269e?w=900&q=80",
        featured: true,
    },
    {
        title: "Modern Home EV Charging & Panel Upgrade",
        category: "RESIDENTIAL",
        date: "Apr 10, 2026",
        image: "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=900&q=80",
    },
    {
        title: "Resort Pool & Landscape Lighting Design",
        category: "SPECIALTY",
        date: "Apr 5, 2026",
        image: "https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=900&q=80",
    },
    {
        title: "24/7 Emergency Power Restoration - Medical Facility",
        category: "EMERGENCY",
        date: "Mar 28, 2026",
        image: "https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=900&q=80",
    },
];

const featuredProject = projects.find((p) => p.featured);
const otherProjects = projects.filter((p) => !p.featured);
---

<section class="bg-gray-50 py-20" id="featured-works">
    <Container size="lg">
        <!-- Header -->
        <div class="text-center mb-12 scroll-animate">
            <Badge variant="accent" class="mb-3 uppercase tracking-wider">
                Portfolio Showcase
            </Badge>
            <Heading level={2} class="!text-text text-4xl md:text-5xl mb-4">
                Featured Electrical <span class="text-accent">Projects</span>
            </Heading>
            <Text size="xl" class="!text-gray-600 max-w-5xl mx-auto">
                Explore our recent electrical installations across commercial,
                residential, specialty, and emergency services throughout
                California.
            </Text>
        </div>

        <!-- Projects Grid -->
        <div class="grid lg:grid-cols-2 gap-6">
            <!-- Left: Featured Large Project -->
            {
                featuredProject && (
                    <div class="scroll-fade-left">
                        <a
                            href="#"
                            class="group block bg-white border border-gray-200 overflow-hidden hover:shadow-xl transition-all duration-300"
                        >
                            <div class="relative overflow-hidden">
                                <img
                                    src={featuredProject.image}
                                    alt={featuredProject.title}
                                    class="w-full h-80 object-cover group-hover:scale-105 transition-transform duration-500"
                                />
                                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
                            </div>
                            <div class="p-6">
                                <Heading
                                    level={4}
                                    class="!text-text text-xl mb-4 group-hover:!text-accent transition-colors"
                                >
                                    {featuredProject.title}
                                </Heading>
                                <div class="flex items-center justify-between">
                                    <span class="inline-block px-3 py-1 bg-gray-100 text-gray-700 text-xs font-bold uppercase tracking-wider">
                                        #{featuredProject.category}
                                    </span>
                                    <div class="flex items-center gap-2 text-sm text-gray-500">
                                        <svg
                                            class="w-4 h-4"
                                            fill="currentColor"
                                            viewBox="0 0 20 20"
                                        >
                                            <path
                                                fill-rule="evenodd"
                                                d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z"
                                                clip-rule="evenodd"
                                            />
                                        </svg>
                                        {featuredProject.date}
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                )
            }

            <!-- Right: Smaller Project Cards -->
            <div class="space-y-6 scroll-fade-right">
                {
                    otherProjects.map((project) => (
                        <a
                            href="#"
                            class="group flex gap-4 bg-white border border-gray-200 overflow-hidden hover:shadow-lg transition-all duration-300"
                        >
                            <div class="relative w-32 h-32 flex-shrink-0 overflow-hidden">
                                <img
                                    src={project.image}
                                    alt={project.title}
                                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                                />
                            </div>
                            <div class="flex-1 py-4 pr-4 flex flex-col justify-between">
                                <div>
                                    <Heading
                                        level={5}
                                        class="!text-text text-base mb-2 group-hover:!text-accent transition-colors line-clamp-2"
                                    >
                                        {project.title}
                                    </Heading>
                                </div>
                                <div class="flex items-center justify-between">
                                    <span class="inline-block px-2 py-1 bg-gray-100 text-gray-700 text-xs font-bold uppercase tracking-wider">
                                        #{project.category}
                                    </span>
                                    <div class="flex items-center gap-1 text-xs text-gray-500">
                                        <svg
                                            class="w-3 h-3"
                                            fill="currentColor"
                                            viewBox="0 0 20 20"
                                        >
                                            <path
                                                fill-rule="evenodd"
                                                d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z"
                                                clip-rule="evenodd"
                                            />
                                        </svg>
                                        {project.date}
                                    </div>
                                </div>
                            </div>
                        </a>
                    ))
                }
            </div>
        </div>

        <!-- View All Button -->
        <div class="text-center mt-12 scroll-animate">
            <Button href="/services" variant="primary" size="lg">
                View All Services
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    slot="icon-after"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
            </Button>
        </div>
    </Container>
</section>
