---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Badge from "../ui/Badge.astro";
import Button from "../ui/Button.astro";

interface Props {
    filter?: "Commercial" | "Residential" | "Specialty" | "Emergency";
    instagramFeed?: Array<{
        id: string;
        media_url: string;
        permalink: string;
        caption?: string;
        media_type: string;
        timestamp: string;
    }>;
    instagramUsername?: string;
}

const { filter, instagramFeed, instagramUsername } = Astro.props;

interface Project {
    title: string;
    category: string;
    image: string;
    href: string;
    isInstagram?: boolean;
    instagramUrl?: string;
}

// Fallback static projects (used when Instagram feed is not available)
const staticProjects: Project[] = [
    {
        title: "Commercial Electrical Panel Installation",
        category: "Commercial",
        image: "https://images.unsplash.com/photo-1621905252507-b35492cc74b4?w=900&q=80",
        href: "/commercial/panels",
    },
    {
        title: "Residential EV Charging Station Setup",
        category: "Residential",
        image: "https://images.unsplash.com/photo-1593941707882-a5bba14938c7?w=900&q=80",
        href: "/residential/ev-charging",
    },
    {
        title: "Outdoor Landscape Lighting Design",
        category: "Specialty",
        image: "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=900&q=80",
        href: "/specialty/landscape",
    },
    {
        title: "24/7 Emergency Electrical Repair",
        category: "Emergency",
        image: "https://images.unsplash.com/photo-1621905251918-48416bd8575a?w=900&q=80",
        href: "/emergency/24-hour",
    },
    {
        title: "Industrial HVAC Electrical Systems",
        category: "Commercial",
        image: "https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=900&q=80",
        href: "/commercial/hvac",
    },
    {
        title: "Home Generator Installation",
        category: "Residential",
        image: "/images/energy-efficiency.jpg",
        href: "/residential/generators",
    },
];

// Convert Instagram feed to project format
let allProjects: Project[] = staticProjects;

if (instagramFeed && instagramFeed.length > 0) {
    allProjects = instagramFeed
        .filter(post => post.media_type === 'IMAGE' || post.media_type === 'CAROUSEL_ALBUM')
        .slice(0, 6) // Limit to 6 posts
        .map(post => {
            // Extract category from caption hashtags or default to "Featured"
            const caption = post.caption || "";
            let category = "Featured";
            
            if (caption.toLowerCase().includes("#commercial")) category = "Commercial";
            else if (caption.toLowerCase().includes("#residential")) category = "Residential";
            else if (caption.toLowerCase().includes("#specialty")) category = "Specialty";
            else if (caption.toLowerCase().includes("#emergency")) category = "Emergency";
            
            // Extract title from caption (first line or first 50 chars)
            const title = caption.split('\n')[0].substring(0, 60).trim() || "Recent Project";
            
            return {
                title: title,
                category: category,
                image: post.media_url,
                href: post.permalink,
                isInstagram: true,
                instagramUrl: post.permalink,
            };
        });
}

const projects = filter 
    ? allProjects.filter(project => project.category === filter)
    : allProjects;

const isUsingInstagram = instagramFeed && instagramFeed.length > 0;
---

<section class="bg-white py-20" id="featured-works">
    <Container size="lg">
        <!-- Header -->
        <div class="text-center mb-12 scroll-animate">
            <Badge variant="accent" class="mb-3 uppercase tracking-wider">
                {isUsingInstagram ? "Recent Projects" : "Portfolio Showcase"}
            </Badge>
            <Heading level={2} class="text-text! text-4xl md:text-5xl mb-4">
                Featured Electrical <span class="text-accent">Projects</span>
            </Heading>
            <Text size="xl" class="text-gray-600! max-w-5xl mx-auto">
                {isUsingInstagram 
                    ? `Follow our latest work on Instagram ${instagramUsername ? `@${instagramUsername}` : ''}`
                    : "Explore our recent electrical installations across commercial, residential, specialty, and emergency services."
                }
            </Text>
        </div>

        <!-- Instagram-style Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
            {
                projects.map((project) => (
                    <a 
                        href={project.isInstagram ? project.instagramUrl : project.href} 
                        class="scroll-animate group block"
                        target={project.isInstagram ? "_blank" : "_self"}
                        rel={project.isInstagram ? "noopener noreferrer" : undefined}
                    >
                        <div class="relative aspect-square overflow-hidden bg-gray-100">
                            <img
                                src={project.image}
                                alt={`${project.title} - completed electrical project showcasing professional installation work`}
                                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                                loading="lazy"
                            />
                            
                            <!-- Overlay on hover -->
                            <div class="absolute inset-0 bg-black/70 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center p-6 text-center">
                                <Heading level={4} class="text-white! text-lg mb-3 line-clamp-2">
                                    {project.title}
                                </Heading>
                                <span class="inline-block px-3 py-1 bg-accent text-white text-xs font-bold uppercase tracking-wider">
                                    {project.category}
                                </span>
                                {project.isInstagram && (
                                    <div class="mt-3 flex items-center gap-2 text-white text-xs">
                                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                                            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                                        </svg>
                                        <span>View on Instagram</span>
                                    </div>
                                )}
                            </div>
                        </div>
                    </a>
                ))
            }
        </div>

        <!-- View All Button / Instagram Link -->
        <div class="text-center scroll-animate">
            {isUsingInstagram && instagramUsername ? (
                <Button 
                    href={`https://instagram.com/${instagramUsername}`} 
                    variant="primary" 
                    size="lg"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                    </svg>
                    Follow Us on Instagram
                    <svg
                        class="w-5 h-5 ml-2"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                    </svg>
                </Button>
            ) : (
                <Button href="/services" variant="primary" size="lg">
                    View All Services
                    <svg
                        class="w-5 h-5 ml-2"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                </Button>
            )}
        </div>
    </Container>
</section>
