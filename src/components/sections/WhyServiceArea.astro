---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Badge from "../ui/Badge.astro";

interface Props {
    city: string;
    reasons: Array<{
        title: string;
        description: string;
        icon: string;
        image: string;
    }>;
}

const { city, reasons } = Astro.props;
---

<section class="bg-gray-50 py-20" id="why-service-area">
    <Container size="lg">
        <!-- Header -->
        <div class="text-center mb-20 scroll-animate">
            <Badge variant="primary" class="mb-3">Local Expertise</Badge>
            <Heading level={2} class="text-4xl md:text-5xl mb-4">
                Why We Service <span class="text-primary">{city}</span>
            </Heading>
            <Text size="xl" class="text-gray-700 max-w-2xl mx-auto">
                We're deeply committed to serving {city} because we understand the unique electrical needs of this vibrant community.
            </Text>
        </div>

        <!-- Reasons Grid -->
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 scroll-stagger">
            {reasons.map((reason) => (
                <div class="group bg-white overflow-hidden border border-gray-200 hover:border-primary hover:shadow-lg transition-all duration-300">
                    <!-- Image Container -->
                    <div class="relative h-40 overflow-hidden bg-gray-200">
                        <img
                            src={reason.image}
                            alt={reason.title}
                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                            loading="lazy"
                        />
                    </div>

                    <!-- Content -->
                    <div class="p-6">
                        <!-- Icon -->
                        <div class="w-10 h-10 bg-primary/10 flex items-center justify-center text-primary mb-3 border border-primary/20">
                            <div class="w-5 h-5" set:html={reason.icon} />
                        </div>

                        <Heading level={4} class="mb-2 text-lg">{reason.title}</Heading>
                        <Text size="sm" class="text-gray-600 leading-relaxed">{reason.description}</Text>
                    </div>
                </div>
            ))}
        </div>

        <!-- Bottom Section -->
        <div class="mt-20 bg-white border border-gray-200 p-8 md:p-12 scroll-animate">
            <div class="grid md:grid-cols-2 gap-12 items-center">
                <!-- Left Content -->
                <div>
                    <Heading level={3} class="mb-4">Local Knowledge, Professional Excellence</Heading>
                    <Text class="text-gray-700 mb-4 leading-relaxed">
                        Our team knows {city} inside and out. We understand the local building codes, climate challenges, and the specific electrical demands of homes and businesses in this area.
                    </Text>
                    <Text class="text-gray-700 leading-relaxed">
                        That's why {city} residents and businesses trust us for all their electrical needs. We're not just service providers—we're your neighbors.
                    </Text>
                </div>

                <!-- Right Image -->
                <div class="relative h-64 overflow-hidden shadow-md">
                    <img
                        src="https://images.unsplash.com/photo-1552664730-d307ca884978?w=600&h=400&fit=crop"
                        alt="Los Angeles community"
                        class="w-full h-full object-cover"
                        loading="lazy"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
                </div>
            </div>
        </div>
    </Container>
</section>
