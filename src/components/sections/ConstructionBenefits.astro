---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Badge from "../ui/Badge.astro";
import Grid from "../ui/Grid.astro";

const iconMap: Record<string, string> = {
    "checkmark-circle": `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    "clock-circle": `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    "lightning-bolt": `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
    "currency-dollar": `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    users: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    "shield-check": `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>`,
};

const rawContent =
    await import("../../content/construction-benefits.md?raw").then(
        (m) => m.default,
    );

const benefits = rawContent
    .split("\n")
    .filter((line: string) => line.startsWith("## "))
    .map((line: string) => {
        const title = line.replace("## ", "").trim();
        const lines = rawContent.split("\n");
        const lineIndex = lines.indexOf(line);

        // Find icon and description in the next lines (skip empty lines)
        let iconKey = "";
        let description = "";

        for (let i = lineIndex + 1; i < lines.length; i++) {
            const currentLine = lines[i];
            if (currentLine.includes("**Icon**")) {
                iconKey =
                    currentLine.match(/\*\*Icon\*\*:\s*(.+)/)?.[1]?.trim() ||
                    "";
            }
            if (currentLine.includes("**Description**")) {
                description =
                    currentLine
                        .match(/\*\*Description\*\*:\s*(.+)/)?.[1]
                        ?.trim() || "";
            }
            // Stop when we hit the next heading or end of content
            if (currentLine.startsWith("## ") && currentLine !== line) break;
        }

        return {
            icon: iconMap[iconKey] || iconMap["checkmark-circle"],
            title,
            description,
        };
    });

console.log("Total benefits parsed:", benefits.length);
benefits.forEach((b) => console.log(`- ${b.title}`));
---

<section class="bg-gray-50 py-20" id="construction-benefits">
    <Container size="lg">
        <!-- Header -->
        <div class="text-center mb-16 scroll-animate">
            <Badge variant="primary" class="mb-3">Why Choose Us</Badge>
            <Heading level={2} class="text-4xl md:text-5xl mb-4">
                Ground-up Construction <span class="text-primary"
                    >Expertise</span
                >
            </Heading>
            <Text size="xl" class="text-gray-700 max-w-2xl mx-auto">
                We bring specialized expertise, reliability, and professionalism
                to every new construction electrical project.
            </Text>
        </div>

        <!-- Benefits Grid -->
        <Grid cols={3} gap="lg" class="scroll-stagger">
            {
                benefits.map((benefit) => (
                    <div class="bg-white border border-gray-200 p-6 hover:border-primary hover:shadow-lg transition-all duration-300">
                        <div class="w-12 h-12 bg-primary/10 flex items-center justify-center text-primary mb-4 border border-primary/20">
                            <div class="w-6 h-6" set:html={benefit.icon} />
                        </div>
                        <Heading level={4} class="mb-2">
                            {benefit.title}
                        </Heading>
                        <Text size="sm" class="text-gray-600">
                            {benefit.description}
                        </Text>
                    </div>
                ))
            }
        </Grid>
    </Container>
</section>
