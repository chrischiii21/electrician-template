---
import Container from "../ui/Container.astro";
import Grid from "../ui/Grid.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";

const rawContent = await import("../../content/trust-badges.md?raw").then(
    (m) => m.default,
);

const trustItems = rawContent
    .split("\n")
    .filter((line: string) => line.startsWith("## "))
    .map((line: string) => {
        const name = line.replace("## ", "").trim();
        const lines = rawContent.split("\n");
        const lineIndex = lines.indexOf(line);

        let rating = "";
        let svg = "";

        for (let i = lineIndex + 1; i < lines.length; i++) {
            const currentLine = lines[i];
            if (currentLine.includes("**Rating**")) {
                rating =
                    currentLine.match(/\*\*Rating\*\*:\s*(.+)/)?.[1]?.trim() ||
                    "";
            }
            if (currentLine.includes("**SVG**")) {
                svg =
                    currentLine.match(/\*\*SVG\*\*:\s*(.+)/)?.[1]?.trim() || "";
            }
            if (currentLine.startsWith("## ") && currentLine !== line) break;
        }

        return {
            name,
            rating,
            svg,
        };
    });

const duplicated = [...trustItems, ...trustItems];
---

<section class="bg-background py-8 border-y border-gray-100 overflow-hidden">
    <Container size="lg">
        <div class="text-center mb-6 scroll-animate">
            <p class="font-body text-xl text-gray-400 uppercase tracking-wider">
                Trusted by thousands of homeowners &amp; businesses
            </p>
        </div>

        <!-- Scrolling Logos -->
        <div class="relative">
            <div
                class="absolute left-0 top-0 bottom-0 w-20 bg-linear-to-r from-background to-transparent z-10 pointer-events-none"
            >
            </div>
            <div
                class="absolute right-0 top-0 bottom-0 w-20 bg-linear-to-l from-background to-transparent z-10 pointer-events-none"
            >
            </div>

            <div class="logo-track">
                <div class="logo-track-inner">
                    {
                        duplicated.map((item) => (
                            <div class="logo-item" title={item.name}>
                                <div class="logo-card">
                                    <div class="logo-svg" set:html={item.svg} />
                                    <div class="logo-meta">
                                        <div class="font-body text-xs font-semibold text-text leading-tight">
                                            {item.name}
                                        </div>
                                        <div class="font-body text-xs text-gray-400">
                                            {item.rating}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>

        <!-- Stats -->
        <Grid cols={4} gap="md" class="mt-8 scroll-stagger">
            <div class="text-center">
                <Heading level={2} class="text-primary mb-1">15+</Heading>
                <Text size="xl" class="text-gray-400">Years Experience</Text>
            </div>
            <div class="text-center">
                <Heading level={2} class="text-primary mb-1">5,000+</Heading>
                <Text size="xl" class="text-gray-400">Projects Completed</Text>
            </div>
            <div class="text-center">
                <Heading level={2} class="text-primary mb-1">100%</Heading>
                <Text size="xl" class="text-gray-400">Satisfaction Rate</Text>
            </div>
            <div class="text-center">
                <Heading level={2} class="text-primary mb-1">24/7</Heading>
                <Text size="xl" class="text-gray-400">Emergency Service</Text>
            </div>
        </Grid>
    </Container>
</section>

<style>
    .logo-track {
        overflow: hidden;
        width: 100%;
    }

    .logo-track-inner {
        display: flex;
        gap: 1.25rem;
        animation: scroll-left 35s linear infinite;
        width: fit-content;
    }

    .logo-track:hover .logo-track-inner {
        animation-play-state: paused;
    }

    @keyframes scroll-left {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(-50%);
        }
    }

    .logo-item {
        flex-shrink: 0;
        width: 210px;
    }

    .logo-card {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        background: white;
        border: 1px solid #f0f0f0;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.05);
        transition:
            box-shadow 0.2s ease,
            transform 0.2s ease;
    }

    .logo-card:hover {
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.1);
        transform: translateY(-2px);
    }

    .logo-svg {
        flex-shrink: 0;
        width: 56px;
        height: 28px;
        display: flex;
        align-items: center;
    }

    .logo-svg svg {
        width: 100%;
        height: 100%;
    }

    .logo-meta {
        flex: 1;
        min-width: 0;
    }

    .logo-meta > div {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>
