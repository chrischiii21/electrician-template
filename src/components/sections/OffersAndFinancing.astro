---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Badge from "../ui/Badge.astro";
import Button from "../ui/Button.astro";
import Card from "../ui/Card.astro";

interface Props {
    category?: "Commercial" | "Residential" | "Specialty" | "Emergency";
}

const { category } = Astro.props;

interface Coupon {
    title: string;
    discount: string;
    description: string;
    code: string;
}

interface FinancingPlan {
    name: string;
    apr: string;
    term: string;
}

// Helper function to parse markdown sections
function parseMarkdownSections(content: string, fields: string[]) {
    const lines = content.split("\n");
    const sections: any[] = [];

    lines.forEach((line, index) => {
        if (line.startsWith("## ")) {
            const section: any = {};
            const title = line.replace("## ", "").trim();

            for (let i = index + 1; i < lines.length; i++) {
                const currentLine = lines[i];
                if (currentLine.startsWith("## ")) break;

                fields.forEach((field) => {
                    const regex = new RegExp(`\\*\\*${field}\\*\\*:\\s*(.+)`);
                    const match = currentLine.match(regex);
                    if (match) {
                        const key = field.toLowerCase().replace(/\s+/g, "");
                        section[key] = match[1].trim();
                    }
                });
            }

            section.title = title;
            sections.push(section);
        }
    });

    return sections;
}

// Load Specials/Coupons
const specialsContent =
    await import("../../content/specials-coupons.md?raw").then(
        (m) => m.default,
    );

const allCoupons: Coupon[] = parseMarkdownSections(specialsContent, [
    "Discount",
    "Description",
    "Code",
]).map((section) => ({
    title: section.title,
    discount: section.discount || "",
    description: section.description || "",
    code: section.code || "",
}));

const filteredCoupons = category
    ? allCoupons.filter((coupon) => {
          const searchText =
              `${coupon.title} ${coupon.description}`.toLowerCase();
          return searchText.includes(category.toLowerCase());
      })
    : allCoupons;

const displayCoupons =
    filteredCoupons.length > 0 ? filteredCoupons : allCoupons;

// Load Financing Plans
const financingContent =
    await import("../../content/financing-plans.md?raw").then((m) => m.default);

const allPlans: FinancingPlan[] = parseMarkdownSections(financingContent, [
    "APR",
    "Term",
]).map((section) => ({
    name: section.title,
    apr: section.apr || "0%",
    term: section.term || "",
}));

const filteredPlans = category
    ? allPlans.filter((plan) => {
          const searchText = plan.name.toLowerCase();
          return searchText.includes(category.toLowerCase());
      })
    : allPlans;

const displayPlans = filteredPlans.length > 0 ? filteredPlans : allPlans;

const specialsCount = displayCoupons.length;
const topDiscount = displayCoupons[0]?.discount || "20% OFF";
const lowestAPR = displayPlans[0]?.apr || "0%";
---

<section class="bg-white py-20" id="offers-financing">
