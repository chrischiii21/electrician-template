                        class="w-full rounded-none font-black"
                    >
                        Apply for Financing
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            slot="icon-after"
                        >
                            <path
                                stroke-linecap="round"
