                        <div>
                            <Heading
                                level={3}
                                class="text-text! text-3xl font-black mb-1"
                            >
                                Special <span class="text-accent">Offers</span>
                            </Heading>
                            <Text size="base" class="text-gray-600! font-bold">
                                {specialsCount} Active Deals
                            </Text>
                        </div>
                    </div>

                    <Card
                        padding="lg"
                        class="border-4 border-accent/20 bg-accent/5 mb-8 rounded-none"
                    >
                        <div class="space-y-6">
                            <div>
                                <div
                                    class="text-accent font-black text-6xl mb-3"
                                >
