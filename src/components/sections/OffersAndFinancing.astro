                            </svg>
                        </div>
                        <div>
                            <Heading
                                level={3}
                                class="text-text! text-3xl font-black mb-1"
                            >
                                Flexible <span class="text-primary"
                                    >Financing</span
                                >
                            </Heading>
                            <Text size="base" class="text-gray-600! font-bold">
                                {displayPlans.length} Payment Plans
                            </Text>
                        </div>
