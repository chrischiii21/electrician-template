                    <Card
                        padding="lg"
                        class="border-4 border-primary/20 bg-primary/5 mb-8 rounded-none"
                    >
                        <div class="space-y-6">
                            <div>
                                <div
                                    class="text-primary font-black text-6xl mb-3"
                                >
                                    {lowestAPR}
