---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Badge from "../ui/Badge.astro";

const rawContent = await import("../../content/construction-process.md?raw").then(
    (m) => m.default,
);

const steps = rawContent
    .split("\n")
    .filter((line: string) => line.startsWith("## "))
    .map((line: string) => {
        const headerMatch = line.match(/## (\d+)\s*-\s*(.+)/);
        const number = headerMatch?.[1] || "";
        const title = headerMatch?.[2]?.trim() || "";
        
        const lines = rawContent.split("\n");
        const lineIndex = lines.indexOf(line);
        
        let description = "";
        let detailsStr = "";
        
        for (let i = lineIndex + 1; i < lines.length; i++) {
            const currentLine = lines[i];
            if (currentLine.includes("**Description**")) {
                description = currentLine.match(/\*\*Description\*\*:\s*(.+)/)?.[1]?.trim() || "";
            }
            if (currentLine.includes("**Details**")) {
                detailsStr = currentLine.match(/\*\*Details\*\*:\s*(.+)/)?.[1]?.trim() || "";
            }
            if (currentLine.startsWith("## ") && currentLine !== line) break;
        }
        
        const details = detailsStr.split(",").map((d: string) => d.trim()).filter((d: string) => d);

        return {
            number,
            title,
            description,
            details,
        };
    });
---

<section class="bg-white py-20" id="construction-process">
    <Container size="lg">
        <!-- Header -->
        <div class="text-center mb-16 scroll-animate">
            <Badge variant="accent" class="mb-3">Our Process</Badge>
            <Heading level={2} class="text-4xl md:text-5xl mb-4">
                Ground-up Construction <span class="text-accent">Process</span>
            </Heading>
            <Text size="xl" class="text-gray-700 max-w-2xl mx-auto">
                From design through commissioning, we manage every phase of new electrical construction with precision and expertise.
            </Text>
        </div>

        <!-- Timeline -->
        <div class="relative scroll-stagger">
            <!-- Vertical line -->
            <div class="absolute left-0 md:left-1/2 top-0 bottom-0 w-1 bg-gradient-to-b from-accent via-accent to-primary md:transform md:-translate-x-1/2"></div>

            <!-- Steps -->
            <div class="space-y-12 md:space-y-16">
                {steps.map((step, index) => (
                    <div class={`relative md:flex ${index % 2 === 0 ? "md:flex-row" : "md:flex-row-reverse"}`}>
                        <!-- Content -->
                        <div class={`md:w-1/2 ${index % 2 === 0 ? "md:pr-12" : "md:pl-12"} pl-12 md:pl-0`}>
                            <div class="bg-gray-50 border border-gray-200 p-6 hover:border-accent hover:shadow-lg hover:shadow-accent/20 transition-all duration-300">
                                <div class="flex items-start gap-4 mb-4">
                                    <div class="text-4xl font-bold text-accent/30">{step.number}</div>
                                    <div class="flex-grow">
                                        <Heading level={4} class="mb-1 group-hover:text-accent">{step.title}</Heading>
                                        <Text size="sm" class="text-gray-600">{step.description}</Text>
                                    </div>
                                </div>

                                <!-- Details -->
                                <div class="grid grid-cols-2 gap-2 mt-4 pt-4 border-t border-gray-200">
                                    {step.details.map((detail) => (
                                        <div class="flex items-center gap-2">
                                            <svg class="w-3 h-3 text-accent shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                                            </svg>
                                            <Text size="xs" class="text-gray-700">{detail}</Text>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        </div>

                        <!-- Timeline dot -->
                        <div class="absolute left-0 md:left-1/2 top-6 md:top-8 w-4 h-4 bg-white border-4 border-accent md:transform md:-translate-x-1/2 md:-translate-x-2"></div>
                    </div>
                ))}
            </div>
        </div>
    </Container>
</section>
