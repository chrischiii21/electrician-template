---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Badge from "../ui/Badge.astro";

interface Props {
    eyebrow?: string;
    title: string;
    description: string;
    stats?: Array<{ number: string; label: string }>;
    image?: string;
    currentCategory?: "Commercial" | "Residential" | "Specialty" | "Emergency";
}

const { eyebrow, title, description, stats, image, currentCategory } =
    Astro.props;

const icons = {
    commercial:
        '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />',
    residential:
        '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />',
    specialty:
        '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />',
    emergency:
        '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />',
};

const allServices = [
    {
        category: "Commercial",
        title: "Commercial Services",
        description:
            "Professional electrical solutions for businesses and offices.",
        icon: icons.commercial,
        href: "/commercial",
    },
    {
        category: "Residential",
        title: "Residential Services",
        description: "Expert electrical work for homes and apartments.",
        icon: icons.residential,
        href: "/residential",
    },
    {
        category: "Specialty",
        title: "Specialty Services",
        description:
            "Specialized electrical installations for unique projects.",
        icon: icons.specialty,
        href: "/specialty",
    },
    {
        category: "Emergency",
        title: "Emergency Services",
        description: "24/7 emergency electrical repairs and service.",
        icon: icons.emergency,
        href: "/emergency",
    },
];

const relatedServices = allServices.filter(
    (service) => service.category !== currentCategory,
);
---

<section class="bg-white py-20">
    <Container size="lg">
        <div class="grid lg:grid-cols-[2fr_1fr] gap-12 items-start">
            <!-- Left: About Content -->
            <div class="scroll-fade-left">
                {
                    eyebrow && (
                        <Badge
                            variant="accent"
                            class="mb-4 uppercase tracking-wider"
                        >
                            {eyebrow}
                        </Badge>
                    )
                }

                <Heading
                    level={2}
                    class="text-text text-4xl md:text-5xl mb-6 font-black"
                >
                    {title}
                </Heading>

                <Text size="xl" class="text-gray-700 mb-8 leading-relaxed">
                    {description}
                </Text>

                {
                    stats && stats.length > 0 && (
                        <div class="grid grid-cols-3 gap-6 mb-8">
                            {stats.map((stat) => (
                                <div class="text-center bg-gray-50 border-2 border-gray-200 p-6 hover:border-accent transition-all">
                                    <div class="text-4xl font-black text-accent mb-2">
                                        {stat.number}
                                    </div>
                                    <Text
                                        size="sm"
                                        class="text-gray-600 font-bold uppercase tracking-wide"
                                    >
                                        {stat.label}
                                    </Text>
                                </div>
                            ))}
                        </div>
                    )
                }

                {
                    image && (
                        <div>
                            <img
                                src={image}
                                alt={`${title} - professional electrical services`}
                                class="w-full h-96 object-cover border-4 border-gray-200"
                            />
                        </div>
                    )
                }
            </div>

            <!-- Right: Related Services -->
            <div class="scroll-fade-right">
                <div class="bg-gray-50 border-2 border-gray-200 p-6">
                    <div class="flex items-center gap-3 mb-6">
                        <div
                            class="w-10 h-10 bg-accent flex items-center justify-center"
                        >
                            <svg
                                class="w-5 h-5 text-white"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"
                                ></path>
                            </svg>
                        </div>
                        <Heading level={3} class="text-xl font-black text-text">
                            Other <span class="text-accent">Services</span>
                        </Heading>
                    </div>

                    <div class="space-y-4">
                        {
                            relatedServices.map((service) => (
                                <a href={service.href} class="block group">
                                    <div class="bg-white border-2 border-gray-200 p-5 hover:border-accent hover:shadow-lg transition-all duration-300">
                                        <div class="flex items-start gap-4">
                                            <div class="w-12 h-12 bg-accent/10 border border-accent/20 flex items-center justify-center shrink-0 group-hover:bg-accent group-hover:border-accent transition-all">
                                                <svg
                                                    class="w-6 h-6 text-accent group-hover:text-white transition-colors"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    viewBox="0 0 24 24"
                                                >
                                                    <Fragment
                                                        set:html={service.icon}
                                                    />
                                                </svg>
                                            </div>
                                            <div class="flex-1">
                                                <Heading
                                                    level={4}
                                                    class="text-lg font-black mb-2 text-text group-hover:text-accent transition-colors"
                                                >
                                                    {service.title}
                                                </Heading>
                                                <Text
                                                    size="sm"
                                                    class="text-gray-600 mb-3"
                                                >
                                                    {service.description}
                                                </Text>
                                                <div class="flex items-center gap-2 text-accent font-bold text-sm">
                                                    <span>Learn More</span>
                                                    <svg
                                                        class="w-4 h-4 transition-transform group-hover:translate-x-1"
                                                        fill="none"
                                                        stroke="currentColor"
                                                        viewBox="0 0 24 24"
                                                    >
                                                        <path
                                                            stroke-linecap="round"
                                                            stroke-linejoin="round"
                                                            stroke-width="2"
                                                            d="M13 7l5 5m0 0l-5 5m5-5H6"
                                                        />
                                                    </svg>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            ))
                        }
                    </div>

                    <div
                        class="mt-6 pt-6 border-t-2 border-gray-200 text-center"
                    >
                        <a
                            href="/services"
                            class="inline-flex items-center gap-2 text-accent font-bold hover:underline"
                        >
                            <span>View All Services</span>
                            <svg
                                class="w-5 h-5"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                            </svg>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </Container>
</section>
