---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";

const questions = [
    {
        icon: "⚡",
        text: "Is your electrical panel over 20 years old?",
        options: ["Yes", "No", "Not Sure"],
        risk: [2, 0, 1],
    },
    {
        icon: "🔌",
        text: "Do you frequently trip breakers or blow fuses?",
        options: ["Yes", "Sometimes", "Never"],
        risk: [2, 1, 0],
    },
    {
        icon: "💡",
        text: "Have you noticed flickering lights or burning smells?",
        options: ["Yes", "No", "Not Sure"],
        risk: [2, 0, 1],
    },
];
---

<section class="bg-gray-900 py-20 overflow-hidden" id="safety-quiz">
    <Container size="lg">
        <div class="grid md:grid-cols-2 gap-12 items-center">
            <!-- Left: branding panel -->
            <div class="scroll-fade-left">
                <p
                    class="text-primary font-semibold text-xs uppercase tracking-widest mb-4 flex items-center gap-2"
                >
                    <span class="inline-block w-6 h-px bg-primary"></span>
                    Safety Diagnostic
                </p>
                <h2
                    class="font-heading font-bold text-4xl md:text-5xl text-white uppercase leading-tight mb-4"
                >
                    Is Your Home<br /><span class="text-primary">At Risk?</span>
                </h2>
                <p class="text-gray-400 mb-10">
                    3 questions. 30 seconds. Get your electrical risk score
                    instantly.
                </p>

                <!-- Voltage gauge -->
                <div class="relative w-48 h-24 mx-auto md:mx-0">
                    <svg viewBox="0 0 200 110" class="w-full">
                        <!-- Track -->
                        <path
                            d="M20 100 A80 80 0 0 1 180 100"
                            fill="none"
                            stroke="#374151"
                            stroke-width="14"
                            stroke-linecap="butt"></path>
                        <!-- Fill — driven by JS -->
                        <path
                            id="gauge-fill"
                            d="M20 100 A80 80 0 0 1 180 100"
                            fill="none"
                            stroke="#22c55e"
                            stroke-width="14"
                            stroke-linecap="butt"
                            stroke-dasharray="251.2"
                            stroke-dashoffset="251.2"
                            style="transition: stroke-dashoffset 0.8s ease, stroke 0.5s ease"
                        ></path>
                        <!-- Needle -->
                        <line
                            id="gauge-needle"
                            x1="100"
                            y1="100"
                            x2="100"
                            y2="28"
                            stroke="white"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            style="transform-origin: 100px 100px; transform: rotate(-90deg); transition: transform 0.8s cubic-bezier(0.22,1,0.36,1)"
                        ></line>
                        <circle cx="100" cy="100" r="5" fill="white"></circle>
                        <!-- Labels -->
                        <text
                            x="16"
                            y="116"
                            fill="#6b7280"
                            font-size="9"
                            font-family="monospace">LOW</text
                        >
                        <text
                            x="86"
                            y="20"
                            fill="#6b7280"
                            font-size="9"
                            font-family="monospace">MED</text
                        >
                        <text
                            x="168"
                            y="116"
                            fill="#6b7280"
                            font-size="9"
                            font-family="monospace">HIGH</text
                        >
                    </svg>
                    <div class="absolute inset-x-0 bottom-0 text-center">
                        <p
                            id="gauge-label"
                            class="font-heading font-bold text-white text-sm uppercase tracking-widest"
                        >
                            RISK LEVEL
                        </p>
                    </div>
                </div>

                <!-- Risk score display -->
                <div class="mt-6 flex items-center gap-3">
                    <div class="flex gap-1.5">
                        <div
                            class="risk-dot w-3 h-3 bg-gray-700 transition-colors duration-500"
                            data-dot="0"
                        >
                        </div>
                        <div
                            class="risk-dot w-3 h-3 bg-gray-700 transition-colors duration-500"
                            data-dot="1"
                        >
                        </div>
                        <div
                            class="risk-dot w-3 h-3 bg-gray-700 transition-colors duration-500"
                            data-dot="2"
                        >
                        </div>
                        <div
                            class="risk-dot w-3 h-3 bg-gray-700 transition-colors duration-500"
                            data-dot="3"
                        >
                        </div>
                        <div
                            class="risk-dot w-3 h-3 bg-gray-700 transition-colors duration-500"
                            data-dot="4"
                        >
                        </div>
                        <div
                            class="risk-dot w-3 h-3 bg-gray-700 transition-colors duration-500"
                            data-dot="5"
                        >
                        </div>
                    </div>
                    <p
                        id="score-label"
                        class="text-gray-500 text-xs font-mono uppercase tracking-wider"
                    >
                        Awaiting input...
                    </p>
                </div>
            </div>

            <!-- Right: quiz terminal -->
            <div class="scroll-fade-right">
                <div class="bg-gray-800 border border-gray-700 overflow-hidden">
                    <!-- Terminal header bar -->
                    <div
                        class="bg-gray-700 px-4 py-2.5 flex items-center gap-2 border-b border-gray-600"
                    >
                        <div class="w-3 h-3 bg-red-500/70"></div>
                        <div class="w-3 h-3 bg-yellow-500/70"></div>
                        <div class="w-3 h-3 bg-green-500/70"></div>
                        <span class="ml-3 text-gray-400 text-xs font-mono"
                            >electrical_safety_check.exe</span
                        >
                    </div>

                    <!-- Progress steps -->
                    <div class="flex border-b border-gray-700">
                        {
                            questions.map((_, i) => (
                                <div
                                    class:list={[
                                        "quiz-step flex-1 py-2 text-center text-xs font-mono border-r border-gray-700 last:border-0 transition-all duration-300",
                                        i === 0
                                            ? "text-primary bg-primary/10"
                                            : "text-gray-600",
                                    ]}
                                    data-step={i}
                                >
                                    Q{i + 1}
                                </div>
                            ))
                        }
                    </div>

                    <!-- Question area -->
                    <div class="p-6 min-h-52">
                        {
                            questions.map((q, i) => (
                                <div
                                    data-question={i}
                                    class:list={[
                                        "quiz-question",
                                        i !== 0 && "hidden",
                                    ]}
                                >
                                    <div class="flex items-start gap-3 mb-6">
                                        <span class="text-2xl leading-none mt-0.5">
                                            {q.icon}
                                        </span>
                                        <p class="font-heading font-bold text-white text-lg leading-snug uppercase">
                                            {q.text}
                                        </p>
                                    </div>
                                    <div class="flex flex-wrap gap-3">
                                        {q.options.map((opt, oi) => (
                                            <button
                                                class="quiz-answer border border-gray-600 px-6 py-2.5 text-xs font-bold uppercase tracking-widest text-gray-300 hover:border-primary hover:text-primary hover:bg-primary/10 transition-all duration-150 font-mono"
                                                data-q={i}
                                                data-risk={q.risk[oi]}
                                            >
                                                {opt}
                                            </button>
                                        ))}
                                    </div>
                                </div>
                            ))
                        }

                        <!-- Result panel -->
                        <div id="quiz-result" class="hidden">
                            <div id="result-icon" class="text-4xl mb-3"></div>
                            <p
                                id="result-headline"
                                class="font-heading font-bold text-white text-xl uppercase mb-2"
                            >
                            </p>
                            <p
                                id="result-body"
                                class="text-gray-400 text-sm leading-relaxed mb-6"
                            >
                            </p>
                            <div class="flex flex-wrap gap-3">
                                <Button
                                    href="#contact"
                                    variant="primary"
                                    size="md"
                                    class="uppercase tracking-wider font-bold font-mono text-xs"
                                >
                                    Book Free Safety Check →
                                </Button>
                                <button
                                    id="quiz-restart"
                                    class="text-xs text-gray-500 hover:text-gray-300 transition-colors font-mono uppercase tracking-wider px-2"
                                >
                                    [ restart ]
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Status bar -->
                    <div
                        class="bg-gray-700/50 border-t border-gray-700 px-4 py-2 flex items-center justify-between"
                    >
                        <span
                            id="status-text"
                            class="text-xs font-mono text-gray-500"
                            >STATUS: READY</span
                        >
                        <span
                            id="progress-text"
                            class="text-xs font-mono text-gray-600"
                            >0 / {questions.length} ANSWERED</span
                        >
                    </div>
                </div>
            </div>
        </div>
    </Container>
</section>

<script>
    const questions = 3;
    let current = 0;
    let totalRisk = 0;
    let answered = 0;

    const gaugeFill = document.getElementById(
        "gauge-fill",
    ) as SVGPathElement | null;
    const gaugeNeedle = document.getElementById(
        "gauge-needle",
    ) as SVGLineElement | null;
    const gaugeLabel = document.getElementById("gauge-label");
    const scoreLabel = document.getElementById("score-label");
    const statusText = document.getElementById("status-text");
    const progressText = document.getElementById("progress-text");
    const FULL_DASH = 251.2;

    function updateGauge(risk: number) {
        // risk 0–6 mapped to 0–180deg needle and 0–100% fill
        const pct = Math.min(risk / 6, 1);
        const offset = FULL_DASH - FULL_DASH * pct;
        const deg = -90 + 180 * pct;

        if (gaugeFill) {
            gaugeFill.style.strokeDashoffset = String(offset);
            gaugeFill.style.stroke =
                pct < 0.4 ? "#22c55e" : pct < 0.7 ? "#f59f0a" : "#ef4444";
        }
        if (gaugeNeedle) {
            gaugeNeedle.style.transform = `rotate(${deg}deg)`;
        }

        // Dots
        const activeDots = Math.round(pct * 6);
        document
            .querySelectorAll<HTMLElement>(".risk-dot")
            .forEach((dot, i) => {
                const on = i < activeDots;
                dot.style.backgroundColor = on
                    ? pct < 0.4
                        ? "#22c55e"
                        : pct < 0.7
                          ? "#f59f0a"
                          : "#ef4444"
                    : "#374151";
            });

        if (gaugeLabel) {
            gaugeLabel.textContent =
                pct < 0.4 ? "LOW RISK" : pct < 0.7 ? "MODERATE" : "HIGH RISK";
            gaugeLabel.style.color =
                pct < 0.4 ? "#22c55e" : pct < 0.7 ? "#f59f0a" : "#ef4444";
        }
        if (scoreLabel) {
            scoreLabel.textContent = `Risk score: ${risk}/6`;
            scoreLabel.style.color =
                pct < 0.4 ? "#22c55e" : pct < 0.7 ? "#f59f0a" : "#ef4444";
        }
    }

    function goTo(index: number) {
        document
            .querySelectorAll<HTMLElement>(".quiz-question")
            .forEach((el, i) => {
                el.classList.toggle("hidden", i !== index);
            });
        document
            .querySelectorAll<HTMLElement>(".quiz-step")
            .forEach((step, i) => {
                step.classList.toggle("text-primary", i === index);
                step.classList.toggle("bg-primary/10", i === index);
                step.classList.toggle("text-gray-400", i < index);
                step.classList.toggle("text-gray-600", i > index);
            });
        if (statusText)
            statusText.textContent = `STATUS: QUESTION ${index + 1} OF ${questions}`;
    }

    function showResult() {
        document
            .querySelectorAll<HTMLElement>(".quiz-question")
            .forEach((el) => el.classList.add("hidden"));
        document.querySelectorAll<HTMLElement>(".quiz-step").forEach((step) => {
            step.classList.add("text-primary", "bg-primary/10");
            step.classList.remove("text-gray-600");
        });

        const result = document.getElementById("quiz-result");
        const icon = document.getElementById("result-icon");
        const headline = document.getElementById("result-headline");
        const body = document.getElementById("result-body");

        const pct = totalRisk / 6;
        if (pct >= 0.6) {
            if (icon) icon.textContent = "🚨";
            if (headline) headline.textContent = "High Risk Detected";
            if (headline) headline.style.color = "#ef4444";
            if (body)
                body.textContent =
                    "Multiple warning signs found. Your home may have a serious electrical hazard. A licensed inspection is strongly recommended before something goes wrong.";
        } else if (pct >= 0.3) {
            if (icon) icon.textContent = "⚠️";
            if (headline) headline.textContent = "Moderate Risk Found";
            if (headline) headline.style.color = "#f59f0a";
            if (body)
                body.textContent =
                    "At least one risk factor was identified. It's worth having a professional take a look — catching issues early saves money and keeps your family safe.";
        } else {
            if (icon) icon.textContent = "✅";
            if (headline) headline.textContent = "Looking Good";
            if (headline) headline.style.color = "#22c55e";
            if (body)
                body.textContent =
                    "No major red flags detected. We still recommend a routine electrical checkup every 5 years to stay ahead of any issues.";
        }

        result?.classList.remove("hidden");
        if (statusText) statusText.textContent = "STATUS: DIAGNOSTIC COMPLETE";
        if (progressText)
            progressText.textContent = `${questions} / ${questions} ANSWERED`;
    }

    document
        .querySelectorAll<HTMLButtonElement>(".quiz-answer")
        .forEach((btn) => {
            btn.addEventListener("click", () => {
                const risk = parseInt(btn.dataset.risk ?? "0");
                totalRisk += risk;
                answered++;

                // Highlight selected
                document
                    .querySelectorAll<HTMLElement>(`[data-q="${current}"]`)
                    .forEach((s) => {
                        s.classList.remove(
                            "border-primary",
                            "text-primary",
                            "bg-primary/10",
                        );
                    });
                btn.classList.add(
                    "border-primary",
                    "text-primary",
                    "bg-primary/10",
                );

                updateGauge(totalRisk);
                if (progressText)
                    progressText.textContent = `${answered} / ${questions} ANSWERED`;

                setTimeout(() => {
                    current++;
                    if (current < questions) {
                        goTo(current);
                    } else {
                        showResult();
                    }
                }, 350);
            });
        });

    document.getElementById("quiz-restart")?.addEventListener("click", () => {
        current = 0;
        totalRisk = 0;
        answered = 0;
        document.getElementById("quiz-result")?.classList.add("hidden");
        document
            .querySelectorAll<HTMLElement>(".quiz-answer")
            .forEach((btn) => {
                btn.classList.remove(
                    "border-primary",
                    "text-primary",
                    "bg-primary/10",
                );
            });
        updateGauge(0);
        goTo(0);
        if (progressText)
            progressText.textContent = `0 / ${questions} ANSWERED`;
    });
</script>
