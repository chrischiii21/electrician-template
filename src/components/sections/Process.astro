---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Badge from "../ui/Badge.astro";

const rawContent = await import("../../content/construction-process.md?raw").then(
    (m) => m.default,
);

const steps = rawContent
    .split("\n")
    .filter((line: string) => line.startsWith("## "))
    .map((line: string) => {
        const headerMatch = line.match(/## (\d+)\s*-\s*(.+)/);
        const number = headerMatch?.[1] || "";
        const title = headerMatch?.[2]?.trim() || "";
        
        const lines = rawContent.split("\n");
        const lineIndex = lines.indexOf(line);
        
        let description = "";
        
        for (let i = lineIndex + 1; i < lines.length; i++) {
            const currentLine = lines[i];
            if (currentLine.includes("**Description**")) {
                description = currentLine.match(/\*\*Description\*\*:\s*(.+)/)?.[1]?.trim() || "";
            }
            if (currentLine.startsWith("## ") && currentLine !== line) break;
        }

        return {
            number,
            title,
            description,
        };
    });
---

<section class="bg-background py-16" id="construction-process">
    <Container size="lg">
        <!-- Header -->
        <div class="text-center mb-12 scroll-animate">
            <Badge variant="accent" class="mb-3">Our Process</Badge>
            <Heading level={2} class="text-4xl md:text-5xl mb-4">
                Ground-up Construction <span class="text-accent">Process</span>
            </Heading>
            <Text size="lg" class="text-gray-600 max-w-2xl mx-auto">
                From design through commissioning, we manage every phase with precision and expertise.
            </Text>
        </div>

        <!-- Horizontal Timeline -->
        <div class="relative scroll-stagger">
            <!-- Desktop: Horizontal line -->
            <div class="hidden lg:block absolute top-20 left-0 right-0 h-0.5 bg-linear-to-r from-accent/20 via-accent to-accent/20"></div>

            <!-- Steps Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-4">
                {steps.map((step, index) => (
                    <div class="relative">
                        <!-- Desktop: Timeline dot -->
                        <div class="hidden lg:block absolute left-1/2 top-20 transform -translate-x-1/2 -translate-y-1/2 w-3 h-3 bg-accent border-4 border-white shadow-md z-10"></div>
                        
                        <!-- Content Card -->
                        <div class="bg-white border border-gray-200 p-5 hover:border-accent hover:shadow-lg hover:shadow-accent/10 transition-all duration-300 h-full">
                            <!-- Number Badge -->
                            <div class="flex justify-center mb-4">
                                <div class="bg-white border-2 border-accent px-4 py-1.5">
                                    <span class="text-2xl font-bold text-accent">{step.number}</span>
                                </div>
                            </div>

                            <!-- Title -->
                            <Heading level={4} class="text-lg font-bold mb-2 text-center">
                                {step.title}
                            </Heading>

                            <!-- Description -->
                            <Text size="sm" class="text-gray-600 text-center leading-relaxed">
                                {step.description}
                            </Text>
                        </div>

                        <!-- Mobile: Connector line (vertical) -->
                        {index < steps.length - 1 && (
                            <div class="lg:hidden flex justify-center py-3">
                                <div class="w-0.5 h-6 bg-accent/30"></div>
                            </div>
                        )}
                    </div>
                ))}
            </div>
        </div>
    </Container>
</section>
