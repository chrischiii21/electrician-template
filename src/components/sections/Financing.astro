---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Badge from "../ui/Badge.astro";
import Grid from "../ui/Grid.astro";
import Card from "../ui/Card.astro";
import Button from "../ui/Button.astro";

const rawContent = await import("../../content/financing-plans.md?raw").then(
    (m) => m.default,
);

const plans = rawContent
    .split("\n")
    .filter((line: string) => line.startsWith("## "))
    .map((line: string) => {
        const name = line.replace("## ", "").trim();
        const lines = rawContent.split("\n");
        const lineIndex = lines.indexOf(line);

        let apr = "";
        let term = "";
        let minAmount = "";
        let maxAmount = "";
        let highlighted = false;
        let featuresStr = "";

        for (let i = lineIndex + 1; i < lines.length; i++) {
            const currentLine = lines[i];
            if (currentLine.includes("**APR**")) {
                apr =
                    currentLine.match(/\*\*APR\*\*:\s*(.+)/)?.[1]?.trim() || "";
            }
            if (currentLine.includes("**Term**")) {
                term =
                    currentLine.match(/\*\*Term\*\*:\s*(.+)/)?.[1]?.trim() ||
                    "";
            }
            if (currentLine.includes("**Min Amount**")) {
                minAmount =
                    currentLine
                        .match(/\*\*Min Amount\*\*:\s*(.+)/)?.[1]
                        ?.trim() || "";
            }
            if (currentLine.includes("**Max Amount**")) {
                maxAmount =
                    currentLine
                        .match(/\*\*Max Amount\*\*:\s*(.+)/)?.[1]
                        ?.trim() || "";
            }
            if (currentLine.includes("**Highlighted**")) {
                const highlightedStr =
                    currentLine
                        .match(/\*\*Highlighted\*\*:\s*(.+)/)?.[1]
                        ?.trim() || "false";
                highlighted = highlightedStr.toLowerCase() === "true";
            }
            if (currentLine.includes("**Features**")) {
                featuresStr =
                    currentLine
                        .match(/\*\*Features\*\*:\s*(.+)/)?.[1]
                        ?.trim() || "";
            }
            if (currentLine.startsWith("## ") && currentLine !== line) break;
        }

        const features = featuresStr
            .split(",")
            .map((f: string) => f.trim())
            .filter((f: string) => f);

        return {
            name,
            apr,
            term,
            minAmount,
            maxAmount,
            features,
            highlighted,
        };
    });
---

<section class="bg-gradient-to-b from-white to-gray-50 py-20" id="financing">
    <Container size="lg">
        <!-- Header -->
        <div class="text-center mb-16 scroll-animate">
            <Badge variant="primary" class="mb-3">Flexible Payments</Badge>
            <Heading level={2} class="text-4xl md:text-5xl mb-4">
                Financing Plans for Every <span class="text-primary"
                    >Project</span
                >
            </Heading>
            <Text size="xl" class="text-gray-700 max-w-2xl mx-auto">
                Choose the financing plan that works best for your electrical
                project. All plans feature 0% APR for qualified customers.
            </Text>
        </div>

        <!-- Plans Grid -->
        <Grid cols={3} gap="lg" class="mb-16 scroll-stagger">
            {
                plans.map((plan) => (
                    <Card
                        padding="lg"
                        class={`relative flex flex-col transition-all duration-200 ${
                            plan.highlighted
                                ? "border-2 border-primary shadow-xl scale-105"
                                : "border border-gray-200 hover:border-primary hover:shadow-lg"
                        }`}
                    >
                        {plan.highlighted && (
                            <div class="absolute -top-4 left-1/2 -translate-x-1/2">
                                <Badge variant="primary">Most Popular</Badge>
                            </div>
                        )}

                        <div class="mb-6">
                            <Heading level={3} class="mb-2">
                                {plan.name}
                            </Heading>
                            <div class="flex items-baseline gap-1 mb-4">
                                <span class="text-4xl font-bold text-primary">
                                    {plan.apr}
                                </span>
                                <span class="text-gray-600">APR</span>
                            </div>
                            <div class="space-y-2 text-md text-gray-600">
                                <p>
                                    <span class="font-semibold">Term:</span>{" "}
                                    {plan.term}
                                </p>
                                <p>
                                    <span class="font-semibold">Amount:</span>{" "}
                                    {plan.minAmount} - {plan.maxAmount}
                                </p>
                            </div>
                        </div>

                        <div class="flex-grow mb-6">
                            <p class="text-md font-semibold text-gray-400 uppercase tracking-wider mb-3">
                                Includes
                            </p>
                            <ul class="space-y-3">
                                {plan.features.map((feature) => (
                                    <li class="flex items-start gap-2">
                                        <svg
                                            class="w-4 h-4 text-accent flex-shrink-0 mt-0.5"
                                            fill="currentColor"
                                            viewBox="0 0 20 20"
                                        >
                                            <path
                                                fill-rule="evenodd"
                                                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                                clip-rule="evenodd"
                                            />
                                        </svg>
                                        <Text size="sm" class="text-gray-700">
                                            {feature}
                                        </Text>
                                    </li>
                                ))}
                            </ul>
                        </div>

                        <Button
                            href="/financing"
                            variant={plan.highlighted ? "primary" : "outline"}
                            size="md"
                            class="w-full"
                        >
                            Learn More
                        </Button>
                    </Card>
                ))
            }
        </Grid>

        <!-- Info Section -->
        <div class="bg-white border border-gray-200 p-8 scroll-animate">
            <Heading level={3} class="mb-4">How It Works</Heading>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                <div class="text-center">
                    <div
                        class="w-12 h-12 bg-accent/10 flex items-center justify-center mx-auto mb-3"
                    >
                        <span class="text-accent font-bold text-lg">1</span>
                    </div>
                    <Heading level={4} class="mb-2">Apply Online</Heading>
                    <Text size="lg" class="text-gray-600">
                        Complete our simple application in minutes
                    </Text>
                </div>
                <div class="text-center">
                    <div
                        class="w-12 h-12 bg-accent/10 flex items-center justify-center mx-auto mb-3"
                    >
                        <span class="text-accent font-bold text-lg">2</span>
                    </div>
                    <Heading level={4} class="mb-2">Get Approved</Heading>
                    <Text size="lg" class="text-gray-600">
                        Receive instant approval decision
                    </Text>
                </div>
                <div class="text-center">
                    <div
                        class="w-12 h-12 bg-accent/10 flex items-center justify-center mx-auto mb-3"
                    >
                        <span class="text-accent font-bold text-lg">3</span>
                    </div>
                    <Heading level={4} class="mb-2">Schedule Service</Heading>
                    <Text size="lg" class="text-gray-600">
                        Book your electrical project
                    </Text>
                </div>
                <div class="text-center">
                    <div
                        class="w-12 h-12 bg-accent/10 flex items-center justify-center mx-auto mb-3"
                    >
                        <span class="text-accent font-bold text-lg">4</span>
                    </div>
                    <Heading level={4} class="mb-2">Start Paying</Heading>
                    <Text size="lg" class="text-gray-600">
                        Make easy monthly payments
                    </Text>
                </div>
            </div>
        </div>
    </Container>
</section>
