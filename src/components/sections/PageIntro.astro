---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Badge from "../ui/Badge.astro";
import Card from "../ui/Card.astro";

interface Props {
    eyebrow?: string;
    title: string;
    description: string;
    stats?: Array<{ number: string; label: string }>;
    features?: Array<{ icon: string; title: string; description: string }>;
    image?: string;
    highlights?: Array<string>;
}

const { eyebrow, title, description, stats, features, image, highlights } =
    Astro.props;
---

<section class="bg-white py-20">
    <Container size="lg">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
            <!-- Left: Content -->
            <div>
                {
                    eyebrow && (
                        <Badge
                            variant="accent"
                            class="mb-4 uppercase tracking-wider"
                        >
                            {eyebrow}
                        </Badge>
                    )
                }

                <Heading
                    level={2}
                    class="text-text! text-4xl md:text-5xl mb-6 font-black"
                >
                    {title}
                </Heading>

                <Text size="xl" class="text-gray-700! mb-8 leading-relaxed">
                    {description}
                </Text>

                {
                    highlights && highlights.length > 0 && (
                        <div class="space-y-3 mb-8">
                            {highlights.map((highlight) => (
                                <div class="flex items-center gap-3">
                                    <svg
                                        class="w-6 h-6 text-accent shrink-0"
                                        fill="currentColor"
                                        viewBox="0 0 20 20"
                                    >
                                        <path
                                            fill-rule="evenodd"
                                            d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                            clip-rule="evenodd"
                                        />
                                    </svg>
                                    <Text
                                        size="lg"
                                        class="text-gray-700! font-semibold"
                                    >
                                        {highlight}
                                    </Text>
                                </div>
                            ))}
                        </div>
                    )
                }

                {
                    stats && stats.length > 0 && (
                        <div class="grid grid-cols-3 gap-6">
                            {stats.map((stat) => (
                                <div class="text-center">
                                    <div class="text-4xl font-black text-primary mb-2">
                                        {stat.number}
                                    </div>
                                    <Text
                                        size="sm"
                                        class="text-gray-600! font-bold uppercase tracking-wide"
                                    >
                                        {stat.label}
                                    </Text>
                                </div>
                            ))}
                        </div>
                    )
                }
            </div>

            <!-- Right: Image or Features -->
            <div>
                {
                    image ? (
                        <div class="relative">
                            <img
                                src={image}
                                alt={`${title} - professional electrical services and installations by licensed electricians`}
                                class="w-full h-96 object-cover border-4 border-gray-200"
                            />
                            {stats && stats.length > 0 && (
                                <div class="absolute -bottom-6 -left-6 bg-primary p-6 border-4 border-primary">
                                    <div class="text-white text-center">
                                        <div class="text-5xl font-black mb-2">
                                            {stats[0].number}
                                        </div>
                                        <div class="text-sm font-bold uppercase tracking-wide">
                                            {stats[0].label}
                                        </div>
                                    </div>
                                </div>
                            )}
                        </div>
                    ) : features && features.length > 0 ? (
                        <div class="space-y-4">
                            {features.map((feature) => (
                                <Card
                                    padding="lg"
                                    class="border-2 border-gray-200 hover:border-primary transition-all rounded-none"
                                >
                                    <div class="flex items-start gap-4">
                                        <div class="w-12 h-12 bg-primary flex items-center justify-center shrink-0">
                                            <span class="text-2xl">
                                                {feature.icon}
                                            </span>
                                        </div>
                                        <div class="flex-1">
                                            <Heading
                                                level={4}
                                                class="text-text! text-xl font-black mb-2"
                                            >
                                                {feature.title}
                                            </Heading>
                                            <Text
                                                size="base"
                                                class="text-gray-600!"
                                            >
                                                {feature.description}
                                            </Text>
                                        </div>
                                    </div>
                                </Card>
                            ))}
                        </div>
                    ) : null
                }
            </div>
        </div>
    </Container>
</section>
