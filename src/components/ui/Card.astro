---
interface Props {
    class?: string;
    padding?: "sm" | "md" | "lg";
    accent?: "none" | "blue" | "orange" | "green" | "purple" | "yellow";
    hover?: boolean;
}

const {
    class: className = "",
    padding = "md",
    accent = "none",
    hover = false,
} = Astro.props;

const paddings = {
    sm: "p-4",
    md: "p-6",
    lg: "p-8",
};

const accents = {
    none: "",
    blue: "border-t-4 border-t-brand-blue",
    orange: "border-t-4 border-t-brand-orange",
    green: "border-t-4 border-t-brand-green",
    purple: "border-t-4 border-t-brand-purple",
    yellow: "border-t-4 border-t-brand-yellow",
};

const hoverEffect = hover
    ? "transition-all duration-300 hover:shadow-lg hover:-translate-y-1"
    : "";

const classes = `bg-background border border-neutral-200 shadow-sm rounded-lg ${paddings[padding]} ${accents[accent]} ${hoverEffect} ${className}`;
---

<div class={classes}>
    <slot />
</div>
