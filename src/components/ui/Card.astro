---
interface Props {
    class?: string;
    padding?: "sm" | "md" | "lg";
}

const { class: className = "", padding = "md" } = Astro.props;

const paddings = {
    sm: "p-4",
    md: "p-6",
    lg: "p-8",
};

const classes = `bg-background border border-text/10 shadow-sm ${paddings[padding]} ${className}`;
---

<div class={classes}>
    <slot />
</div>
