---
interface Props {
    variant?:
        | "primary"
        | "secondary"
        | "accent"
        | "blue"
        | "orange"
        | "green"
        | "purple"
        | "outline";
    size?: "sm" | "md" | "lg";
    href?: string;
    type?: "button" | "submit" | "reset";
    class?: string;
}

const {
    variant = "primary",
    size = "md",
    href,
    type = "button",
    class: className = "",
} = Astro.props;

const baseStyles =
    "inline-flex items-center justify-center font-bold transition-all duration-200 hover:-translate-y-0.5";

const variants = {
    primary:
        "bg-primary text-white hover:bg-accent hover:shadow-lg hover:shadow-primary/30",
    secondary:
        "bg-secondary text-white hover:bg-secondary/90 hover:shadow-lg hover:shadow-secondary/30",
    accent: "bg-accent text-white hover:bg-primary hover:shadow-lg hover:shadow-accent/30",
    blue: "bg-brand-blue text-white hover:bg-brand-blue/90 hover:shadow-lg hover:shadow-brand-blue/20",
    orange: "bg-brand-orange text-white hover:bg-brand-orange/90 hover:shadow-lg hover:shadow-brand-orange/20",
    green: "bg-brand-green text-white hover:bg-brand-green/90 hover:shadow-lg hover:shadow-brand-green/20",
    purple: "bg-brand-purple text-white hover:bg-brand-purple/90 hover:shadow-lg hover:shadow-brand-purple/20",
    outline:
        "border-1 !border-white !text-white hover:!bg-white hover:!text-accent shadow-lg backdrop-blur-sm bg-white/10",
};

const sizes = {
    sm: "px-4 py-2 text-sm",
    md: "px-6 py-3 text-base",
    lg: "px-8 py-4 text-xl",
};

const classes = `${baseStyles} ${variants[variant]} ${sizes[size]} ${className}`;

const Tag = href ? "a" : "button";
---

<Tag href={href} type={!href ? type : undefined} class={classes}>
    <slot />
</Tag>
