---
import Button from "./Button.astro";

// Quick offer configuration
const offer = {
    discount: "$75 OFF",
    title: "Spring Special",
    description: "Any electrical panel upgrade",
    code: "SPRING75",
    cta: "Claim Offer",
    ctaLink: "/contact",
};
---

<!-- Floating trigger button -->
<button
    id="qh-trigger"
    class="fixed bottom-6 right-6 z-50 w-16 h-16 bg-gradient-to-br from-accent to-primary text-white shadow-2xl flex items-center justify-center transition-all duration-300 hover:scale-110 group"
    aria-label="Special Offer"
    aria-expanded="false"
>
    <svg
        class="w-8 h-8 group-hover:rotate-12 transition-transform"
        fill="currentColor"
        viewBox="0 0 20 20"
    >
        <path
            d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
        ></path>
    </svg>

    <!-- Pulse effect -->
    <span class="absolute inset-0 bg-accent animate-ping opacity-75"></span>

    <!-- Badge -->
    <span
        class="absolute -top-2 -right-2 px-2 py-1 bg-brand-yellow text-primary text-xs font-black border-2 border-white shadow-lg"
    >
        $75
    </span>
</button>

<!-- Slide-in Banner -->
<div
    id="qh-banner"
    class="fixed bottom-24 right-6 z-50 w-80 md:w-96 bg-white shadow-2xl border-4 border-accent opacity-0 pointer-events-none"
    role="alert"
    aria-live="polite"
    style="transform: translateX(100px) scale(0.9);"
>
    <!-- Animated gradient glow -->
    <div
        class="absolute -inset-1 bg-gradient-to-r from-accent via-primary to-accent opacity-50 blur-lg"
    >
    </div>

    <!-- Content wrapper -->
    <div class="relative bg-white">
        <!-- Accent top bar -->
        <div class="h-2 bg-gradient-to-r from-accent via-primary to-accent">
        </div>

        <!-- Close button -->
        <button
            id="qh-close"
            class="absolute top-3 right-3 w-7 h-7 bg-gray-100 hover:bg-accent text-gray-600 hover:text-white transition-all flex items-center justify-center z-10"
            aria-label="Close"
        >
            <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2.5"
                    d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>

        <div class="p-6">
            <!-- Header with icon -->
            <div class="flex items-start gap-4 mb-5">
                <div
                    class="w-14 h-14 bg-gradient-to-br from-accent to-primary flex items-center justify-center shrink-0 shadow-lg"
                >
                    <svg
                        class="w-7 h-7 text-white"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                    >
                        <path
                            d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                        ></path>
                    </svg>
                </div>
                <div class="flex-1 pt-1">
                    <div class="flex items-center gap-2 mb-2">
                        <span
                            class="text-3xl font-black text-accent leading-none"
                            >{offer.discount}</span
                        >
                    </div>
                    <div
                        class="inline-block px-3 py-1 bg-accent text-white text-xs font-bold uppercase tracking-wider mb-2"
                    >
                        {offer.title}
                    </div>
                    <p class="text-sm text-gray-600 font-semibold">
                        {offer.description}
                    </p>
                </div>
            </div>

            <!-- Coupon Code -->
            <div
                class="bg-gradient-to-br from-gray-50 to-gray-100 border-2 border-dashed border-accent/40 p-4 mb-5 relative overflow-hidden"
            >
                <div
                    class="absolute top-0 right-0 w-20 h-20 bg-accent/5 rounded-full -mr-10 -mt-10"
                >
                </div>
                <div class="relative">
                    <p
                        class="text-xs text-gray-500 uppercase tracking-widest font-bold mb-2"
                    >
                        Use Coupon Code
                    </p>
                    <div class="flex items-center justify-between gap-3">
                        <code
                            class="text-xl font-black text-accent tracking-[0.15em]"
                        >
                            {offer.code}
                        </code>
                        <button
                            id="copy-code-btn"
                            class="px-4 py-2 bg-accent text-white hover:bg-primary transition-all hover:scale-105 shadow-md"
                            data-code={offer.code}
                            aria-label={`Copy code ${offer.code}`}
                            title="Copy code"
                        >
                            <svg
                                class="w-5 h-5"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
                                ></path>
                            </svg>
                        </button>
                    </div>
                </div>
            </div>

            <!-- CTA Button -->
            <Button
                href={offer.ctaLink}
                variant="accent"
                size="lg"
                class="w-full font-black uppercase tracking-wider shadow-lg hover:shadow-xl"
            >
                {offer.cta} →
            </Button>

            <!-- Timer -->
            <div
                class="mt-4 pt-4 border-t border-gray-200 flex items-center justify-center gap-2 text-xs"
            >
                <svg
                    class="w-4 h-4 text-accent animate-pulse"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                >
                    <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z"
                        clip-rule="evenodd"></path>
                </svg>
                <span
                    class="text-gray-500 font-semibold uppercase tracking-wide"
                    >Expires in:</span
                >
                <span
                    id="qh-timer"
                    class="font-black text-accent tabular-nums text-sm"
                    >47:59:59</span
                >
            </div>
        </div>
    </div>
</div>

<script>
    const trigger = document.getElementById("qh-trigger");
    const banner = document.getElementById("qh-banner");
    const closeBtn = document.getElementById("qh-close");
    const copyBtn = document.getElementById("copy-code-btn");
    const timerElement = document.getElementById("qh-timer");

    let isOpen = false;
    let countdownInterval: number | null = null;

    // Shared timer key for syncing across components
    const TIMER_KEY = "promo_timer_end";
    const TIMER_DURATION = 48 * 60 * 60 * 1000; // 48 hours in milliseconds

    function getTimerEndTime(): number {
        const stored = localStorage.getItem(TIMER_KEY);
        if (stored) {
            const endTime = parseInt(stored);
            if (endTime > Date.now()) {
                return endTime;
            }
        }
        // Set new end time
        const newEndTime = Date.now() + TIMER_DURATION;
        localStorage.setItem(TIMER_KEY, newEndTime.toString());
        return newEndTime;
    }

    function updateAllTimers() {
        const endTime = getTimerEndTime();
        const now = Date.now();
        const remaining = Math.max(0, endTime - now);

        const hours = Math.floor(remaining / (1000 * 60 * 60));
        const minutes = Math.floor(
            (remaining % (1000 * 60 * 60)) / (1000 * 60),
        );
        const seconds = Math.floor((remaining % (1000 * 60)) / 1000);

        // Update QuickHelp timer
        if (timerElement) {
            timerElement.textContent = `${String(hours).padStart(2, "0")}:${String(minutes).padStart(2, "0")}:${String(seconds).padStart(2, "0")}`;
        }

        // Update header promo bar timers
        const hoursEl = document.querySelector('[data-unit="hours"]');
        const minsEl = document.querySelector('[data-unit="mins"]');
        const secsEl = document.querySelector('[data-unit="secs"]');

        if (hoursEl) hoursEl.textContent = String(hours).padStart(2, "0");
        if (minsEl) minsEl.textContent = String(minutes).padStart(2, "0");
        if (secsEl) secsEl.textContent = String(seconds).padStart(2, "0");

        if (remaining <= 0 && countdownInterval) {
            clearInterval(countdownInterval);
            countdownInterval = null;
        }
    }

    function startCountdown() {
        // Update immediately
        updateAllTimers();

        // Then update every second
        if (!countdownInterval) {
            countdownInterval = setInterval(
                updateAllTimers,
                1000,
            ) as unknown as number;
        }
    }

    function openBanner() {
        if (banner && !isOpen) {
            isOpen = true;
            banner.style.opacity = "1";
            banner.style.transform = "translateX(0) scale(1)";
            banner.style.pointerEvents = "auto";
            banner.style.transition =
                "all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1)";
            trigger?.setAttribute("aria-expanded", "true");

            if (!countdownInterval) {
                startCountdown();
            }
        }
    }

    function closeBanner() {
        if (banner && isOpen) {
            isOpen = false;
            banner.style.opacity = "0";
            banner.style.transform = "translateX(100px) scale(0.9)";
            banner.style.pointerEvents = "none";
            banner.style.transition = "all 0.3s ease-in";
            trigger?.setAttribute("aria-expanded", "false");
        }
    }

    // Copy code functionality
    copyBtn?.addEventListener("click", async (e) => {
        e.preventDefault();
        const code = copyBtn.getAttribute("data-code");
        if (code) {
            try {
                await navigator.clipboard.writeText(code);
                const originalHTML = copyBtn.innerHTML;
                copyBtn.innerHTML = `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>`;
                setTimeout(() => {
                    copyBtn.innerHTML = originalHTML;
                }, 2000);
            } catch (err) {
                console.error("Failed to copy:", err);
            }
        }
    });

    // Event listeners
    trigger?.addEventListener("click", () => {
        if (isOpen) {
            closeBanner();
        } else {
            openBanner();
        }
    });

    closeBtn?.addEventListener("click", closeBanner);

    // Start countdown on page load
    startCountdown();

    // Expose to window for external control
    (window as any).quickHelpBanner = {
        open: openBanner,
        close: closeBanner,
    };
</script>
