---
import Button from "./Button.astro";
import Heading from "./Heading.astro";
import Text from "./Text.astro";

const faqs = [
    {
        id: "emergency",
        emoji: "🚨",
        question: "What should I do in an electrical emergency?",
        answer: "Turn off the main breaker if it's safe to do so, avoid touching wet areas, and call us immediately at (555) 000-0000. We offer 24/7 emergency response.",
        followUp: "Still need help?",
    },
    {
        id: "quote",
        emoji: "💰",
        question: "How do I get a free quote?",
        answer: "Fill out our online form or call us at (555) 000-0000. We'll assess your project and provide a detailed, no-obligation estimate within 24 hours.",
        followUp: "Ready to get started?",
    },
    {
        id: "coupon",
        emoji: "✂️",
        question: "What coupons and discounts are available?",
        answer: "We offer seasonal promotions, first-time customer discounts, and special rates for seniors and military. Check our Specials page for current offers.",
        followUp: "Want to book now?",
    },
    {
        id: "schedule",
        emoji: "📅",
        question: "How do I schedule a service visit?",
        answer: "Call us at (555) 000-0000 or use our online booking form. We offer same-day service in most areas and flexible scheduling to fit your needs.",
        followUp: "Ready to schedule?",
    },
    {
        id: "warranty",
        emoji: "✅",
        question: "Do you offer warranties on your work?",
        answer: "Yes! All our work is backed by a 1-year warranty on labor and parts. We stand behind every job we do.",
        followUp: "Have more questions?",
    },
    {
        id: "licensed",
        emoji: "🔒",
        question: "Are you licensed and insured?",
        answer: "Absolutely. We're fully licensed, bonded, and insured. All our electricians are certified professionals with years of experience.",
        followUp: "Need anything else?",
    },
];
---

<!-- Floating trigger button -->
<button
    id="qh-trigger"
    class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-accent text-white shadow-lg shadow-primary/40 flex items-center justify-center transition-all duration-300 hover:scale-110 hover:shadow-primary/60"
    aria-label="Quick Help"
    aria-expanded="false"
    aria-controls="qh-panel"
>
    <!-- Chat icon (default) -->
    <svg
        id="qh-icon-chat"
        class="w-6 h-6"
        fill="currentColor"
        viewBox="0 0 24 24"
    >
        <path
            d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"
        ></path>
    </svg>
    <!-- Close icon (when open) -->
    <svg
        id="qh-icon-close"
        class="w-6 h-6 hidden"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
    >
        <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2.5"
            d="M6 18L18 6M6 6l12 12"></path>
    </svg>
</button>

<!-- Panel -->
<div
    id="qh-panel"
    class="fixed bottom-24 right-6 z-50 w-80 bg-white shadow-2xl overflow-hidden qh-panel-hidden"
    role="dialog"
    aria-label="Quick Help"
>
    <!-- Header -->
    <div class="bg-gradient-to-r from-accent to-primary px-5 py-4">
        <div class="flex items-center gap-2 mb-0.5">
            <svg
                class="w-4 h-4 text-white animate-pulse"
                fill="currentColor"
                viewBox="0 0 20 20"
            >
                <path
                    fill-rule="evenodd"
                    d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z"
                    clip-rule="evenodd"></path>
            </svg>
            <Heading level={4} class="!text-white !mb-0">Quick Help</Heading>
        </div>
        <Text size="sm" class="!text-white/80 !mt-0.5">Ask us anything</Text>
    </div>

    <!-- Content Area -->
    <div class="p-4 bg-gray-50 max-h-96 overflow-y-auto">
        <!-- Questions List (initial view) -->
        <div id="qh-questions-list" class="flex flex-col gap-2">
            {
                faqs.map((faq) => (
                    <button
                        class="qh-question-btn flex items-start gap-3 bg-white px-4 py-3 text-left text-sm font-medium text-text border-2 border-gray-100 shadow-sm hover:border-accent hover:bg-accent/5 transition-all duration-200 w-full"
                        data-faq-id={faq.id}
                    >
                        <span class="text-lg leading-none shrink-0">
                            {faq.emoji}
                        </span>
                        <span class="flex-1 text-left">{faq.question}</span>
                        <svg
                            class="w-4 h-4 text-accent shrink-0 mt-0.5 transition-transform"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 5l7 7-7 7"
                            />
                        </svg>
                    </button>
                ))
            }
        </div>

        <!-- Answer View (hidden initially) -->
        <div id="qh-answer-view" class="hidden">
            <!-- Back button -->
            <button
                id="qh-back-btn"
                class="flex items-center gap-2 text-accent text-sm font-semibold mb-4 hover:gap-3 transition-all duration-200 hover:text-accent/80"
            >
                <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 19l-7-7 7-7"></path>
                </svg>
                Back to questions
            </button>

            <!-- Question -->
            <div class="mb-4">
                <div class="flex items-start gap-3 mb-3">
                    <span id="qh-answer-emoji" class="text-2xl leading-none"
                        >🚨</span
                    >
                    <h5
                        id="qh-answer-question"
                        class="font-heading font-bold text-text text-base leading-snug"
                    >
                        Question here
                    </h5>
                </div>
            </div>

            <!-- Answer -->
            <div class="bg-white border-2 border-accent/20 p-4 mb-4 rounded-sm">
                <p
                    id="qh-answer-text"
                    class="text-sm text-gray-700 leading-relaxed"
                >
                    Answer here
                </p>
            </div>

            <!-- Follow-up -->
            <div class="space-y-2">
                <p
                    id="qh-followup-text"
                    class="text-xs text-accent font-semibold uppercase tracking-wider"
                >
                    Still need help?
                </p>
                <Button
                    href="/contact"
                    variant="accent"
                    size="md"
                    class="w-full uppercase tracking-wider font-bold shadow-md hover:shadow-lg hover:shadow-accent/30"
                >
                    Contact Us
                </Button>
            </div>
        </div>
    </div>
</div>

<script>
    const trigger = document.getElementById("qh-trigger");
    const panel = document.getElementById("qh-panel");
    const iconChat = document.getElementById("qh-icon-chat");
    const iconClose = document.getElementById("qh-icon-close");
    const questionsList = document.getElementById("qh-questions-list");
    const answerView = document.getElementById("qh-answer-view");
    const backBtn = document.getElementById("qh-back-btn");
    const questionBtns = document.querySelectorAll(".qh-question-btn");

    // FAQ data
    const faqData: Record<string, any> = {
        emergency: {
            emoji: "🚨",
            question: "What should I do in an electrical emergency?",
            answer: "Turn off the main breaker if it's safe to do so, avoid touching wet areas, and call us immediately at (555) 000-0000. We offer 24/7 emergency response.",
            followUp: "Still need help?",
        },
        quote: {
            emoji: "💰",
            question: "How do I get a free quote?",
            answer: "Fill out our online form or call us at (555) 000-0000. We'll assess your project and provide a detailed, no-obligation estimate within 24 hours.",
            followUp: "Ready to get started?",
        },
        coupon: {
            emoji: "✂️",
            question: "What coupons and discounts are available?",
            answer: "We offer seasonal promotions, first-time customer discounts, and special rates for seniors and military. Check our Specials page for current offers.",
            followUp: "Want to book now?",
        },
        schedule: {
            emoji: "📅",
            question: "How do I schedule a service visit?",
            answer: "Call us at (555) 000-0000 or use our online booking form. We offer same-day service in most areas and flexible scheduling to fit your needs.",
            followUp: "Ready to schedule?",
        },
        warranty: {
            emoji: "✅",
            question: "Do you offer warranties on your work?",
            answer: "Yes! All our work is backed by a 1-year warranty on labor and parts. We stand behind every job we do.",
            followUp: "Have more questions?",
        },
        licensed: {
            emoji: "🔒",
            question: "Are you licensed and insured?",
            answer: "Absolutely. We're fully licensed, bonded, and insured. All our electricians are certified professionals with years of experience.",
            followUp: "Need anything else?",
        },
    };

    let open = false;

    function togglePanel() {
        open = !open;
        trigger?.setAttribute("aria-expanded", String(open));

        if (open) {
            panel?.classList.replace("qh-panel-hidden", "qh-panel-visible");
            iconChat?.classList.add("hidden");
            iconClose?.classList.remove("hidden");
        } else {
            closePanel();
        }
    }

    function showAnswer(faqId: string) {
        const faq = faqData[faqId];
        if (!faq) return;

        // Update answer view with proper element selection
        const emojiEl = document.getElementById("qh-answer-emoji");
        const questionEl = document.getElementById("qh-answer-question");
        const answerEl = document.getElementById("qh-answer-text");
        const followUpEl = document.getElementById("qh-followup-text");

        if (emojiEl) emojiEl.textContent = faq.emoji;
        if (questionEl) questionEl.textContent = faq.question;
        if (answerEl) answerEl.textContent = faq.answer;
        if (followUpEl) followUpEl.textContent = faq.followUp;

        // Switch views
        questionsList?.classList.add("hidden");
        answerView?.classList.remove("hidden");
    }

    function backToQuestions() {
        questionsList?.classList.remove("hidden");
        answerView?.classList.add("hidden");
    }

    function closePanel() {
        open = false;
        panel?.classList.replace("qh-panel-visible", "qh-panel-hidden");
        iconChat?.classList.remove("hidden");
        iconClose?.classList.add("hidden");
        // Reset to questions list
        questionsList?.classList.remove("hidden");
        answerView?.classList.add("hidden");

        // Trigger coupon modal after panel closes
        setTimeout(() => {
            (window as any).couponModal?.open?.();
        }, 300);
    }

    // Event listeners
    trigger?.addEventListener("click", (e) => {
        e.stopPropagation();
        togglePanel();
    });

    backBtn?.addEventListener("click", (e) => {
        e.stopPropagation();
        backToQuestions();
    });

    // Question button clicks
    questionBtns.forEach((btn) => {
        btn.addEventListener("click", (e) => {
            e.stopPropagation();
            const faqId = (btn as HTMLElement).getAttribute("data-faq-id");
            if (faqId) showAnswer(faqId);
        });
    });

    // Close on outside click
    document.addEventListener("click", (e) => {
        if (
            open &&
            !panel?.contains(e.target as Node) &&
            !trigger?.contains(e.target as Node)
        ) {
            closePanel();
        }
    });

    // Close on Escape
    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && open) closePanel();
    });
</script>

<style>
    .qh-panel-hidden {
        opacity: 0;
        transform: translateY(12px) scale(0.97);
        pointer-events: none;
        transition:
            opacity 0.25s ease,
            transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .qh-panel-visible {
        opacity: 1;
        transform: translateY(0) scale(1);
        pointer-events: auto;
        transition:
            opacity 0.25s ease,
            transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
    }
</style>
