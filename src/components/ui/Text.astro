---
interface Props {
    size?: "sm" | "base" | "xl";
    class?: string;
    as?: "p" | "span" | "div";
}

const { size = "base", class: className = "", as = "p" } = Astro.props;

const Tag = as;

const sizes = {
    sm: "text-sm",
    base: "text-base",
    xl: "text-xl",
};

const classes = `font-body ${sizes[size]} ${className}`.replace(
    "text-text",
    "",
);
---

<Tag class={classes}>
    <slot />
</Tag>
