---
interface Props {
    name: string;
    size?: "sm" | "md" | "lg" | "xl";
    class?: string;
}

const { name, size = "md", class: className = "" } = Astro.props;

const sizes = {
    sm: "w-4 h-4",
    md: "w-6 h-6",
    lg: "w-8 h-8",
    xl: "w-12 h-12",
};

const classes = `inline-block ${sizes[size]} ${className}`;
---

<svg class={classes} aria-hidden="true">
    <use href={`#icon-${name}`}></use>
</svg>
