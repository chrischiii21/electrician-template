---
interface Props {
    level?: 1 | 2 | 3 | 4 | 5 | 6;
    class?: string;
    as?: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
    accent?: boolean;
    gradient?: boolean;
}

const {
    level = 2,
    class: className = "",
    as,
    accent = false,
    gradient = false,
} = Astro.props;

const Tag = as || `h${level}`;

const sizes = {
    1: "text-5xl",
    2: "text-4xl",
    3: "text-3xl",
    4: "text-2xl",
    5: "text-xl",
    6: "text-base",
};

const accentClass = accent ? "accent-underline pb-4" : "";
const gradientClass = gradient ? "text-gradient-brand" : "text-text";

const classes = `font-heading font-bold ${sizes[level]} ${accentClass} ${gradientClass} ${className}`;
---

<Tag class={classes}>
    <slot />
</Tag>
