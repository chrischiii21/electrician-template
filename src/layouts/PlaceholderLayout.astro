---
import BaseLayout from "./BaseLayout.astro";

interface Props {
    title: string;
    section?: string;
    description?: string;
}

const {
    title,
    section = "Page",
    description = "This page is currently under construction.",
} = Astro.props;
---

<BaseLayout title={`${title} | Electrician Services`}>
    <section
        class="bg-gray-900 min-h-screen flex items-center justify-center py-32 relative overflow-hidden"
        style="will-change: transform; transform: translateZ(0);"
    >
        <!-- Grid background -->
        <div
            class="absolute inset-0 opacity-10"
            style="background-image: linear-gradient(#F96939 1px, transparent 1px), linear-gradient(90deg, #F96939 1px, transparent 1px); background-size: 40px 40px;"
        >
        </div>

        <!-- Glow -->
        <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-primary/10 pointer-events-none"
            style="filter: blur(80px); will-change: transform;"
        >
        </div>

        <div class="relative text-center px-6 max-w-2xl mx-auto">
            <!-- Terminal badge -->
            <div
                class="inline-flex items-center gap-2 bg-gray-800 border border-gray-700 px-4 py-2 mb-8 font-mono text-xs text-gray-400"
            >
                <span class="w-2 h-2 bg-primary animate-pulse"></span>
                <span>STATUS: UNDER CONSTRUCTION</span>
            </div>

            <!-- Lightning bolt -->
            <div class="flex justify-center mb-6">
                <svg
                    class="w-16 h-16 text-primary"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                >
                    <path
                        fill-rule="evenodd"
                        d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z"
                        clip-rule="evenodd"></path>
                </svg>
            </div>

            <p
                class="text-primary font-semibold text-xs uppercase tracking-widest mb-3"
            >
                {section}
            </p>
            <h1
                class="font-heading font-bold text-4xl md:text-5xl text-white mb-4"
            >
                {title}
            </h1>
            <p class="text-gray-400 text-lg mb-10">{description}</p>

            <!-- Progress bar -->
            <div class="w-full bg-gray-800 h-1 mb-2 overflow-hidden">
                <div class="h-full bg-primary wiring-progress"></div>
            </div>
            <p class="text-xs text-gray-600 font-mono mb-10">
                Wiring in progress...
            </p>

            <!-- Actions -->
            <div
                class="flex flex-col sm:flex-row items-center justify-center gap-4"
            >
                <a
                    href="/"
                    class="inline-flex items-center gap-2 bg-primary text-white font-bold text-sm uppercase tracking-wider px-6 py-3 hover:bg-primary/90 transition-colors"
                >
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                    </svg>
                    Back to Home
                </a>
                <a
                    href="tel:+15550000000"
                    class="inline-flex items-center gap-2 border border-gray-600 text-gray-300 font-bold text-sm uppercase tracking-wider px-6 py-3 hover:border-primary hover:text-primary transition-colors"
                >
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                        ></path>
                    </svg>
                    Call Us Instead
                </a>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    .wiring-progress {
        width: 0%;
        animation: wire 3s cubic-bezier(0.4, 0, 0.2, 1) 0.5s forwards;
    }
    @keyframes wire {
        0% {
            width: 0%;
        }
        60% {
            width: 75%;
        }
        80% {
            width: 82%;
        }
        100% {
            width: 68%;
        }
    }
</style>
